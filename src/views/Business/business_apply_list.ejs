<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Danh sách ứng viên</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <div class="container my-5">
    <div class="card shadow-sm">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Danh sách ứng viên</h4>
      </div>

      <div class="card-body">
        <% if (applicants && applicants.length > 0) { %>

          <table class="table table-bordered table-striped">
            <thead>
              <tr>
                <th>Họ tên sinh viên</th>
                <th>ID</th>
                <th>Vị trí ứng tuyển</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
              </tr>
            </thead>

            <tbody>
              <% applicants.forEach(app => { %>
                <tr>
                  <td><%= app.SinhVien?.hoten %></td>
                  <td><%= app.SinhVien?.id %></td>
                  <td><%= app.JD?.ten_vi_tri %></td>
                  <td>
                    <span class="badge bg-info text-dark">
                      <%= app.trangthai %>
                    </span>
                  </td>
                  <td>
                    <a href="/student/viewCV/<%= app.SinhVien?.id %>" class="btn btn-sm btn-primary">
                      Xem CV
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

        <% } else { %>
          <div class="alert alert-warning">Không có ứng viên nào.</div>
        <% } %>
      </div>
    </div>
  </div>

</body>
</html>
