<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learn2Earn Business - Trang chủ</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        .header a {
            cursor: pointer;
        }

        /* Thêm cho dropdown item */
        .header .dropdown-item {
            cursor: pointer;
        }

        :root {
            --navy: #1e2a44;
            --navy-light: #2d3b57;
            --gray-bg: #f1f5f9;
            --card-bg: #ffffff;
            --text: #1e293b;
            --muted: #64748b;
            --dark-btn: #111827;
            --dark-btn-hover: #0f1623;
        }

        body {
            background: var(--gray-bg);
            font-family: "Inter", sans-serif;
            color: var(--text);
        }

        /* HEADER */
        .header {
            background: white;
            box-shadow: 0 2px 8px rgba(0, 0, 0, .08);
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .navbar-brand img {
            height: 55px;
            transform: scale(2.2);
            transform-origin: left center;
        }

        .nav-link {
            font-weight: 500;
            color: var(--muted) !important;
            border-radius: 14px;
            padding: 8px 18px !important;
        }

        .nav-link:hover {
            background: #e6ecf5;
            color: var(--navy) !important;
        }

        .nav-link.active {
            background: #dbe4f3;
            color: var(--navy) !important;
        }

        .nav-icon {
            width: 40px;
            height: 40px;
            background: #e6ecf5;
            color: var(--navy);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: 6px;
            font-size: 18px;
        }

        .nav-icon:hover {
            background: #d4dceb;
            color: var(--navy);
        }

        /* HERO */
        .hero-section {
            text-align: center;
            padding: 60px 0 40px;
        }

        .hero-title {
            font-size: 36px;
            font-weight: 700;
            color: var(--navy);
        }

        .hero-title span {
            background: linear-gradient(135deg, var(--navy), var(--navy-light));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .hero-sub {
            font-size: 16px;
            color: var(--muted);
            max-width: 600px;
            margin: 0 auto;
        }

        /* FEATURES */
        .feature-card {
            background: var(--card-bg);
            border-radius: 18px;
            padding: 24px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 6px 16px rgba(0, 0, 0, .06);
            text-align: center;
        }

        .feature-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 14px;
            border-radius: 50%;
            background: #e6ecf5;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            color: var(--navy);
        }

        .btn-main {
            width: 100%;
            padding: 12px 0;
            border-radius: 10px;
            background: var(--dark-btn);
            color: white;
            border: none;
            font-size: 15px;
            font-weight: 500;
        }

        .btn-main:hover {
            background: var(--dark-btn-hover);
        }

        /* FOOTER */
        .footer {
            background: #020617;
            color: #E5E7EB;
            padding: 40px 0 20px;
            margin-top: 60px;
        }

        .footer-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #fff;
        }

        .footer-links {
            list-style: none;
            padding: 0;
        }

        .footer-links li {
            margin-bottom: 6px;
        }

        .footer-links a {
            color: #E5E7EB;
            font-size: .9rem;
        }

        .footer-bottom {
            border-top: 1px solid #111827;
            margin-top: 20px;
            padding-top: 12px;
            text-align: center;
            font-size: .85rem;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <%- include('../ComponentBusiness/header') %>


        <!-- HERO -->
        <section class="hero-section">
            <h1 class="hero-title">
                Chào mừng đến với <span>Learn2Earn Business</span>
            </h1>
            <p class="hero-sub">
                Nền tảng hỗ trợ doanh nghiệp đăng tuyển – quản lý ứng viên – tối ưu tuyển dụng nhanh chóng và hiệu quả.
            </p>
        </section>

        <!-- FEATURES -->
        <div class="container my-4">
            <div class="row g-4">

                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="bi bi-file-earmark-plus"></i></div>
                        <h5>Đăng tin tuyển dụng</h5>
                        <p class="text-muted">Tạo tin tuyển dụng chỉ với vài bước đơn giản.</p>
                        <button class="btn-main" onclick="window.location.href='/Business/PostJob'">Bắt đầu
                            ngay</button>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="bi bi-people-fill"></i></div>
                        <h5>Quản lý ứng viên</h5>
                        <p class="text-muted">Xem CV – lọc ứng viên – liên hệ nhanh chóng.</p>
                        <button class="btn-main" onclick="window.location.href='/Business/ApplyList'">Xem ngay</button>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="bi bi-bar-chart-line"></i></div>
                        <h5>Thống kê tuyển dụng</h5>
                        <p class="text-muted">Theo dõi hiệu quả chiến dịch tuyển dụng.</p>
                        <button class="btn-main">Xem thống kê</button>
                    </div>
                </div>

            </div>
        </div>

        <!-- FOOTER -->
        <%- include('../ComponentBusiness/footer') %>


</body>

</html>