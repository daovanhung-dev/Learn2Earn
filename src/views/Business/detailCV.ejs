<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>Chi tiết CV</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root{
      --accent:#0ea5a4;
      --muted:#6b7280;
      --card-shadow: 0 8px 28px rgba(2,6,23,0.06);
      --bg:#f6fbfb;
    }
    body{ background:var(--bg); font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial; color:#111827; }
    .cv-card{ border-radius:12px; box-shadow:var(--card-shadow); overflow:hidden; }
    .left-side{ background:linear-gradient(180deg, rgba(14,165,164,0.06), #fff); padding:32px; }
    .avatar{ width:112px; height:112px; object-fit:cover; border-radius:999px; border:4px solid rgba(255,255,255,0.7); box-shadow:0 6px 18px rgba(2,6,23,0.06); }
    .name { font-size:1.4rem; font-weight:700; color:var(--accent); margin-top:12px; }
    .role { color:var(--muted); margin-bottom:12px; }
    .info-row { margin-bottom:10px; }
    .info-label{ font-weight:600; color:#374151; font-size:0.9rem; }
    .info-val{ color:#374151; font-size:0.96rem; }
    .tag { display:inline-block; margin:4px 6px 4px 0; padding:6px 10px; border-radius:999px; background:#ecfdf5; color:var(--accent); font-weight:600; font-size:.85rem; }
    .section-title{ font-weight:700; color:#0f172a; margin-bottom:8px; }
    .muted{ color:var(--muted); font-size:0.9rem; }
    .actions .btn{ border-radius:8px; }
    .divider{ height:1px; background:#eef2f7; margin:18px 0; border-radius:4px; }
    @media (max-width: 991px){
      .left-side{ text-align:center; padding-bottom:22px; }
      .avatar{ margin:0 auto; }
      .actions { margin-top:12px; }
    }
  </style>
</head>
<body>
    <%- include('../ComponentBusiness/header') %>

<% 
  // safe CV object
  const C = (typeof cv !== 'undefined' && cv) ? cv : {};

  // format date safely (return dd/mm/YYYY for UX)
  function fmtDate(d){
    if (!d) return '---';
    try {
      const dt = (d instanceof Date) ? d : new Date(d);
      if (Number.isNaN(dt.getTime())) return '---';
      const dd = String(dt.getDate()).padStart(2,'0');
      const mm = String(dt.getMonth()+1).padStart(2,'0');
      const yyyy = dt.getFullYear();
      return `${dd}/${mm}/${yyyy}`;
    } catch(e){
      return '---';
    }
  }

  function safe(v){ if (v === 0) return '0'; return (v || v === '') ? String(v) : '---'; }

  // skills parsing helper
  function parseSkills(s){
    if (!s) return [];
    if (Array.isArray(s)) return s.map(x=>String(x).trim()).filter(Boolean);
    return String(s).split(/[,;|]/).map(x=>x.trim()).filter(Boolean);
  }
%>

<div class="container my-5">
  <div class="cv-card row g-0">
    <!-- Left -->
    <div class="col-lg-4 left-side d-flex flex-column align-items-start">
      <img src="<%= C.avt || '/img/default-avt.png' %>" alt="avatar" class="avatar mb-2">
      <div class="name"><%= safe(C.hoten === 'undefined' ? '' : C.hoten) %></div>
      <div class="role"><%= C.vitri || 'Vị trí mong muốn chưa cập nhật' %></div>

      <div class="divider w-100"></div>

      <div class="w-100">
        <div class="info-row">
          <div class="info-label">Email</div>
          <div class="info-val"><%= C.email || '---' %></div>
        </div>

        <div class="info-row">
          <div class="info-label">Số điện thoại</div>
          <div class="info-val"><%= C.sdt || '---' %></div>
        </div>

        <div class="info-row">
          <div class="info-label">Địa chỉ</div>
          <div class="info-val"><%= C.diachi || '---' %></div>
        </div>

        <div class="info-row">
          <div class="info-label">Ngày sinh</div>
          <div class="info-val"><%= fmtDate(C.ngaysinh) %></div>
        </div>

        <div class="info-row">
          <div class="info-label">Giới tính</div>
          <div class="info-val"><%= C.gioitinh || '---' %></div>
        </div>
      </div>

      <div class="divider w-100"></div>

      <div class="w-100 actions d-flex gap-2">
        <a href="/student/dashboard" class="btn btn-light w-50">Quay lại</a>
        <% if (C.portfolio) { %>
          <a href="<%= C.portfolio %>" target="_blank" class="btn btn-outline-success w-50">Portfolio</a>
        <% } else { %>
          <button class="btn btn-outline-secondary w-50" disabled>Portfolio</button>
        <% } %>
      </div>

      <div class="mt-3 muted small w-100">ID: <strong><%= (typeof C.id !== 'undefined' && C.id !== null) ? String(C.id) : '---' %></strong></div>
    </div>

    <!-- Right -->
    <div class="col-lg-8 p-4">
      <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
          <h4 style="margin:0">Hồ sơ ứng viên</h4>
          <div class="muted">Chi tiết CV — <span class="small-muted"><%= C.nganh || 'Ngành chưa cập nhật' %></span></div>
        </div>
        <div class="text-end muted small"><em>cập nhật: <%= (C.updatedAt ? fmtDate(C.updatedAt) : '---') %></em></div>
      </div>

      <section class="mb-3">
        <div class="section-title">Mục tiêu nghề nghiệp</div>
        <div class="muted"><%= C.muctieunghiep || '---' %></div>
      </section>

      <section class="mb-3">
        <div class="section-title">Học vấn</div>
        <div class="muted"><%= C.hocvan || '---' %></div>
      </section>

      <section class="mb-3">
        <div class="section-title">Kinh nghiệm</div>
        <div class="muted"><%= C.kinhnghiem || '---' %></div>
      </section>

      <section class="mb-3">
        <div class="section-title">Kỹ năng</div>
        <div>
          <% const skills = parseSkills(C.kynang); %>
          <% if (skills.length === 0) { %>
            <div class="muted">---</div>
          <% } else { %>
            <% skills.forEach(s => { %>
              <span class="tag"><%= s %></span>
            <% }) %>
          <% } %>
        </div>
      </section>

      <section class="mb-3">
        <div class="section-title">Ngoại ngữ</div>
        <div class="muted"><%= C.ngoaingu || '---' %></div>
      </section>

      <section class="mb-3">
        <div class="section-title">Chứng chỉ</div>
        <div class="muted"><%= C.chungchi || '---' %></div>
      </section>

      <section class="mb-3">
        <div class="section-title">Dự án tiêu biểu</div>
        <div class="muted"><%= C.duan || '---' %></div>
      </section>

      <section class="mb-0">
        <div class="section-title">Giải thưởng / Hoạt động</div>
        <div class="muted"><%= (C.giaithuong || '') + (C.hoatdong ? (' — ' + C.hoatdong) : '') || '---' %></div>
      </section>
    </div>
  </div>
</div>
        <%- include('../ComponentBusiness/footer') %>

</body>
</html>
