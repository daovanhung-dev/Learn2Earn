<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>
    <%= jd.ten_vi_tri || "Chi tiết tuyển dụng" %>
  </title>

  <!-- Fonts & Icons like home.ejs -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap"
    rel="stylesheet">

  <!-- ===== STYLES (giữ nguyên các style bạn đặt) ===== -->
  <style>
    /* Cho phép TẤT CẢ thẻ <a> trong header hiển thị con trỏ dạng chọn */
    .header a {
      cursor: pointer;
    }

    /* Thêm cho dropdown item */
    .header .dropdown-item {
      cursor: pointer;
    }

    :root {
      --primary: #2563EB;
      --primary-soft: #EFF6FF;
      --primary-strong: #1D4ED8;
      --neutral: #64748B;
      --bg: #F8FAFC;
      --card: #FFFFFF;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: #1E293B;
      line-height: 1.6;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-family: 'Poppins', sans-serif;
      font-weight: 600
    }

    a {
      text-decoration: none
    }

    /* HEADER */
    .header {
      background: #fff;
      box-shadow: 0 2px 8px rgba(15, 23, 42, .08);
      position: sticky;
      top: 0;
      z-index: 1000
    }

    .navbar {
      padding: .7rem 0
    }

    .navbar-brand {
      display: flex;
      align-items: center
    }

    .logo-img {
      display: flex;
      align-items: center;
      justify-content: center
    }

    .brand-logo {
      height: 60px;
      width: auto;
      object-fit: contain;
      transform: scale(2.2);
      transform-origin: left center
    }

    .navbar-nav .nav-link {
      font-weight: 500;
      font-size: .95rem;
      color: #475569;
      padding: 8px 14px;
      border-radius: 999px;
    }

    .navbar-nav .nav-link:hover {
      background: var(--primary-soft);
      color: var(--primary)
    }

    .navbar-nav .nav-link.active {
      background: #DBEAFE;
      color: var(--primary-strong)
    }

    .nav-icon {
      width: 38px;
      height: 38px;
      margin: 0 6px;
      border-radius: 50%;
      background: #E2E8F0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #475569;
      font-size: 18px;
    }

    .nav-icon:hover {
      background: #CBD5E1;
      color: var(--primary)
    }

    .l2e-dropdown:hover .dropdown-menu {
      display: block
    }

    .dropdown-menu {
      border-radius: 12px;
      border: 1px solid #E5E7EB
    }

    .dropdown-item {
      font-size: .9rem
    }

    /* HERO */
    .hero-section {
      background: radial-gradient(circle at top left, #e0f2fe 0, #f8fafc 50%, #ffffff 100%);
      padding: 70px 0 45px;
    }

    .hero-title {
      font-size: 38px;
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 16px;
    }

    .hero-title span {
      background: linear-gradient(135deg, #3B82F6, #1D4ED8);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      border: 1px solid #BFDBFE;
      background: #EFF6FF;
      font-size: .85rem;
      color: var(--primary-strong);
      margin-bottom: 12px;
    }

    .hero-subtitle {
      font-size: 16px;
      color: #64748B;
      max-width: 640px;
      margin: 0 auto 24px;
    }

    .hero-stats {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 16px;
      font-size: .9rem;
      color: #475569;
    }

    .hero-stat-pill {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 14px;
      border-radius: 999px;
      background: #fff;
      border: 1px solid #E2E8F0;
    }

    .hero-stat-pill span:first-child {
      font-weight: 600;
      color: var(--primary)
    }

    /* SEARCH */
    .search-section {
      margin-top: -26px
    }

    .search-box {
      background: #fff;
      border-radius: 18px;
      padding: 20px;
      border: 1px solid #E2E8F0;
    }

    .search-form .form-control {
      border-radius: 12px;
      border: 1px solid #E2E8F0;
      font-size: .95rem;
    }

    .search-form .input-group-text {
      border-radius: 12px 0 0 12px;
      border: 1px solid #E2E8F0;
      border-right: 0;
      background: #F8FAFC;
      color: #94A3B8;
    }

    .search-form .input-group .form-control {
      border-left: 0;
      border-radius: 0 12px 12px 0;
    }

    .btn-search {
      width: 100%;
      border: 0;
      border-radius: 12px;
      padding: 10px 20px;
      font-weight: 600;
      font-size: .95rem;
      color: #fff;
      background: linear-gradient(135deg, #3B82F6, #2563EB);
    }

    .search-helper {
      margin-top: 8px;
      font-size: .85rem;
      color: #64748B;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: space-between;
    }

    .search-helper strong {
      color: #2563EB
    }

    /* FILTER TABS */
    .filter-tabs {
      margin: 28px 0 16px
    }

    .filter-meta {
      font-size: .9rem;
      color: #64748B
    }

    .nav-chips .nav-link {
      background: #E5E7EB;
      border-radius: 999px;
      padding: 6px 16px;
      font-size: .9rem;
      font-weight: 500;
      color: #334155;
      margin: 0 6px 6px 0;
    }

    .nav-chips .nav-link.active {
      background: #2563EB;
      color: #fff;
    }

    /* SIDEBAR */
    .sidebar-card {
      background: #fff;
      border-radius: 18px;
      border: 1px solid #E2E8F0;
      margin-bottom: 20px;
    }

    .sidebar-card .card-header {
      border-bottom: 1px solid #E2E8F0;
      padding: 14px 18px;
      font-weight: 600;
      display: flex;
      justify-content: space-between;
    }

    .filter-label {
      font-size: 15px;
      font-weight: 600;
      margin-bottom: 8px
    }

    .filter-group {
      padding-bottom: 14px;
      margin-bottom: 14px;
      border-bottom: 1px solid #E2E8F0
    }

    .filter-group:last-child {
      border-bottom: 0;
      margin-bottom: 0;
      padding-bottom: 0
    }

    .form-check {
      font-size: .9rem;
      margin-bottom: 6px
    }

    .btn-clear {
      width: 100%;
      border-radius: 999px;
      padding: 8px 16px;
      font-size: .9rem;
      font-weight: 500;
      border: 1px solid #E2E8F0;
      background: #F1F5F9;
    }

    /* JOB LIST */
    .jobs-header {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 12px;
    }

    .jobs-title {
      font-size: 18px;
      font-weight: 600
    }

    .jobs-title span {
      color: #2563EB
    }

    .jobs-subtitle {
      font-size: .9rem;
      color: #64748B
    }

    .result-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      border-radius: 999px;
      background: #EFF6FF;
      color: #2563EB;
      font-size: .85rem;
    }

    .job-card {
      border-radius: 16px;
      background: #fff;
      border: 1px solid #E2E8F0;
      margin-bottom: 14px;
    }

    .job-card .card-body {
      padding: 16px
    }

    .job-logo {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      background: #EFF6FF;
      color: #2563EB;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      margin-right: 14px;
    }

    .job-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 4px
    }

    .job-company {
      font-size: .9rem;
      color: #6B7280;
      margin-bottom: 8px
    }

    .job-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 8px
    }

    .job-meta-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: .8rem;
      background: #F1F5F9;
      border-radius: 999px;
      padding: 4px 8px;
    }

    .job-salary {
      font-weight: 600;
      color: #F97316
    }

    .job-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 6px
    }

    .job-tag {
      font-size: .8rem;
      padding: 3px 9px;
      border-radius: 999px;
      background: #EFF6FF;
      color: #2563EB;
      font-weight: 500;
    }

    .job-time {
      font-size: .8rem;
      color: #6B7280
    }

    .job-actions {
      display: flex;
      flex-direction: column;
      gap: 6px;
      justify-content: center;
      height: 100%
    }

    .btn-apply,
    .btn-quick-view {
      font-size: .9rem
    }

    .btn-apply {
      background: linear-gradient(135deg, #3B82F6, #2563EB);
      color: #fff;
      border-radius: 999px;
      border: 0;
      padding: 8px 16px;
    }

    .btn-quick-view {
      border-radius: 999px;
      border: 1px solid #BFDBFE;
      padding: 7px 14px;
      color: #2563EB;
      background: #fff;
    }

    /* PAGINATION */
    .pagination {
      justify-content: center;
      margin-top: 22px
    }

    .page-link {
      border-radius: 999px;
      font-size: .9rem;
      padding: 6px 12px;
      margin: 0 3px;
      color: #475569;
      border: 1px solid #E2E8F0;
    }

    .page-item.active .page-link {
      background: #2563EB;
      border-color: #2563EB;
      color: #fff;
    }

    /* FOOTER */
    .footer {
      background: #020617;
      color: #E5E7EB;
      padding: 40px 0 22px;
      margin-top: 60px;
    }

    .footer-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 12px;
      color: #fff
    }

    .footer p,
    .footer-links li {
      font-size: .9rem
    }

    .footer-links {
      list-style: none;
      padding: 0;
      margin: 0
    }

    .footer-links li {
      margin-bottom: 6px
    }

    .footer-links a {
      color: #E5E7EB
    }

    .footer-bottom {
      border-top: 1px solid #111827;
      margin-top: 20px;
      padding-top: 14px;
      text-align: center;
      font-size: .85rem;
    }

    @media (max-width:992px) {
      .hero-title {
        font-size: 32px
      }
    }

    @media (max-width:768px) {
      .hero-section {
        padding: 55px 0 32px
      }

      .job-card .card-body {
        padding: 14px
      }

      .job-actions {
        margin-top: 8px
      }
    }
  </style>

  <style>
    :root {
      --primary: #2563EB;
      --primary-soft: #EFF6FF;
      --neutral: #64748B;
      --bg: #F8FAFC;
      --card: #FFFFFF;
    }

    * {
      box-sizing: border-box
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: #0F172A;
      margin: 0;
      padding: 20px
    }

    h1,
    h2,
    h3,
    h4 {
      font-family: 'Poppins', sans-serif
    }

    .card-job {
      border-radius: 14px;
      border: 1px solid #E2E8F0;
      background: var(--card);
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04)
    }

    .avatar {
      width: 140px;
      height: 140px;
      object-fit: cover;
      border-radius: 12px
    }

    .company-name {
      font-weight: 700;
      margin-top: 8px
    }

    .company-meta {
      color: var(--neutral);
      font-size: 0.92rem
    }

    .label {
      font-weight: 600;
      color: #0F172A;
      width: 150px
    }

    .value {
      word-break: break-word
    }

    .job-header {
      display: flex;
      align-items: center;
      gap: 16px
    }

    .job-title {
      font-size: 1.35rem;
