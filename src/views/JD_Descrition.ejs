    .desc {
      white-space: pre-wrap
    }

    @media (max-width:992px) {
      .avatar {
        width: 110px;
        height: 110px
      }

      .label {
        width: 130px
      }

      .sticky-apply {
        position: static;
        margin-top: 12px
      }
    }
  </style>
</head>

<body>
  <header class="header">
    <nav class="navbar navbar-expand-lg navbar-light">
      <div class="container">

        <!-- Logo -->
        <a class="navbar-brand" role="button" data-route="/Student/Home" onclick="navigateTo('/Student/Home')">
          <img src="/img/logo-nobr.png" alt="Logo Learn2Earn" class="brand-logo">
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
          aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
          <!-- MENU CHÍNH -->
          <ul class="navbar-nav mx-auto d-flex align-items-center">
            <li class="nav-item">
              <a class="nav-link" data-route="/Student/Home" onclick="navigateTo('/Student/Home')">Trang chủ</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" data-route="/Student/Profile" onclick="navigateTo('/Student/Profile')">Hồ sơ</a>
            </li>

            <!-- DROPDOWN CV -->
            <li class="nav-item dropdown l2e-dropdown">
              <a class="nav-link dropdown-toggle" onclick="window.location.href=''" id="cvMenu">CV</a>
            </li>

            <li class="nav-item">
              <a class="nav-link" data-route="/Student/Interview" onclick="navigateTo('/Student/Interview')">Lịch phỏng
                vấn</a>
            </li>

            <li class="nav-item">
              <a class="nav-link" data-route="/Student/PostJobs" onclick="navigateTo('/Student/PostJobs')">Tin tuyển
                dụng</a>
            </li>
          </ul>

          <!-- ICON PHẢI -->
          <ul class="navbar-nav ms-auto d-flex align-items-center">
            <li class="nav-item">
              <a class="nav-icon" role="button" data-route="/Student/Noti" onclick="navigateTo('/Student/Noti')">
                <i class="bi bi-bell"></i>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-icon" role="button" data-route="/Student/Chat" onclick="navigateTo('/Student/Chat')">
                <i class="bi bi-chat-dots"></i>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" data-route="/Student/Setting" onclick="navigateTo('/Student/Setting')">Cài đặt</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <script>
      // chuyển trang với fade-out
      function navigateTo(url) {
        // nếu đang ở cùng trang thì không reload
        if (location.pathname === url || location.pathname.endsWith(url)) {
          return;
        }
        document.body.style.transition = 'opacity 0.25s';
        document.body.style.opacity = '0';
        setTimeout(() => { window.location.href = url; }, 220);
      }

      // tự động highlight menu theo current path (dùng data-route)
      function setActiveNavByPath() {
        const links = document.querySelectorAll('[data-route]');
        const path = location.pathname || '/';
        // mapping: nếu path là '/' thì treat as '/Student/Home'
        links.forEach(a => a.classList.remove('active'));
        // Try exact then contains
        let found = false;
        links.forEach(a => {
          const r = a.getAttribute('data-route');
          if (!r) return;
          if (path === r || path.endsWith(r) || path.includes(r)) {
            a.classList.add('active');
            found = true;
          }
        });
        if (!found) {
          // fallback: highlight Trang chủ if on base / or not matched
          const home = document.querySelector('[data-route="/Student/Home"]');
          if (home) home.classList.add('active');
        }
      }

      // close dropdown on small screens when collapsed by bootstrap automatically,
      // but ensure hover dropdown doesn't permanently display after window resize
      function resetDropdownsOnResize() {
        document.querySelectorAll('.dropdown-menu').forEach(dm => {
          if (window.innerWidth <= 992) {
            dm.style.display = '';
          }
        });
      }

      document.addEventListener('DOMContentLoaded', () => {
        setActiveNavByPath();
        window.addEventListener('popstate', setActiveNavByPath);
        window.addEventListener('resize', resetDropdownsOnResize);
      });
    </script>
  </header>

  <div class="container">
    <% 
      // helpers: định nghĩa trước khi dùng
      const fmt = (d) => {
        if (!d) return '';
        const date = new Date(d);
        if (isNaN(date.getTime())) return String(d);
        return date.toLocaleDateString('vi-VN');
      };

      const show = (v) => (v === null || v === undefined || v === '') ? false : true;
      const nl2br = (s) => s ? String(s).replace(/\r\n|\r|\n/g, '<br />') : '';
    %>

    <div class="card card-body card-job mt-4">
      <div class="row g-3">
        <div class="col-lg-8">
          <div class="job-header">
            <div class="d-flex align-items-center">
              <% if (show(jd.avt)) { %>
                <img src="<%= jd.avt.startsWith('http') ? jd.avt : ('/uploads/' + jd.avt) %>" alt="Logo công ty"
                  class="avatar me-3" />
              <% } else { %>
                <div class="avatar d-flex align-items-center justify-content-center bg-white border text-muted me-3">
                  <i class="fa-solid fa-building fa-2x"></i>
                </div>
              <% } %>
            </div>

            <div>
              <div class="job-title">
                <%= jd.ten_vi_tri || 'Vị trí' %>
              </div>
              <% if (show(jd.ten_cong_ty)) { %>
                <div class="company-name">
                  <%= jd.ten_cong_ty %>
                </div>
              <% } %>

              <div class="job-sub">
                <% if (show(jd.dia_diem)) { %><i class="fa-solid fa-location-dot me-1"></i>
                  <%= jd.dia_diem %> · <% } %>
                <% if (show(jd.thoi_gian)) { %><i class="fa-regular fa-clock me-1"></i>
                  <%= jd.thoi_gian %>
                <% } %>
              </div>

              <div class="mt-2 tags">
                <% if (show(jd.cap_bac)) { %><span class="tag"><%= jd.cap_bac %></span><% } %>
                <% if (show(jd.nganh)) { %><span class="tag"><%= jd.nganh %></span><% } %>
                <% if (show(jd.muc_luong)) { %><span class="tag job-salary"><%= jd.muc_luong %></span><% } %>
              </div>
            </div>
          </div>

          <hr />

          <% if (show(jd.nhiem_vu)) { %>
            <div>
              <div class="section-title">Nhiệm vụ chính</div>
              <div class="desc mb-3"><%- nl2br(jd.nhiem_vu) %></div>
            </div>
          <% } %>

          <% if (show(jd.trinh_do) || show(jd.kinh_nghiem) || show(jd.ky_nang) || show(jd.ky_nang_mem)) { %>
            <div>
              <div class="section-title">Yêu cầu</div>
              <ul>
                <% if (show(jd.trinh_do)) { %>
                  <li>Trình độ: <%= jd.trinh_do %></li>
                <% } %>
                <% if (show(jd.kinh_nghiem)) { %>
                  <li>Kinh nghiệm: <%= jd.kinh_nghiem %></li>
                <% } %>
                <% if (show(jd.ky_nang)) { %>
                  <li>Kỹ năng chuyên môn: <%= jd.ky_nang %></li>
                <% } %>
                <% if (show(jd.ky_nang_mem)) { %>
                  <li>Kỹ năng mềm: <%= jd.ky_nang_mem %></li>
                <% } %>
              </ul>
            </div>
          <% } %>

          <% if (show(jd.moi_truong)) { %>
            <div>
              <div class="section-title">Môi trường làm việc</div>
              <div class="desc mb-3"><%- nl2br(jd.moi_truong) %></div>
            </div>
          <% } %>

          <% if (show(jd.mo_ta)) { %>
            <div>
              <div class="section-title">Mô tả chi tiết</div>
              <div class="desc mb-3"><%- nl2br(jd.mo_ta) %></div>
            </div>
          <% } %>

          <div class="text-muted small">Tạo: <%= fmt(jd.ngay_tao) %></div>

        </div>

        <div class="col-lg-4">
          <!-- Right column: apply box + meta -->
          <div class="sticky-apply">
            <div class="card p-3 mb-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                  <div class="small text-muted">Mức lương</div>
                  <div class="job-salary">
                    <%= jd.muc_luong || 'Thương lượng' %>
                  </div>
                </div>
                <div class="text-end">
                  <div class="small text-muted">Hạn nộp</div>
                  <div>
                    <%= jd.han_nop ? fmt(jd.han_nop) : 'Không rõ' %>
                  </div>
                </div>
              </div>

              <div class="d-grid gap-2">
                <a href="/student/CandidateJD/<%= jd.doanhnghiep_id %>" class="btn btn-apply">Ứng tuyển ngay</a>
                <a href="/student/home" class="btn btn-outline-secondary btn-back">Quay lại danh sách</a>
              </div>

              <% if (show(jd.cach_ung_tuyen)) { %>
                <div class="mt-3 small text-muted">Cách ứng tuyển:</div>
                <div class="small"><%= jd.cach_ung_tuyen %></div>
              <% } %>

              <% if (show(jd.uu_tien)) { %>
                <div class="mt-3 small text-muted">Ưu tiên:</div>
                <div class="small"><%= jd.uu_tien %></div>
              <% } %>

            </div>

            <!-- compact info card -->
            <div class="card p-3">
              <div class="small text-muted mb-2">Liên hệ</div>
              <% if (show(jd.ten_cong_ty)) { %>
                <div class="mb-1"><strong><%= jd.ten_cong_ty %></strong></div>
              <% } %>
              <% if (show(jd.dia_chi)) { %>
                <div class="small mb-1"><i class="fa-solid fa-map-marker-alt me-1"></i><%= jd.dia_chi %></div>
              <% } %>
              <% if (show(jd.lien_he)) { %>
                <div class="small mb-1"><i class="fa-solid fa-phone me-1"></i><%= jd.lien_he %></div>
              <% } %>
              <% if (show(jd.email)) { %>
                <div class="small"><i class="fa-regular fa-envelope me-1"></i><%= jd.email %></div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- bootstrap js: cần ở cuối body để collapse hoạt động -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
