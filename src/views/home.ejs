<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Learn2Earn – Tìm Việc Làm Nhanh Chóng & Hiệu Quả</title>

  <!-- Bootstrap + Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <!-- Google Fonts -->
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap"
    rel="stylesheet">

  <style>
    /* ====== VARIABLES & RESET ====== */
    :root {
      --primary-50: #EFF6FF;
      --primary-100: #DBEAFE;
      --primary-200: #BFDBFE;
      --primary-300: #93C5FD;
      --primary-400: #60A5FA;
      --primary-500: #3B82F6;
      --primary-600: #2563EB;
      --primary-700: #1D4ED8;
      --primary-800: #1E40AF;
      --primary-900: #1E3A8A;

      --neutral-50: #F8FAFC;
      --neutral-100: #F1F5F9;
      --neutral-200: #E2E8F0;
      --neutral-300: #CBD5E1;
      --neutral-400: #94A3B8;
      --neutral-500: #64748B;
      --neutral-600: #475569;
      --neutral-700: #334155;
      --neutral-800: #1E293B;
      --neutral-900: #0F172A;

      --accent-400: #FB923C;
      --accent-500: #F97316;
      --accent-600: #EA580C;

      --primary-gradient: linear-gradient(135deg, var(--primary-500) 0%, var(--primary-600) 100%);
      --primary-gradient-hover: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-700) 100%);
      --light-gradient: radial-gradient(circle at top left, #e0f2fe 0, #f8fafc 45%, #ffffff 100%);

      --card-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
      --card-shadow-hover: 0 18px 40px rgba(15, 23, 42, 0.12);
      --input-shadow: 0 4px 12px rgba(59, 130, 246, 0.12);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--neutral-50);
      color: var(--neutral-800);
      line-height: 1.6;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-family: 'Poppins', sans-serif;
      font-weight: 600;
    }

    a {
      text-decoration: none;
    }

    /* ====== HEADER & NAVIGATION ====== */
    .header {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(18px);
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .navbar {
      padding-top: 0.8rem;
      padding-bottom: 0.8rem;
    }

    .navbar-brand {
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      font-size: 24px;
      color: var(--primary-700);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .brand-logo {
      height: 60px;
      width: auto;
      display: block;
      object-fit: contain;

      transform: scale(2.3);
      transform-origin: left center;
    }

    .navbar {
      padding-top: 0.6rem;
      padding-bottom: 0.6rem;
    }

    .navbar-brand {
      padding-top: 0;
      padding-bottom: 0;
    }

    .navbar-nav .nav-link {
      font-weight: 500;
      color: var(--neutral-600);
      padding: 8px 14px;
      border-radius: 999px;
      transition: all 0.25s ease;
      position: relative;
      font-size: 0.95rem;
    }

    .navbar-nav .nav-link:hover {
      color: var(--primary-600);
      background: var(--primary-50);
    }

    .navbar-nav .nav-link.active {
      color: var(--primary-700);
      background: var(--primary-100);
    }

    .btn-auth {
      border-radius: 999px;
      font-weight: 500;
      padding: 8px 18px;
      font-size: 0.95rem;
      transition: all 0.25s ease;
    }

    .btn-login {
      color: var(--primary-600);
      border: 1px solid var(--primary-200);
      background: #fff;
    }

    .btn-login:hover {
      background: var(--primary-50);
      border-color: var(--primary-300);
    }

    .btn-signup {
      background: var(--primary-gradient);
      color: white;
      border: none;
      box-shadow: 0 10px 24px rgba(37, 99, 235, 0.45);
    }

    .btn-signup:hover {
      background: var(--primary-gradient-hover);
      transform: translateY(-1px);
      box-shadow: 0 14px 30px rgba(37, 99, 235, 0.6);
    }

    /* ====== HERO SECTION ====== */
    .hero-section {
      background: var(--light-gradient);
      padding: 80px 0 50px;
      position: relative;
      overflow: hidden;
    }

    .hero-section::before,
    .hero-section::after {
      content: '';
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
      opacity: 0.35;
    }

    .hero-section::before {
      top: -120px;
      right: -80px;
      width: 260px;
      height: 260px;
      background: rgba(59, 130, 246, 0.35);
    }

    .hero-section::after {
      bottom: -120px;
      left: -60px;
      width: 260px;
      height: 260px;
      background: rgba(59, 130, 246, 0.18);
    }

    .hero-content {
      position: relative;
      z-index: 2;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(37, 99, 235, 0.06);
      border: 1px solid rgba(59, 130, 246, 0.15);
      font-size: 0.85rem;
      color: var(--primary-700);
      margin-bottom: 14px;
    }

    .hero-badge i {
      font-size: 0.9rem;
    }

    .hero-title {
      font-family: 'Poppins', sans-serif;
      font-size: 42px;
      font-weight: 700;
      margin-bottom: 16px;
      color: var(--neutral-900);
      line-height: 1.25;
    }

    .hero-title span {
      background: var(--primary-gradient);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-subtitle {
      font-size: 18px;
      color: var(--neutral-600);
      margin-bottom: 28px;
      max-width: 640px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      font-size: 0.9rem;
      color: var(--neutral-600);
    }

    .hero-stat-pill {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.75);
      border: 1px solid rgba(226, 232, 240, 0.9);
      box-shadow: 0 6px 18px rgba(148, 163, 184, 0.18);
    }

    .hero-stat-pill span:first-child {
      font-weight: 600;
      color: var(--primary-700);
    }

    /* ====== SEARCH SECTION ====== */
    .search-section {
      margin-top: -30px;
      position: relative;
      z-index: 10;
    }

    .search-box {
      background: white;
      border-radius: 20px;
      padding: 24px;
      box-shadow: var(--card-shadow);
      border: 1px solid rgba(226, 232, 240, 0.9);
    }

    .search-form .form-control,
    .search-form select.form-control {
      border-radius: 12px;
      border: 1px solid var(--neutral-200);
      padding: 11px 14px;
      font-size: 0.95rem;
      transition: all 0.25s ease;
      box-shadow: none;
    }

    .search-form .form-control:focus,
    .search-form select.form-control:focus {
      border-color: var(--primary-400);
      box-shadow: var(--input-shadow);
    }

    .search-form .input-group-text {
      background: var(--neutral-50);
      border: 1px solid var(--neutral-200);
      border-right: none;
      border-radius: 12px 0 0 12px;
      color: var(--neutral-500);
    }

    .search-form .input-group .form-control {
      border-left: none;
      border-radius: 0 12px 12px 0;
    }

    .btn-search {
      background: var(--primary-gradient);
      color: white;
      border: none;
      border-radius: 12px;
      padding: 11px 26px;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all 0.25s ease;
      width: 100%;
      white-space: nowrap;
      box-shadow: 0 10px 22px rgba(37, 99, 235, 0.4);
    }

    .btn-search:hover {
      background: var(--primary-gradient-hover);
      transform: translateY(-1px);
      box-shadow: 0 14px 26px rgba(37, 99, 235, 0.55);
    }

    .search-helper {
      margin-top: 10px;
      font-size: 0.85rem;
      color: var(--neutral-500);
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .search-helper span strong {
      color: var(--primary-600);
    }

    /* ====== FILTER TABS ====== */
    .filter-tabs {
      margin: 36px 0 18px;
    }

    .nav-chips .nav-link {
      background: var(--neutral-100);
      color: var(--neutral-700);
      border: 1px solid var(--neutral-200);
      border-radius: 999px;
      padding: 7px 18px;
      font-weight: 500;
      margin-right: 8px;
      margin-bottom: 8px;
      transition: all 0.25s ease;
      font-size: 0.9rem;
    }

    .nav-chips .nav-link:hover {
      background: var(--neutral-200);
      color: var(--primary-600);
    }

    .nav-chips .nav-link.active {
      background: var(--primary-600);
      color: #fff;
      border-color: var(--primary-600);
      box-shadow: 0 10px 18px rgba(37, 99, 235, 0.4);
    }

    .filter-meta {
      font-size: 0.9rem;
      color: var(--neutral-500);
    }

    /* ====== SIDEBAR FILTER ====== */
    .sidebar-card {
      border: 0;
      border-radius: 18px;
      box-shadow: var(--card-shadow);
      background: white;
      margin-bottom: 24px;
      border: 1px solid rgba(226, 232, 240, 0.9);
    }

    .sidebar-card .card-header {
      background: white;
      border-bottom: 1px solid var(--neutral-200);
      padding: 18px 20px;
      font-weight: 600;
      color: var(--neutral-800);
      font-size: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .filter-count {
      font-size: 0.8rem;
      color: var(--neutral-500);
    }

    .sidebar-card .card-body {
      padding: 18px 20px 20px;
    }

    .filter-group {
      padding-bottom: 18px;
      margin-bottom: 18px;
      border-bottom: 1px solid var(--neutral-200);
    }

    .filter-group:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .filter-label {
      font-size: 15px;
      font-weight: 600;
      color: var(--neutral-700);
      margin-bottom: 10px;
    }

    .form-check {
      margin-bottom: 8px;
      font-size: 0.9rem;
    }

    .form-check-input {
      width: 17px;
      height: 17px;
      margin-right: 8px;
      border: 1px solid var(--neutral-300);
      cursor: pointer;
    }

    .form-check-input:checked {
      background-color: var(--primary-500);
      border-color: var(--primary-500);
    }

    .form-check-label {
      font-size: 0.9rem;
      color: var(--neutral-600);
      cursor: pointer;
    }

    .btn-clear {
      background: var(--neutral-100);
      color: var(--neutral-700);
      border: 1px solid var(--neutral-200);
      border-radius: 999px;
      padding: 9px 18px;
      font-weight: 500;
      transition: all 0.25s ease;
      width: 100%;
      font-size: 0.9rem;
    }

    .btn-clear:hover {
      background: var(--neutral-200);
    }

    /* ====== JOB CARDS ====== */
    .jobs-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 14px;
    }

    .jobs-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--neutral-800);
    }

    .jobs-title span {
      color: var(--primary-600);
    }

    .jobs-subtitle {
      font-size: 0.9rem;
      color: var(--neutral-500);
    }

    .result-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 11px;
      border-radius: 999px;
      background: var(--primary-50);
      color: var(--primary-700);
      font-size: 0.85rem;
      border: 1px solid var(--primary-100);
    }

    .job-card {
      border: 0;
      border-radius: 18px;
      box-shadow: var(--card-shadow);
      transition: all 0.25s ease;
      margin-bottom: 18px;
      background: white;
      overflow: hidden;
      border-top: 3px solid rgba(148, 163, 184, 0.2);
    }

    .job-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--card-shadow-hover);
      border-top-color: var(--primary-400);
    }

    .job-card .card-body {
      padding: 18px 18px 16px;
    }

    .job-logo {
      width: 56px;
      height: 56px;
      border-radius: 14px;
      background: var(--primary-50);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary-500);
      font-size: 22px;
      margin-right: 16px;
      flex-shrink: 0;
    }

    .job-title {
      font-size: 17px;
      font-weight: 600;
      color: var(--neutral-900);
      margin-bottom: 4px;
    }

    .job-company {
      font-size: 0.9rem;
      color: var(--neutral-500);
      margin-bottom: 10px;
    }

    .job-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 10px;
    }

    .job-meta-item {
      display: inline-flex;
      align-items: center;
      font-size: 0.85rem;
      color: var(--neutral-600);
      gap: 6px;
      padding: 4px 8px;
      border-radius: 999px;
      background: var(--neutral-100);
    }

    .job-meta-item i {
      color: var(--primary-500);
      font-size: 0.9rem;
    }

    .job-salary {
      font-weight: 600;
      color: var(--accent-500);
      background: rgba(249, 115, 22, 0.08);
    }

    .job-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-bottom: 10px;
    }

    .job-tag {
      background: var(--primary-50);
      color: var(--primary-600);
      border-radius: 999px;
      padding: 3px 10px;
      font-size: 0.8rem;
      font-weight: 500;
    }

    .job-time {
      font-size: 0.8rem;
      color: var(--neutral-500);
    }

    .job-actions {
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: stretch;
      justify-content: center;
      height: 100%;
    }

    .btn-apply,
    .btn-quick-view {
      font-size: 0.9rem;
    }

    .btn-apply {
      background: var(--primary-gradient);
      color: #fff;
      border: none;
      border-radius: 999px;
      padding: 9px 18px;
      font-weight: 500;
      transition: all 0.25s ease;
      width: 100%;
    }

    .btn-apply:hover {
      background: var(--primary-gradient-hover);
      transform: translateY(-1px);
      box-shadow: 0 10px 22px rgba(37, 99, 235, 0.45);
    }

    .btn-quick-view {
      background: #fff;
      color: var(--primary-600);
      border: 1px solid var(--primary-200);
      border-radius: 999px;
      padding: 8px 16px;
      font-weight: 500;
      transition: all 0.25s ease;
      width: 100%;
    }

    .btn-quick-view:hover {
      background: var(--primary-50);
      border-color: var(--primary-300);
    }

    /* ====== PAGINATION ====== */
    .pagination {
      margin-top: 28px;
      justify-content: center;
    }

    .page-link {
      border: 1px solid var(--neutral-200);
      color: var(--neutral-600);
      padding: 7px 14px;
      margin: 0 3px;
      border-radius: 999px;
      transition: all 0.25s ease;
      font-size: 0.9rem;
      min-width: 36px;
      text-align: center;
    }

    .page-link:hover {
      background: var(--primary-50);
      color: var(--primary-600);
      border-color: var(--primary-300);
    }

    .page-item.active .page-link {
      background: var(--primary-600);
      border-color: var(--primary-600);
      color: white;
      box-shadow: 0 10px 18px rgba(37, 99, 235, 0.45);
    }

    .page-item.disabled .page-link {
      background: var(--neutral-100);
      color: var(--neutral-400);
      border-color: var(--neutral-200);
    }

    /* ====== FOOTER ====== */
    .footer {
      background: var(--neutral-900);
      color: white;
      padding: 56px 0 26px;
      margin-top: 70px;
      position: relative;
      overflow: hidden;
    }

    .footer::before {
      content: '';
      position: absolute;
      top: -80px;
      right: -80px;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(59, 130, 246, 0.35), transparent);
      opacity: 0.8;
    }

    .footer-title {
      font-size: 17px;
      font-weight: 600;
      margin-bottom: 18px;
      color: white;
    }

    .footer p {
      font-size: 0.9rem;
      color: var(--neutral-300);
    }

    .footer-links {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .footer-links li {
      margin-bottom: 8px;
      font-size: 0.9rem;
    }

    .footer-links a {
      color: var(--neutral-400);
      text-decoration: none;
      transition: all 0.25s ease;
    }

    .footer-links a:hover {
      color: white;
    }

    .footer-bottom {
      border-top: 1px solid var(--neutral-800);
      padding-top: 18px;
      margin-top: 32px;
      text-align: center;
      color: var(--neutral-500);
      font-size: 0.85rem;
    }

    /* ====== RESPONSIVE ADJUSTMENTS ====== */
    @media (max-width: 992px) {
      .hero-title {
        font-size: 36px;
      }

      .search-box {
        padding: 20px;
      }

      .job-actions {
        margin-top: 10px;
      }
    }

    @media (max-width: 768px) {
      .hero-title {
        font-size: 30px;
      }

      .hero-subtitle {
        font-size: 0.95rem;
      }

      .search-form .btn-search {
        margin-top: 4px;
      }

      .job-card .card-body {
        padding: 16px;
      }

      .jobs-header {
        align-items: flex-start;
      }
    }

    @media (max-width: 576px) {
      .hero-section {
        padding: 60px 0 32px;
      }

      .search-section {
        margin-top: -18px;
      }

      .hero-badge {
        font-size: 0.8rem;
      }

      .hero-stat-pill {
        width: 100%;
        justify-content: center;
      }

      .job-meta-item {
        padding: 3px 7px;
      }
    }
  </style>
</head>

<body>

  <!-- ================= HEADER ================= -->
  <header class="header">
    <nav class="navbar navbar-expand-lg navbar-light">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="index.html">
          <img src="/img/logo-nobr.png" alt="Learn2Earn logo" class="brand-logo">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
          aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link active" href="index.html">Trang chủ</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#">Việc làm</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#">Công cụ</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#">Tạo CV</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#">Liên hệ</a>
            </li>
          </ul>
          <div class="d-flex gap-2">
            <button onclick="window.location.href='/signInRole'" class="btn btn-auth btn-login">Đăng nhập</button>
            <button onclick="window.location.href='/signUpRole'" class="btn btn-auth btn-signup">Đăng ký</button>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <!-- ================= HERO SECTION ================= -->
  <section class="hero-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center">
          <div class="hero-content">
            <div class="hero-badge">
              <i class="fa-solid fa-bolt"></i>
              <span>Tìm việc nhanh – Kết nối trực tiếp doanh nghiệp</span>
            </div>
            <h1 class="hero-title">
              Tìm <span>việc làm phù hợp</span> với bạn
            </h1>
            <p class="hero-subtitle">
              Kết nối với hàng ngàn cơ hội việc làm từ các doanh nghiệp hàng đầu trên toàn quốc dành cho sinh viên và
              người đi làm.
            </p>

            <div class="hero-stats">
              <div class="hero-stat-pill">
                <span>1.000+</span>
                <span>việc làm mới mỗi tuần</span>
              </div>
              <div class="hero-stat-pill">
                <span>500+</span>
                <span>doanh nghiệp đối tác</span>
              </div>
              <div class="hero-stat-pill">
                <span>24/7</span>
                <span>theo dõi lịch phỏng vấn</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SEARCH SECTION ================= -->
  <section class="search-section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-10">
          <div class="search-box">
            <form class="search-form">
              <div class="row g-3 align-items-center">
                <div class="col-md-4">
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-briefcase"></i></span>
                    <input type="text" class="form-control" placeholder="Vị trí tuyển dụng">
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                    <input type="text" class="form-control" placeholder="Địa điểm">
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-tag"></i></span>
                    <select class="form-control">
                      <option selected>Danh mục nghề</option>
                      <option>Công nghệ thông tin</option>
                      <option>Kinh doanh / Bán hàng</option>
                      <option>Marketing</option>
                      <option>Kế toán / Tài chính</option>
                      <option>Nhân sự</option>
                    </select>
                  </div>
                </div>
                <div class="col-md-2">
                  <button type="submit" class="btn btn-search">
                    <i class="fas fa-search me-2"></i>Tìm kiếm
                  </button>
                </div>
              </div>

              <div class="search-helper">
                <span>Gợi ý: <strong>Marketing, Thực tập sinh, Bán thời gian,...</strong></span>
                <span>Hiển thị kết quả theo ưu tiên “<strong>Mới nhất</strong>”</span>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= FILTER TABS ================= -->
  <section class="filter-tabs">
    <div class="container">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center flex-wrap gap-2">
          <span class="text-muted me-1 filter-meta">Tìm kiếm theo:</span>
          <ul class="nav nav-pills nav-chips">
            <li class="nav-item"><a class="nav-link" href="#">Tên việc làm</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Tên công ty</a></li>
            <li class="nav-item"><a class="nav-link active" href="#">Cả hai</a></li>
          </ul>
        </div>
        <div class="d-inline-flex align-items-center gap-2">
          <span class="text-muted small">Ưu tiên hiển thị theo:</span>
          <select class="form-select form-select-sm w-auto rounded-3">
            <option>Mới nhất</option>
            <option>Lương cao</option>
            <option>Gần bạn</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= MAIN CONTENT ================= -->
  <main class="container my-4 my-lg-5">
    <div class="row g-4">
      <!-- ========== SIDEBAR FILTER ========== -->
      <aside class="col-lg-3">
        <div class="sidebar-card">
          <div class="card-header">
            <span><i class="fas fa-filter me-2"></i>Lọc nâng cao</span>
            <span class="filter-count">6 kết quả</span>
          </div>
          <div class="card-body">
            <!-- Theo danh mục nghề -->
            <div class="filter-group">
              <div class="filter-label">Theo danh mục nghề</div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="dm1">
                <label class="form-check-label" for="dm1">Quản lý kinh doanh</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="dm2">
                <label class="form-check-label" for="dm2">Marketing</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="dm3">
                <label class="form-check-label" for="dm3">Kế toán</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="dm4">
                <label class="form-check-label" for="dm4">Sales Bán lẻ</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="dm5">
                <label class="form-check-label" for="dm5">Kinh doanh/Bán hàng</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="dm6">
                <label class="form-check-label" for="dm6">Nhân sự</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="dm7">
                <label class="form-check-label" for="dm7">Quảng cáo/Sáng tạo</label>
              </div>
            </div>

            <!-- Cấp bậc -->
            <div class="filter-group">
              <div class="filter-label">Cấp bậc</div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="capbac" id="cb0" checked>
                <label class="form-check-label" for="cb0">Tất cả</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="capbac" id="cb1">
                <label class="form-check-label" for="cb1">Nhân viên</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="capbac" id="cb2">
                <label class="form-check-label" for="cb2">Trưởng nhóm</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="capbac" id="cb3">
                <label class="form-check-label" for="cb3">Trưởng phòng</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="capbac" id="cb4">
                <label class="form-check-label" for="cb4">Giám đốc</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="capbac" id="cb5">
                <label class="form-check-label" for="cb5">Thực tập sinh</label>
              </div>
            </div>

            <!-- Mức lương -->
            <div class="filter-group">
              <div class="filter-label">Mức lương</div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="luong" id="lu0" checked>
                <label class="form-check-label" for="lu0">Tất cả</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="luong" id="lu1">
                <label class="form-check-label" for="lu1">Dưới 10 triệu</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="luong" id="lu2">
                <label class="form-check-label" for="lu2">10 – 15 triệu</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="luong" id="lu3">
                <label class="form-check-label" for="lu3">15 – 20 triệu</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="luong" id="lu4">
                <label class="form-check-label" for="lu4">20 – 25 triệu</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="luong" id="lu5">
                <label class="form-check-label" for="lu5">Trên 25 triệu</label>
              </div>
            </div>

            <!-- Hình thức làm việc -->
            <div class="filter-group">
              <div class="filter-label">Hình thức làm việc</div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="hinhthuc" id="ht0" checked>
                <label class="form-check-label" for="ht0">Tất cả</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="hinhthuc" id="ht1">
                <label class="form-check-label" for="ht1">Toàn thời gian</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="hinhthuc" id="ht2">
                <label class="form-check-label" for="ht2">Bán thời gian</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="hinhthuc" id="ht3">
                <label class="form-check-label" for="ht3">Thực tập</label>
              </div>
            </div>

            <!-- Nút Xóa lọc -->
            <button type="button" class="btn btn-clear">Xóa lọc</button>
          </div>
        </div>
      </aside>

      <!-- ========== DANH SÁCH VIỆC LÀM ========== -->
      <section class="col-lg-9">
  <div class="jobs-header">
    <div>
      <div class="jobs-title">
        Kết quả tìm kiếm <span>(<%= jobs.length %> việc làm)</span>
      </div>
      <div class="jobs-subtitle">
        Sắp xếp theo: <strong>Mới nhất</strong> · Bạn có thể thay đổi tiêu chí ở phía trên.
      </div>
    </div>
    <div class="result-badge">
      <i class="fa-solid fa-circle-check"></i>
      Phù hợp với sinh viên & người mới đi làm
    </div>
  </div>

  <!-- Job List -->
  <% jobs.forEach(job => { %>
  <div class="card job-card">
    <div class="card-body">
      <div class="row gx-3">
        <div class="col-md-9">
          <div class="d-flex align-items-start mb-2">
            <div class="job-logo">
              <% if (job.avt) { %>
                <img src="<%= job.avt %>" alt="Logo" style="width:50px;height:50px;">
              <% } else { %>
                <i class="fas fa-building"></i>
              <% } %>
            </div>
            <div>
              <h3 class="job-title"><%= job.ten_vi_tri %></h3>
              <p class="job-company"><%= job.ten_cong_ty %> · <%= job.dia_diem %></p>
              <div class="job-meta">
                <% if (job.dia_diem) { %>
                <div class="job-meta-item">
                  <i class="fas fa-map-marker-alt"></i>
                  <span><%= job.dia_diem %></span>
                </div>
                <% } %>
                <% if (job.thoi_gian) { %>
                <div class="job-meta-item">
                  <i class="fas fa-clock"></i>
                  <span><%= job.thoi_gian %></span>
                </div>
                <% } %>
                <% if (job.muc_luong) { %>
                <div class="job-meta-item job-salary">
                  <i class="fas fa-money-bill-wave"></i>
                  <span><%= job.muc_luong %></span>
                </div>
                <% } %>
              </div>
              <div class="job-tags">
                <% if (job.nganh) { %><span class="job-tag"><%= job.nganh %></span><% } %>
                <% if (job.ky_nang) { %><span class="job-tag"><%= job.ky_nang %></span><% } %>
                <% if (job.ky_nang_mem) { %><span class="job-tag"><%= job.ky_nang_mem %></span><% } %>
              </div>
              <div class="job-time">
                Đăng <%= new Date(job.ngay_tao).toLocaleDateString() %> 
                <% if (job.uu_tien) { %>· <%= job.uu_tien %><% } %>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="job-actions">
            <button class="btn btn-quick-view">Xem nhanh</button>
            <button class="btn btn-apply">Ứng tuyển</button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% }) %>

  <!-- Pagination -->
  <nav aria-label="Page navigation">
    <ul class="pagination">
      <li class="page-item disabled">
        <a class="page-link" href="#" tabindex="-1" aria-disabled="true">Trước</a>
      </li>
      <li class="page-item active"><a class="page-link" href="#">1</a></li>
      <li class="page-item"><a class="page-link" href="#">2</a></li>
      <li class="page-item"><a class="page-link" href="#">3</a></li>
      <li class="page-item">
        <a class="page-link" href="#">Tiếp</a>
      </li>
    </ul>
  </nav>
</section>

    </div>
  </main>

