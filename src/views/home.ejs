          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2023 Learn2Earn. Tất cả các quyền được bảo lưu.</p>
      </div>
    </div>
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>