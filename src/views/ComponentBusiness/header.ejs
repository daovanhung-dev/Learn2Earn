
<header class="header">
  <style>
        .header a {
            cursor: pointer;
        }

        /* Thêm cho dropdown item */
        .header .dropdown-item {
            cursor: pointer;
        }

        :root {
            --navy: #1e2a44;
            --navy-light: #2d3b57;
            --gray-bg: #f1f5f9;
            --card-bg: #ffffff;
            --text: #1e293b;
            --muted: #64748b;
            --dark-btn: #111827;
            --dark-btn-hover: #0f1623;
        }

        body {
            background: var(--gray-bg);
            font-family: "Inter", sans-serif;
            color: var(--text);
        }

        /* HEADER */
        .header {
            background: white;
            box-shadow: 0 2px 8px rgba(0, 0, 0, .08);
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .navbar-brand img {
            height: 55px;
            transform: scale(2.2);
            transform-origin: left center;
        }

        .nav-link {
            font-weight: 500;
            color: var(--muted) !important;
            border-radius: 14px;
            padding: 8px 18px !important;
        }

        .nav-link:hover {
            background: #e6ecf5;
            color: var(--navy) !important;
        }

        .nav-link.active {
            background: #dbe4f3;
            color: var(--navy) !important;
        }

        .nav-icon {
            width: 40px;
            height: 40px;
            background: #e6ecf5;
            color: var(--navy);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: 6px;
            font-size: 18px;
        }

        .nav-icon:hover {
            background: #d4dceb;
            color: var(--navy);
        }

        /* HERO */
        .hero-section {
            text-align: center;
            padding: 60px 0 40px;
        }

        .hero-title {
            font-size: 36px;
            font-weight: 700;
            color: var(--navy);
        }

        .hero-title span {
            background: linear-gradient(135deg, var(--navy), var(--navy-light));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .hero-sub {
            font-size: 16px;
            color: var(--muted);
            max-width: 600px;
            margin: 0 auto;
        }

        /* FEATURES */
        .feature-card {
            background: var(--card-bg);
            border-radius: 18px;
            padding: 24px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 6px 16px rgba(0, 0, 0, .06);
            text-align: center;
        }

        .feature-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 14px;
            border-radius: 50%;
            background: #e6ecf5;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            color: var(--navy);
        }

        .btn-main {
            width: 100%;
            padding: 12px 0;
            border-radius: 10px;
            background: var(--dark-btn);
            color: white;
            border: none;
            font-size: 15px;
            font-weight: 500;
        }

        .btn-main:hover {
            background: var(--dark-btn-hover);
        }

        /* FOOTER */
        .footer {
            background: #020617;
            color: #E5E7EB;
            padding: 40px 0 20px;
            margin-top: 60px;
        }

        .footer-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #fff;
        }

        .footer-links {
            list-style: none;
            padding: 0;
        }

        .footer-links li {
            margin-bottom: 6px;
        }

        .footer-links a {
            color: #E5E7EB;
            font-size: .9rem;
        }

        .footer-bottom {
            border-top: 1px solid #111827;
            margin-top: 20px;
            padding-top: 12px;
            text-align: center;
            font-size: .85rem;
        }
    </style>
  <nav class="navbar navbar-expand-lg navbar-light">
    <div class="container">
      <a class="navbar-brand" href="/">
        <img src="/img/logo-nobr.png" alt="Logo Learn2Earn" class="l2e-logo">
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse justify-content-between" id="navMenu">

        <% const activeTab = typeof active !== 'undefined' ? active : ''; %>

        <ul class="navbar-nav mx-auto">
          <li class="nav-item">
            <a class="nav-link <%= activeTab === 'home' ? 'active' : '' %>" onclick="window.location.href='/Business/Home'">Trang chủ</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= activeTab === 'jobs' ? 'active' : '' %>" onclick="window.location.href='/Business/ManganerJD'">Quản lý tin tuyển dụng</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= activeTab === 'candidates' ? 'active' : '' %>" onclick="window.location.href='/Business/ApplyList'">Ứng viên</a>
          </li>
          <li class="nav-item"><a class="nav-link" href="#">Chat</a></li>
          <li class="nav-item"><a class="nav-link" href="#">Thống kê</a></li>
        </ul>

        <ul class="navbar-nav ms-auto d-flex align-items-center">
          <li class="nav-item"><a class="nav-icon" href="#"><i class="fa-regular fa-bell"></i></a></li>
          <li class="nav-item"><a class="nav-icon" href="#"><i class="fa-regular fa-comment-dots"></i></a></li>
          <li class="nav-item"><a class="nav-link" href="/business/setting">Cài đặt</a></li>
        </ul>
      </div>
    </div>
  </nav>
</header>
