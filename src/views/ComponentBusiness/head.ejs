<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || "Learn2Earn" %>
    </title>

    <!-- CSS / Icon CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <!-- Local CSS -->
    <style>
        :root {
            --navy: #1e2a44;
            --navy-light: #2d3b57;
            --gray-bg: #f1f5f9;
            --card-bg: #ffffff;
            --text: #1e293b;
            --muted: #64748b;
            --dark-btn: #111827;
            --dark-btn-hover: #0f1623;
        }

        body {
            background: var(--gray-bg);
            font-family: "Inter", sans-serif;
            color: var(--text);
        }

        /* HEADER */
        .header {
            background: white;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .l2e-logo {
            height: 55px;
            transform: scale(2.2);
            transform-origin: left center;
        }

        /* Nav links */
        .nav-link {
            font-weight: 500;
            color: var(--muted) !important;
            border-radius: 14px;
            padding: 8px 18px !important;
        }

        .nav-link:hover {
            background: #e6ecf5;
            color: var(--navy) !important;
        }

        .nav-link.active {
            background: #dbe4f3;
            color: var(--navy) !important;
        }

        .nav-icon {
            width: 40px;
            height: 40px;
            background: #e6ecf5;
            color: var(--navy);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: 6px;
            font-size: 18px;
        }

        .nav-icon:hover {
            background: #d4dceb;
            color: var(--navy);
        }

        /* FOOTER */
        .footer {
            background: #020617;
            color: #e5e7eb;
            padding: 40px 0 20px;
            margin-top: 60px;
        }

        .footer-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #fff;
        }

        .footer-links {
            list-style: none;
            padding: 0;
        }

        .footer-links li {
            margin-bottom: 6px;
        }

        .footer-links a {
            color: #e5e7eb;
            font-size: 0.9rem;
            text-decoration: none;
        }

        .footer-links a:hover {
            text-decoration: underline;
        }

        .footer-bottom {
            border-top: 1px solid #111827;
            margin-top: 20px;
            padding-top: 12px;
            text-align: center;
            font-size: 0.85rem;
        }
    </style>
    <!-- (tùy chọn) meta khác / favicons -->
</head>