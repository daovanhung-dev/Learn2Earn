<script>
  // Xử lý chọn file CV PDF
  const uploadInput = document.getElementById("uploadCvInput");
  uploadInput.addEventListener("change", function () {
    const file = this.files[0];
    if (file) {
      alert("Bạn đã chọn file CV: " + file.name + " (demo, chưa upload lên server)");
    }
  });

  // Xử lý form chỉnh sửa hồ sơ (demo)
  const editForm = document.getElementById("editProfileForm");
  editForm.addEventListener("submit", function (e) {
    e.preventDefault();

    const newName      = document.getElementById("editName").value.trim();
    const newMajor     = document.getElementById("editMajor").value.trim();
    const newLocation  = document.getElementById("editLocation").value.trim();

    if (newName)     document.getElementById("profileName").textContent     = newName;
    if (newMajor)    document.getElementById("profileMajor").textContent    = newMajor;
    if (newLocation) document.getElementById("profileLocation").textContent = newLocation;

    const modalEl = document.getElementById("editProfileModal");
    const modal   = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
    modal.hide();

    alert("Đã cập nhật thông tin hồ sơ.");
  });
</script>

