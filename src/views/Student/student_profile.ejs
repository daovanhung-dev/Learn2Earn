    .footer-title {
      font-size: 17px;
      font-weight: 600;
      margin-bottom: 18px;
      color: white;
    }

    .footer p {
      font-size: 0.9rem;
      color: #CBD5F5;
    }

    .footer-links {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .footer-links li {
      margin-bottom: 8px;
      font-size: 0.9rem;
    }

    .footer-links a {
      color: #94A3B8;
      text-decoration: none;
      transition: 0.25s;
    }

    .footer-links a:hover {
      color: white;
    }

    .footer-bottom {
      border-top: 1px solid #1E293B;
      padding-top: 18px;
      margin-top: 32px;
      text-align: center;
      color: #94A3B8;
      font-size: 0.85rem;
