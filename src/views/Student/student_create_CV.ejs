<div class="container py-4">

  <h3 class="fw-bold text-primary mb-4">
    <i class="bi bi-file-earmark-plus"></i> Tạo CV sinh viên
  </h3>

  <div class="row g-4">

    <!-- FORM -->
    <div class="col-lg-6">
      <div class="card shadow-sm border-0">
        <div class="card-body">

          <form id="cvForm" class="needs-validation" novalidate>

            <!-- Avatar -->
            <div class="text-center mb-4">
              <div class="avatar-box mx-auto" id="avatarPreview">
                <i class="bi bi-person-circle" style="font-size:60px;color:#6b7280;"></i>
              </div>
              <input type="file" id="avatarInput" class="form-control mt-3" accept="image/*">
              <div class="form-text">Không bắt buộc – nên dùng ảnh chân dung</div>
            </div>

            <h5 class="fw-bold text-secondary">Thông tin cá nhân</h5>
            <div class="row">
              <div class="col-6 mb-3">
                <label class="form-label">Họ tên <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="name" required>
                <div class="invalid-feedback">Vui lòng nhập họ tên.</div>
              </div>
              <div class="col-6 mb-3">
                <label class="form-label">Vị trí mong muốn <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="position" required>
                <div class="invalid-feedback">Vui lòng nhập vị trí.</div>
              </div>
              <div class="col-6 mb-3">
                <label class="form-label">Email <span class="text-danger">*</span></label>
                <input type="email" class="form-control" id="email" required>
                <div class="invalid-feedback">Email không hợp lệ.</div>
              </div>
              <div class="col-6 mb-3">
                <label class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="phone" required pattern="^[0-9]{9,11}$">
                <div class="invalid-feedback">SĐT chỉ gồm số, 9–11 ký tự.</div>
              </div>
            </div>

            <h5 class="fw-bold text-secondary mt-4">Học vấn <span class="text-danger">*</span></h5>
            <textarea class="form-control mb-3" id="education" rows="2" required
              placeholder="- Đại học Nông nghiệp VN (VNUA)
- Ngành: CNTT · GPA: 3.0/4.0"></textarea>
            <div class="invalid-feedback">Vui lòng nhập học vấn.</div>

            <h5 class="fw-bold text-secondary mt-4">Kinh nghiệm</h5>
            <textarea class="form-control mb-3" id="experience" rows="3"
              placeholder="- Thực tập sinh Java (3 tháng)
- Hỗ trợ CRUD, API, ReactJS"></textarea>

            <h5 class="fw-bold text-secondary mt-4">Kỹ năng</h5>
            <textarea class="form-control mb-3" id="skills" rows="3"
              placeholder="- Java, Spring Boot
- Flutter · Dart
- SQL, Git"></textarea>

            <h5 class="fw-bold text-secondary mt-4">Dự án</h5>
            <textarea class="form-control mb-3" id="projects" rows="3"
              placeholder="- Learn2Earn (Kết nối SV – DN)
- Todo App (Flutter)"></textarea>

            <!-- Upload PDF -->
            <h5 class="fw-bold text-secondary mt-4">Tải CV PDF (nếu đã có)</h5>
            <input type="file" id="pdfFile" class="form-control mb-3" accept="application/pdf">

            <button class="btn btn-primary w-100" type="submit">
              <i class="bi bi-eye"></i> Xem CV Preview
            </button>
          </form>

        </div>
      </div>
    </div>

    <!-- CV PREVIEW -->
    <div class="col-lg-6">
      <div class="cv-preview">
        <h4 class="fw-bold text-center mb-3">CV CỦA SINH VIÊN</h4>

        <div class="text-center mb-3">
          <div class="avatar-box mx-auto" style="width:110px;height:110px;">
            <img id="previewAvatarImg" src="" style="display:none;">
          </div>
        </div>

        <h5 class="fw-bold">Thông tin cá nhân</h5>
        <p><strong>Họ tên:</strong> <span id="pName"></span></p>
        <p><strong>Vị trí:</strong> <span id="pPosition"></span></p>
        <p><strong>Email:</strong> <span id="pEmail"></span></p>
        <p><strong>SĐT:</strong> <span id="pPhone"></span></p>

        <h5 class="fw-bold mt-4">Học vấn</h5>
        <pre id="pEducation"></pre>

        <h5 class="fw-bold mt-4">Kinh nghiệm</h5>
        <pre id="pExperience"></pre>

        <h5 class="fw-bold mt-4">Kỹ năng</h5>
        <pre id="pSkills"></pre>

        <h5 class="fw-bold mt-4">Dự án</h5>
        <pre id="pProjects"></pre>

        <button class="btn btn-success w-100 mt-4">
          <i class="bi bi-download"></i> Tải CV PDF
        </button>
      </div>
    </div>

  </div>
</div>

