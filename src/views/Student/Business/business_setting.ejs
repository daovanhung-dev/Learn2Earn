<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Cài đặt Doanh nghiệp - Learn2Earn Business</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap + Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <style>
    :root {
      --navy: #1e2a44;
      --navy-light: #2d3b57;
      --gray-bg: #eef2f7;
      --card-bg: #ffffff;
      --text: #1e293b;
      --muted: #64748b;
      --dark-btn: #111827;
      --dark-btn-hover: #0f1623;
    }

    body {
      background: var(--gray-bg);
      font-size: 0.95rem;
      font-family: "Inter", sans-serif;
      color: var(--text);
    }

    /* ===== HEADER (template Business) ===== */
    .header {
      background: white;
      box-shadow: 0 2px 8px rgba(0, 0, 0, .08);
      position: sticky;
      top: 0;
      z-index: 999;
    }

    .navbar-brand img {
      height: 55px;
      transform: scale(2.2);
      transform-origin: left center;
    }

    .nav-link {
      font-weight: 500;
      color: var(--muted) !important;
      border-radius: 14px;
      padding: 8px 18px !important;
    }

    .nav-link:hover {
      background: #e6ecf5;
      color: var(--navy) !important;
    }

    .nav-link.active {
      background: #dbe4f3;
      color: var(--navy) !important;
    }

    .nav-icon {
      width: 40px;
      height: 40px;
      background: #e6ecf5;
      color: var(--navy);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: 6px;
      font-size: 18px;
    }

    .nav-icon:hover {
      background: #d4dceb;
    }

    /* ===== PAGE CONTENT ===== */
    .card-soft {
      border-radius: 16px;
      border: 0;
      background: var(--card-bg);
      box-shadow: 0 4px 16px rgba(30,42,68,.12);
    }

    .section-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 10px;
      color: #1e2a44;
    }

    .section-title i {
      color: #ff944d;
    }

    .logo-box {
      width: 100px;
      height: 100px;
      background: #e5e7eb;
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .logo-box img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .form-switch .form-check-input {
      cursor: pointer;
    }

    .danger-zone {
      border: 1px solid #ffc9c9;
      background: #ffecec;
      padding: 14px;
      border-radius: 12px;
      color: #991b1b;
    }

    /* ===== FOOTER (template Business) ===== */
    .footer {
      background: #020617;
      color: #E5E7EB;
      padding: 40px 0 20px;
      margin-top: 60px;
    }

    .footer-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 12px;
      color: #fff;
    }

    .footer-links {
      list-style: none;
      padding: 0;
    }

    .footer-links li {
      margin-bottom: 6px;
    }

    .footer-links a {
      color: #E5E7EB;
      font-size: .9rem;
    }

    .footer-bottom {
      border-top: 1px solid #111827;
      margin-top: 20px;
      padding-top: 12px;
      text-align: center;
      font-size: .85rem;
    }
  </style>
</head>

<body>

  <!-- ========== HEADER ========== -->
  <header class="header">
    <nav class="navbar navbar-expand-lg navbar-light">
      <div class="container">

        <a class="navbar-brand" href="#">
          <img src="/img/logo-nobr.png" alt="Logo Learn2Earn">
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-between" id="navMenu">

          <ul class="navbar-nav mx-auto">
            <li class="nav-item"><a class="nav-link" href="/Business">Trang chủ</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Quản lý tin tuyển dụng</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Ứng viên</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Chat</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Thống kê</a></li>
          </ul>

          <ul class="navbar-nav ms-auto d-flex align-items-center">
            <li class="nav-item">
              <a class="nav-icon" href="#"><i class="fa-regular fa-bell"></i></a>
            </li>
            <li class="nav-item">
              <a class="nav-icon" href="#"><i class="fa-regular fa-comment-dots"></i></a>
            </li>
            <!-- Cài đặt cạnh icon Chat -->
            <li class="nav-item">
              <a class="nav-link active" href="#">Cài đặt</a>
            </li>
          </ul>

        </div>
      </div>
    </nav>
  </header>

  <!-- ========== PAGE CONTENT ========== -->
  <div class="container py-4">

    <h4 class="fw-bold text-dark mb-3">Cài đặt doanh nghiệp</h4>
    <div class="text-muted mb-4">Quản lý thông tin & cấu hình tuyển dụng của công ty</div>

    <div class="row g-4">

      <!-- THÔNG TIN DOANH NGHIỆP -->
      <div class="col-lg-6">
        <div class="card card-soft mb-3">
          <div class="card-body">

            <div class="section-title"><i class="bi bi-building"></i> Thông tin doanh nghiệp</div>

            <div class="d-flex align-items-center mb-3">
              <div class="logo-box me-3">
                <img id="logoPreview" src="https://via.placeholder.com/200x200?text=LOGO" alt="Logo công ty">
              </div>
              <div>
                <label class="form-label small">Logo công ty</label>
                <input type="file" id="logoInput" class="form-control form-control-sm" accept="image/*">
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Tên doanh nghiệp</label>
              <input type="text" class="form-control" value="Công ty Minh Long">
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Email liên hệ</label>
              <input type="email" class="form-control" value="contact@minhlong.com">
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Số điện thoại</label>
              <input type="text" class="form-control" value="02812345678">
            </div>

            <button class="btn btn-dark w-100">
              <i class="bi bi-save"></i> Lưu thông tin
            </button>

          </div>
        </div>
      </div>

      <!-- BẢO MẬT -->
      <div class="col-lg-6">
        <div class="card card-soft mb-3">
          <div class="card-body">

            <div class="section-title"><i class="bi bi-shield-lock"></i> Bảo mật</div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Mật khẩu hiện tại</label>
              <input type="password" class="form-control" placeholder="••••••">
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Mật khẩu mới</label>
              <input type="password" class="form-control" placeholder="Tối thiểu 6 ký tự">
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Nhập lại mật khẩu mới</label>
              <input type="password" class="form-control" placeholder="Nhập lại mật khẩu">
            </div>

            <button class="btn btn-dark w-100 mb-2">
              <i class="bi bi-key"></i> Đổi mật khẩu
            </button>

            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="twoFactor">
              <label class="form-check-label" for="twoFactor">Bật xác thực 2 bước</label>
            </div>

          </div>
        </div>
      </div>

      <!-- CÀI ĐẶT TUYỂN DỤNG -->
      <div class="col-lg-6">
        <div class="card card-soft mb-3">
          <div class="card-body">

            <div class="section-title"><i class="bi bi-briefcase"></i> Cài đặt tuyển dụng</div>

            <div class="form-check form-switch mb-2">
              <input class="form-check-input" type="checkbox" checked>
              <label class="form-check-label">Tự động gửi email xác nhận ứng tuyển</label>
            </div>

            <div class="form-check form-switch mb-2">
              <input class="form-check-input" type="checkbox" checked>
              <label class="form-check-label">Thông báo khi ứng viên cập nhật CV</label>
            </div>

            <div class="form-check form-switch mb-2">
              <input class="form-check-input" type="checkbox">
              <label class="form-check-label">Bật chế độ ưu tiên hồ sơ phù hợp</label>
            </div>

            <label class="form-label fw-semibold mt-3">Thời gian phản hồi ứng viên</label>
            <select class="form-select mb-3">
              <option>Trong 24 giờ</option>
              <option>Trong 48 giờ</option>
              <option>Trong 72 giờ</option>
            </select>

          </div>
        </div>
      </div>

      <!-- QUYỀN TRUY CẬP -->
      <div class="col-lg-6">
        <div class="card card-soft mb-3">
          <div class="card-body">

            <div class="section-title"><i class="bi bi-people"></i> Quyền truy cập & hiển thị</div>

            <label class="form-label fw-semibold">Ai có thể xem công ty của bạn?</label>
            <select class="form-select mb-3">
              <option>Công khai</option>
              <option>Chỉ ứng viên đã nộp CV</option>
              <option>Chỉ quản trị viên</option>
            </select>

            <label class="form-label fw-semibold">Ai có thể xem vị trí tuyển dụng?</label>
            <select class="form-select mb-3">
              <option>Tất cả ứng viên</option>
              <option>Ứng viên có CV phù hợp</option>
            </select>

            <div class="form-check form-switch mb-2">
              <input class="form-check-input" type="checkbox" checked>
              <label class="form-check-label">Hiển thị đánh giá công ty</label>
            </div>

            <div class="form-check form-switch mb-2">
              <input class="form-check-input" type="checkbox">
              <label class="form-check-label">Ẩn thông tin lương trên job post</label>
            </div>

          </div>
        </div>
      </div>

      <!-- DANGER ZONE -->
      <div class="col-lg-12">
        <div class="danger-zone mt-2">
          <div class="fw-semibold mb-2">⚠ Khu vực nguy hiểm</div>
          <p class="small mb-2">
            Xóa tài khoản doanh nghiệp sẽ khiến toàn bộ job post, ứng viên, dữ liệu tuyển dụng và thông tin công ty bị xóa vĩnh viễn.
          </p>
          <button class="btn btn-danger btn-sm">
            <i class="bi bi-trash"></i> Xóa tài khoản doanh nghiệp
          </button>
        </div>
      </div>

    </div>
  </div>

  <!-- ========== FOOTER ========== -->
  <footer class="footer">
    <div class="container">
      <div class="row">

        <div class="col-lg-4 mb-4">
          <h4 class="footer-title">Learn2Earn</h4>
          <p>Nền tảng hỗ trợ tuyển dụng và tìm kiếm ứng viên chất lượng cao.</p>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Về chúng tôi</h4>
          <ul class="footer-links">
            <li><a href="#">Giới thiệu</a></li>
            <li><a href="#">Tin tức</a></li>
            <li><a href="#">Tuyển dụng</a></li>
            <li><a href="#">Liên hệ</a></li>
          </ul>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Doanh nghiệp</h4>
          <ul class="footer-links">
            <li><a href="#">Đăng tin</a></li>
            <li><a href="#">Quản lý ứng viên</a></li>
            <li><a href="#">Gói dịch vụ</a></li>
            <li><a href="#">Hỗ trợ</a></li>
          </ul>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Liên hệ</h4>
          <ul class="footer-links">
            <li><a href="#"><i class="fas fa-phone me-2"></i>+84 123 456 789</a></li>
            <li><a href="#"><i class="fas fa-envelope me-2"></i>support@learn2earn.vn</a></li>
            <li><a href="#"><i class="fas fa-map-marker-alt me-2"></i>Hà Nội, Việt Nam</a></li>
          </ul>
        </div>

      </div>

      <div class="footer-bottom">
        &copy; 2024 Learn2Earn. All rights reserved.
      </div>
    </div>
  </footer>

  <!-- JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Preview logo
    document.getElementById("logoInput").addEventListener("change", function (e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function (event) {
        document.getElementById("logoPreview").src = event.target.result;
      };
      reader.readAsDataURL(file);
    });
  </script>

</body>
</html>
