<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <title>Thông báo cho Doanh nghiệp - Learn2Earn Business</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <style>
    :root {
      --navy: #1e2a44;
      --navy-light: #2d3b57;
      --gray-bg: #eef2f7;
      --card-bg: #ffffff;
      --text: #1e293b;
      --muted: #64748b;
      --dark-btn: #111827;
      --dark-btn-hover: #0f1623;
    }

    body {
      background: var(--gray-bg);
      font-size: 0.95rem;
      font-family: "Inter", sans-serif;
      color: var(--text);
    }

    /* ===== HEADER ===== */
    .header {
      background: white;
      box-shadow: 0 2px 8px rgba(0, 0, 0, .08);
      position: sticky;
      top: 0;
      z-index: 999;
    }

    .navbar-brand img {
      height: 55px;
      transform: scale(2.2);
      transform-origin: left center;
    }

    .nav-link {
      font-weight: 500;
      color: var(--muted) !important;
      border-radius: 14px;
      padding: 8px 18px !important;
    }

    .nav-link:hover {
      background: #e6ecf5;
      color: var(--navy) !important;
    }

    .nav-link.active {
      background: #dbe4f3;
      color: var(--navy) !important;
    }

    .nav-icon {
      width: 40px;
      height: 40px;
      background: #e6ecf5;
      color: var(--navy);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: 6px;
      font-size: 18px;
    }

    .nav-icon:hover {
      background: #d4dceb;
    }

    /* ===== PAGE CONTENT ===== */
    .card-soft {
      border-radius: 16px;
      border: 0;
      box-shadow: 0 4px 16px rgba(30, 42, 68, 0.10);
      background: #ffffff;
    }

    .notif-item {
      cursor: pointer;
      border-radius: 12px;
      padding: 12px 14px;
      margin-bottom: 8px;
    }

    .notif-item.unread {
      background: #fff5e8;
    }

    .notif-item:hover {
      background: #ffe6cc;
    }

    .notif-title {
      font-weight: 600;
      color: #1e2a44;
    }

    .badge-type {
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 0.75rem;
    }

    .badge-cv {
      background: #e0f2fe;
      color: #075985;
    }

    .badge-interview {
      background: #dcfce7;
      color: #166534;
    }

    .badge-system {
      background: #e5e7eb;
      color: #444;
    }

    .filter-pill {
      border-radius: 999px;
      padding: 5px 14px;
      border: 1px solid #cbd5e1;
      background: white;
      cursor: pointer;
      font-size: 0.8rem;
    }

    .filter-pill.active {
      background: #ff944d;
      color: white;
      border-color: #ff944d;
    }

    /* ===== FOOTER ===== */
    .footer {
      background: #020617;
      color: #E5E7EB;
      padding: 40px 0 20px;
      margin-top: 60px;
    }

    .footer-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 12px;
      color: #fff;
    }

    .footer-links {
      list-style: none;
      padding: 0;
    }

    .footer-links li {
      margin-bottom: 6px;
    }

    .footer-links a {
      color: #E5E7EB;
      font-size: .9rem;
    }

    .footer-bottom {
      border-top: 1px solid #111827;
      margin-top: 20px;
      padding-top: 12px;
      text-align: center;
      font-size: .85rem;
    }
  </style>
</head>

<body>

  <!-- ========== HEADER ========== -->
  <header class="header">
    <nav class="navbar navbar-expand-lg navbar-light">
      <div class="container">

        <a class="navbar-brand" href="#">
          <img src="/img/logo-nobr.png" alt="Logo Learn2Earn">
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-between" id="navMenu">

          <ul class="navbar-nav mx-auto">
            <li class="nav-item"><a class="nav-link" href="/Business">Trang chủ</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Quản lý tin tuyển dụng</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Ứng viên</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Chat</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Thống kê</a></li>
          </ul>

          <ul class="navbar-nav ms-auto d-flex align-items-center">
            <li class="nav-item"><a class="nav-icon" href="#"><i class="fa-regular fa-bell"></i></a></li>
            <li class="nav-item"><a class="nav-icon" href="#"><i class="fa-regular fa-comment-dots"></i></a></li>
            <li class="nav-item"><a class="nav-link" href="#">Cài đặt</a></li>
          </ul>

        </div>
      </div>
    </nav>
  </header>

  <!-- ========== PAGE CONTENT ========== -->
  <div class="container py-4">

    <!-- TITLE + FILTER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h4 class="fw-bold text-dark">Trung tâm thông báo</h4>
        <div class="text-muted small">Thông báo từ ứng viên · phỏng vấn · hệ thống</div>
      </div>

      <div class="d-flex gap-2">
        <button class="filter-pill active" data-filter="all">Tất cả</button>
        <button class="filter-pill" data-filter="unread">Chưa đọc</button>
        <button class="filter-pill" data-filter="cv">CV</button>
        <button class="filter-pill" data-filter="interview">Phỏng vấn</button>
        <button class="filter-pill" data-filter="system">Hệ thống</button>
      </div>
    </div>

    <div class="row g-4">

      <!-- LIST -->
      <div class="col-lg-5">
        <div class="card card-soft">
          <div class="card-body">

            <div class="d-flex justify-content-between mb-2">
              <div class="fw-semibold">Danh sách thông báo</div>
              <button class="btn btn-sm btn-outline-secondary" id="markAllRead">
                <i class="bi bi-check2-all"></i> Đánh dấu đọc
              </button>
            </div>

            <div id="notifList">

              <!-- Item 1 -->
              <div class="notif-item unread"
                   data-id="1"
                   data-type="cv"
                   data-title="Ứng viên Nguyễn Tùng gửi CV mới"
                   data-source="Vị trí: Thực tập sinh Marketing"
                   data-time="14/11/2025 · 14:20"
                   data-content="Ứng viên Nguyễn Tùng vừa gửi CV ứng tuyển vào vị trí Thực tập sinh Marketing. Bạn có thể xem hồ sơ trong mục Ứng viên.">
                <div class="d-flex justify-content-between">
                  <div class="notif-title">Ứng viên Nguyễn Tùng gửi CV mới</div>
                  <span class="badge-type badge-cv">CV mới</span>
                </div>
                <div class="small text-muted">Vị trí: Thực tập sinh Marketing</div>
              </div>

              <!-- Item 2 -->
              <div class="notif-item unread"
                   data-id="2"
                   data-type="interview"
                   data-title="Xác nhận phỏng vấn ứng viên Trần Thu Hà"
                   data-source="Frontend Intern"
                   data-time="16/11/2025 · 09:00"
                   data-content="Ứng viên Trần Thu Hà đã xác nhận tham gia buổi phỏng vấn cho vị trí Frontend Intern. Hãy chuẩn bị câu hỏi và phòng họp.">
                <div class="d-flex justify-content-between">
                  <div class="notif-title">Xác nhận phỏng vấn ứng viên Trần Thu Hà</div>
                  <span class="badge-type badge-interview">Phỏng vấn</span>
                </div>
                <div class="small text-muted">Frontend Intern</div>
              </div>

              <!-- Item 3 -->
              <div class="notif-item"
                   data-id="3"
                   data-type="system"
                   data-title="Cập nhật chính sách đăng tuyển"
                   data-source="Hệ thống Learn2Earn"
                   data-time="10/11/2025"
                   data-content="Hệ thống đã cập nhật chính sách đăng tuyển mới nhằm tối ưu hiệu quả tiếp cận ứng viên.">
                <div class="d-flex justify-content-between">
                  <div class="notif-title">Cập nhật chính sách đăng tuyển</div>
                  <span class="badge-type badge-system">Hệ thống</span>
                </div>
                <div class="small text-muted">Learn2Earn</div>
              </div>

              <!-- Item 4 -->
              <div class="notif-item"
                   data-id="4"
                   data-type="cv"
                   data-title="Ứng viên Lê Quốc Nhật cập nhật CV"
                   data-source="Backend Intern"
                   data-time="09/11/2025"
                   data-content="Ứng viên Lê Quốc Nhật đã cập nhật CV cho vị trí Backend Intern. Kiểm tra bản cập nhật trong mục Ứng viên.">
                <div class="d-flex justify-content-between">
                  <div class="notif-title">Ứng viên Lê Quốc Nhật cập nhật CV</div>
                  <span class="badge-type badge-cv">CV cập nhật</span>
                </div>
                <div class="small text-muted">Backend Intern</div>
              </div>

            </div>
          </div>
        </div>
      </div>

      <!-- DETAIL -->
      <div class="col-lg-7">
        <div class="card card-soft mb-3">
          <div class="card-body">
            <div class="d-flex justify-content-between">
              <div>
                <div id="detailTitle" class="fw-semibold">Ứng viên Nguyễn Tùng gửi CV mới</div>
                <div id="detailSource" class="small text-muted">Vị trí: Thực tập sinh Marketing</div>
              </div>

              <span id="detailTypeText" class="badge bg-info text-dark small">CV mới</span>
            </div>

            <div class="small text-muted mt-2 mb-2">
              <i class="bi bi-clock me-1"></i> <span id="detailTime">14/11/2025 · 14:20</span>
            </div>

            <hr>

            <p id="detailContent" class="small mb-0">
              Ứng viên Nguyễn Tùng vừa gửi CV ứng tuyển vào vị trí Thực tập sinh Marketing.
              Bạn có thể xem hồ sơ trong mục Ứng viên.
            </p>
          </div>
        </div>

        <div class="card card-soft">
          <div class="card-body">
            <div class="fw-semibold mb-2">Hành động</div>

            <div class="d-flex flex-wrap gap-2">
              <button class="btn btn-success btn-sm">
                <i class="bi bi-person-check"></i> Duyệt hồ sơ
              </button>

              <button class="btn btn-outline-primary btn-sm">
                <i class="bi bi-envelope"></i> Gửi phản hồi
              </button>

              <button class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-star"></i> Lưu ứng viên
              </button>
            </div>

            <hr>

            <div class="small text-muted">
              Gợi ý: Duyệt hồ sơ nhanh giúp tối ưu thời gian tuyển dụng và giữ chân ứng viên tiềm năng.
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ========== FOOTER ========== -->
  <footer class="footer">
    <div class="container">
      <div class="row">

        <div class="col-lg-4 mb-4">
          <h4 class="footer-title">Learn2Earn</h4>
          <p>Nền tảng hỗ trợ tuyển dụng và tìm kiếm ứng viên chất lượng cao.</p>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Về chúng tôi</h4>
          <ul class="footer-links">
            <li><a href="#">Giới thiệu</a></li>
            <li><a href="#">Tin tức</a></li>
            <li><a href="#">Tuyển dụng</a></li>
            <li><a href="#">Liên hệ</a></li>
          </ul>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Doanh nghiệp</h4>
          <ul class="footer-links">
            <li><a href="#">Đăng tin</a></li>
            <li><a href="#">Quản lý ứng viên</a></li>
            <li><a href="#">Gói dịch vụ</a></li>
            <li><a href="#">Hỗ trợ</a></li>
          </ul>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Liên hệ</h4>
          <ul class="footer-links">
            <li><a href="#"><i class="fas fa-phone me-2"></i>+84 123 456 789</a></li>
            <li><a href="#"><i class="fas fa-envelope me-2"></i>support@learn2earn.vn</a></li>
            <li><a href="#"><i class="fas fa-map-marker-alt me-2"></i>Hà Nội, Việt Nam</a></li>
          </ul>
        </div>

      </div>

      <div class="footer-bottom">
        &copy; 2024 Learn2Earn. All rights reserved.
      </div>
    </div>
  </footer>

  <!-- JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    function setDetail(item) {
      document.getElementById("detailTitle").textContent = item.dataset.title;
      document.getElementById("detailSource").textContent = item.dataset.source;
      document.getElementById("detailTime").textContent = item.dataset.time;
      document.getElementById("detailContent").textContent = item.dataset.content;

      const type = item.dataset.type;
      const badge = document.getElementById("detailTypeText");

      if (type === "cv") {
        badge.textContent = "CV";
        badge.className = "badge bg-info text-dark small";
      } else if (type === "interview") {
        badge.textContent = "Phỏng vấn";
        badge.className = "badge bg-success text-white small";
      } else if (type === "system") {
        badge.textContent = "Hệ thống";
        badge.className = "badge bg-secondary text-white small";
      } else {
        badge.textContent = "Khác";
        badge.className = "badge bg-primary text-white small";
      }

      item.classList.remove("unread");
    }

    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".notif-item");

      items.forEach(item => {
        item.addEventListener("click", () => setDetail(item));
      });

      if (items.length > 0) {
        setDetail(items[0]); // load item đầu
      }

      document.getElementById("markAllRead").addEventListener("click", () => {
        items.forEach(i => i.classList.remove("unread"));
      });

      document.querySelectorAll(".filter-pill").forEach(btn => {
        btn.addEventListener("click", () => {
          document.querySelectorAll(".filter-pill").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");

          const f = btn.dataset.filter;
          items.forEach(item => {
            const type = item.dataset.type;
            const unread = item.classList.contains("unread");

            let show = true;
            if (f === "cv" && type !== "cv") show = false;
            if (f === "interview" && type !== "interview") show = false;
            if (f === "system" && type !== "system") show = false;
            if (f === "unread" && !unread) show = false;

            item.style.display = show ? "" : "none";
          });
        });
      });
    });
  </script>

</body>
</html>
