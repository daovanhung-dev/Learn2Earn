<!-- ================= CONTENT ================= -->
<div class="container py-4">
  <div class="card card-soft">
    <div class="card-body">

      <!-- HEADER TIN TUYỂN DỤNG -->
      <div class="job-header mb-3">
        <div class="company-logo" id="logoBox">A</div>
        <div class="flex-grow-1">
          <h5 class="mb-1 fw-semibold" id="jobTitle">Thực tập sinh Java</h5>
          <div class="small-muted">
            <i class="bi bi-building me-1"></i><span id="jobCompany">ABC Software</span>
            · <span id="jobLocation">Hà Nội</span>
          </div>
          <div class="small-muted">
            <i class="bi bi-clock me-1"></i>Hạn nộp: <span id="jobDeadline">30/11/2025</span>
          </div>
        </div>
        <div class="text-end">
          <div class="badge-jobcode mb-2">
            Mã tin: <span id="jobCode">L2E-JAVA-01</span>
          </div>
          <div class="small-muted">
            Gửi CV phù hợp, viết thư giới thiệu rõ ràng.
          </div>
        </div>
      </div>

      <hr class="mt-2 mb-3">

      <!-- FORM ỨNG TUYỂN -->
      <form id="applyForm" class="needs-validation" novalidate>

        <!-- CHỌN CV -->
        <div class="mb-3">
          <label class="form-label fw-semibold">
            Chọn CV để ứng tuyển <span class="text-danger">*</span>
          </label>
          <select class="form-select" id="cvSelect" required>
            <option value="">-- Chọn CV của bạn --</option>
            <option value="CV_Fresher_Java.pdf">CV_Fresher_Java.pdf</option>
            <option value="CV_Intern_Flutter.pdf">CV_Intern_Flutter.pdf</option>
            <option value="CV_Fresher_Frontend.pdf">CV_Fresher_Frontend.pdf</option>
          </select>
          <div class="invalid-feedback">Vui lòng chọn một CV.</div>
          <div class="form-text small">
            Nếu chưa có CV, hãy vào trang “Tạo CV” / “Cập nhật CV”.
          </div>
        </div>

        <!-- THƯ GIỚI THIỆU -->
        <div class="mb-3">
          <label class="form-label fw-semibold">
            Thư giới thiệu ngắn gọn <span class="text-danger">*</span>
          </label>
          <textarea class="form-control" id="coverLetter" rows="4" required
            placeholder="Giới thiệu về bản thân, kỹ năng chính và lý do bạn phù hợp với vị trí này..."></textarea>
          <div class="invalid-feedback">Vui lòng nhập thư giới thiệu.</div>
        </div>

        <!-- THÔNG TIN LIÊN HỆ -->
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Số điện thoại liên hệ <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="phone"
                   value="0987654321"
                   pattern="^[0-9]{9,11}$" required>
            <div class="invalid-feedback">
              Số điện thoại chỉ gồm số, 9–11 ký tự.
            </div>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" id="email"
                   value="sv001@sv.vnua.edu.vn" required>
            <div class="invalid-feedback">
              Email không hợp lệ.
            </div>
          </div>
        </div>

        <!-- NÚT GỬI -->
        <button class="btn btn-primary w-100 mt-2" type="submit">
          <i class="bi bi-send-check me-1"></i> Gửi hồ sơ ứng tuyển
        </button>
      </form>
    </div>
