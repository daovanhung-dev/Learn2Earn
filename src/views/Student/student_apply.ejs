<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Lấy dữ liệu tin tuyển dụng từ query string
  function loadJobFromQuery() {
    const params   = new URLSearchParams(window.location.search);

    const title    = params.get("title")    || "Thực tập sinh Java";
    const company  = params.get("company")  || "ABC Software";
    const location = params.get("location") || "Hà Nội";
    const deadline = params.get("deadline") || "30/11/2025";
    const code     = params.get("code")     || "L2E-JAVA-01";

    document.getElementById("jobTitle").textContent    = title;
    document.getElementById("jobCompany").textContent  = company;
    document.getElementById("jobLocation").textContent = location;
    document.getElementById("jobDeadline").textContent = deadline;
    document.getElementById("jobCode").textContent     = code;

    // logo = chữ cái đầu tên công ty
    const trimmed = company.trim();
    const logoChar = trimmed ? trimmed[0].toUpperCase() : "?";
    document.getElementById("logoBox").textContent = logoChar;
  }

  // Validate form & submit (demo)
  (function () {
    const form = document.getElementById("applyForm");

    form.addEventListener("submit", function (event) {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
        form.classList.add("was-validated");
        const firstInvalid = form.querySelector(":invalid");
        if (firstInvalid) firstInvalid.focus();
      } else {
        event.preventDefault(); // demo: không gửi lên server

        const title = document.getElementById("jobTitle").textContent;
        const cv    = document.getElementById("cvSelect").value;

        form.classList.add("was-validated");
        alert(
          "Đã gửi hồ sơ ứng tuyển (demo)!" +
          "\nVị trí: " + title +
          "\nCV: " + cv
        );
      }
    }, false);
  })();

  window.addEventListener("DOMContentLoaded", loadJobFromQuery);
</script>

