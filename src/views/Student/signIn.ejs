<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Đăng Nhập - Learn2Earn</title>

  <!-- Bootstrap + Font Awesome + Fonts -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --primary-500:#3B82F6;
      --primary-600:#2563EB;
      --neutral-50:#F8FAFC;
      --border:#E6EEF9;
      --card-shadow: 0 18px 36px rgba(59,130,246,0.07);
    }
    *{box-sizing:border-box}
    body{
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg,var(--neutral-50),#fff);
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:20px;
      color:#1e293b;
    }

    .login-container{
      width:100%;
      max-width:1040px;
      border-radius:18px;
      overflow:hidden;
      display:grid;
      grid-template-columns: 420px 1fr;
      background:#fff;
      box-shadow:var(--card-shadow);
    }

    /* left panel */
    .login-left{
      padding:44px;
      background: linear-gradient(180deg,#fff,var(--neutral-50));
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:14px;
      text-align:center;
    }
    .logo-img img{width:120px;height:120px;object-fit:contain}
    .login-left h1{font-size:28px;margin-top:6px;color:#0f172a}
    .login-left p{color:#475569;margin-bottom:6px}
    .features{list-style:none;padding:0;margin-top:14px}
    .features li{display:flex;gap:10px;align-items:center;color:#334155;margin-bottom:10px}
    .features i{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;background:#f1f5f9;color:var(--primary-500)}

    /* right panel (form) */
    .login-right{padding:36px 44px; display:flex; flex-direction:column; justify-content:center;}
    .login-header h2{font-family:'Poppins',sans-serif;font-size:26px;margin-bottom:6px}
    .login-header p{color:#64748b;margin-bottom:18px}

    .social-login{display:flex;gap:10px;margin-bottom:12px}
    .social-btn{flex:1;border-radius:10px;border:1px solid var(--border);padding:9px 10px;background:#fff;display:flex;align-items:center;justify-content:center;gap:8px;font-weight:600}
    .divider{display:flex;align-items:center;gap:12px;margin:16px 0;color:#64748b}
    .divider::before,.divider::after{content:"";flex:1;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent)}

    .form-label{font-weight:600;margin-bottom:6px;color:#334155}
    .btn-login{width:100%;padding:12px;border-radius:10px;border:none;font-weight:700;background:linear-gradient(135deg,var(--primary-500),var(--primary-600));color:#fff}
    .btn-login:active{transform:translateY(0)}
    .small-note{font-size:13px;color:#64748b;margin-top:10px;text-align:center}

    /* alert style */
    .alert-custom{display:flex;align-items:flex-start;gap:12px;padding:12px;border-radius:10px}
    .alert-custom i{font-size:20px;margin-top:4px}

    @media(max-width:900px){
      .login-container{grid-template-columns:1fr;max-width:720px}
      .login-left{padding:28px}
      .login-right{padding:24px}
    }

    @media(max-width:420px){
      .logo-img img{width:100px;height:100px}
    }
  </style>
</head>

<body>
  <div class="login-container">
    <!-- LEFT -->
    <aside class="login-left">
      <div class="logo-img"><img src="/img/logo-nobr.png" alt="Learn2Earn"></div>
      <h1>Chào mừng trở lại</h1>
      <p>Tiếp tục hành trình học & kiếm tiền cùng Learn2Earn</p>

      <ul class="features" aria-hidden="false">
        <li><i class="fas fa-rocket"></i><span>Tiếp tục khóa học bạn đang theo</span></li>
        <li><i class="fas fa-coins"></i><span>Truy cập cơ hội kiếm tiền</span></li>
        <li><i class="fas fa-users"></i><span>Kết nối cộng đồng học viên</span></li>
        <li><i class="fas fa-chart-line"></i><span>Theo dõi tiến độ & thành tích</span></li>
      </ul>
    </aside>

    <!-- RIGHT (FORM) -->
    <main class="login-right" aria-labelledby="loginTitle">
      <div class="login-header">
        <h2 id="loginTitle">Đăng nhập</h2>
        <p>Nhập thông tin tài khoản để tiếp tục</p>
      </div>

      <div class="social-login" role="group" aria-label="Đăng nhập bằng mạng xã hội">
        <button type="button" class="social-btn" title="Đăng nhập bằng Google"><i class="fab fa-google"></i>Google</button>
        <button type="button" class="social-btn" title="Đăng nhập bằng Facebook"><i class="fab fa-facebook-f"></i>Facebook</button>
        <button type="button" class="social-btn" title="Đăng nhập bằng LinkedIn"><i class="fab fa-linkedin-in"></i>LinkedIn</button>
      </div>

      <div class="divider"><span>Hoặc</span></div>

      <!-- ERRORS -->
      <% if (errors && errors.length) { %>
        <div class="mb-3">
          <% errors.forEach(function(err){ %>
            <div class="alert alert-danger alert-custom" role="alert">
              <i class="fas fa-exclamation-circle"></i>
              <div>
                <strong>Lỗi:</strong>
                <div><%= err %></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <form id="login-form" action="/signInStudent" method="POST" novalidate>
        <div class="mb-3">
          <label class="form-label" for="email">Tài khoản</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-user"></i></span>
            <input id="email" name="email" type="text" class="form-control" placeholder="Email hoặc số điện thoại" required
              value="<%= typeof email !== 'undefined' ? email : '' %>" autocomplete="username" autofocus aria-label="Email hoặc số điện thoại">
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label" for="matkhau">Mật khẩu</label>
          <div class="input-group position-relative">
            <span class="input-group-text"><i class="fas fa-lock"></i></span>
            <input id="matkhau" name="matkhau" type="password" class="form-control" placeholder="Nhập mật khẩu" required autocomplete="current-password" aria-label="Mật khẩu">
            <button type="button" id="togglePassword" class="btn btn-sm position-absolute" style="right:8px;top:50%;transform:translateY(-50%);border:none;background:none;">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="rememberMe" name="rememberMe">
            <label class="form-check-label" for="rememberMe">Ghi nhớ đăng nhập</label>
          </div>
          <div><a href="#" class="small">Quên mật khẩu?</a></div>
        </div>

        <button id="submitBtn" type="submit" class="btn btn-login">
          <span id="btnText">Đăng Nhập</span>
          <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
        </button>

        <div class="small-note">Chưa có tài khoản? <a href="/signUp">Đăng ký ngay</a></div>
      </form>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Toggle password visibility
    (function(){
      const toggle = document.getElementById('togglePassword');
      const pass = document.getElementById('matkhau');
      toggle?.addEventListener('click', () => {
        if (!pass) return;
        pass.type = pass.type === 'password' ? 'text' : 'password';
        toggle.querySelector('i')?.classList.toggle('fa-eye-slash');
      });

      // simple submit UX: show spinner & disable button
      const form = document.getElementById('login-form');
      const submitBtn = document.getElementById('submitBtn');
      const spinner = document.getElementById('btnSpinner');
      form?.addEventListener('submit', () => {
        if (!submitBtn || !spinner) return;
        submitBtn.setAttribute('disabled', 'true');
        spinner.classList.remove('d-none');
      });
    })();
  </script>
</body>
</html>
