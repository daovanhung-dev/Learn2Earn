<!-- ================= JS ================= -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
  function sendMessage() {
    const input = document.getElementById("chatInput");
    const text = input.value.trim();
    if (!text) return;

    const chatBody = document.getElementById("chatBody");

    const row = document.createElement("div");
    row.className = "msg-row me";
    row.innerHTML = `
      <div>
        <div class="msg-bubble me">${text}</div>
        <div class="msg-time">Bạn · vừa xong</div>
      </div>
    `;
    chatBody.appendChild(row);

    chatBody.scrollTop = chatBody.scrollHeight;
    input.value = "";
  }

  document.getElementById("btnSend").addEventListener("click", sendMessage);
  document.getElementById("chatInput").addEventListener("keydown", function (e) {
    if (e.key === "Enter") {
      e.preventDefault();
      sendMessage();
    }
  });

  const chatItems = document.querySelectorAll(".chat-item");
  chatItems.forEach(item => {
    item.addEventListener("click", function () {
      chatItems.forEach(i => i.classList.remove("active"));
      item.classList.add("active");

      const company  = item.getAttribute("data-company");
      const logo     = item.getAttribute("data-logo");
      const position = item.getAttribute("data-position");
      const status   = item.getAttribute("data-status");

      document.getElementById("currentCompany").textContent = company;
      document.getElementById("currentLogo").textContent    = logo;
      document.getElementById("currentPosition").textContent = position;

      const statusDot  = document.getElementById("currentStatusDot");
      const statusText = document.getElementById("currentStatusText");

      if (status === "online") {
        statusDot.className = "status-dot status-online";
        statusText.textContent = "Đang online";
      } else {
        statusDot.className = "status-dot status-offline";
        statusText.textContent = "Ngoại tuyến gần đây";
      }

      const chatBody = document.getElementById("chatBody");
      chatBody.innerHTML = "";
    });
  });

  document.getElementById("chatSearch").addEventListener("input", function () {
    const q = this.value.toLowerCase();
    chatItems.forEach(item => {
      const txt = (item.getAttribute("data-company") + " " + item.getAttribute("data-position")).toLowerCase();
      item.style.display = txt.includes(q) ? "" : "none";
    });
  });
</script>

