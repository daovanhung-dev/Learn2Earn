  <style>
    body {
      background: #f3f6fb;
      font-size: 0.95rem;
      margin: 0;
      font-family: 'Inter', sans-serif;
    }

    /* ================= HEADER ================= */
    .header {
      background: #ffffff;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    .navbar {
      min-height: 72px;
      display: flex;
      align-items: center;
    }
    .navbar-brand img {
      height: 55px;
      object-fit: contain;
    }
    .navbar-nav .nav-link {
      font-weight: 500;
      color: #475569;
      padding: 8px 14px;
      border-radius: 999px;
      transition: 0.25s;
    }
    .navbar-nav .nav-link:hover {
      background: #EFF6FF !important;
      color: #2563EB !important;
    }
    .navbar-nav .nav-link.active {
      background: #DBEAFE !important;
      color: #1D4ED8 !important;
    }

    /* ICONS */
    .nav-icon {
      width: 38px;
      height: 38px;
      margin-left: 8px;
      margin-right: 8px;
      border-radius: 50%;
      background: #f1f5f9;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #475569;
      font-size: 18px;
      transition: 0.25s;
    }
    .nav-icon:hover {
      background: #e2e8f0;
      color: #2563EB;
    }
    .brand-logo {
        height: 60px;       
        width: auto;
        display: block;
        object-fit: contain;

        transform: scale(2.3);
        transform-origin: left center;
    }

    /* Dropdown */
    .l2e-dropdown:hover .dropdown-menu {
      display: block;
    }
    .dropdown-menu {
      display: none;
      border-radius: 12px;
      box-shadow: 0 8px 22px rgba(0,0,0,0.1);
      border: 1px solid #e5e7eb;
      padding: 6px 0;
    }
    .dropdown-item {
      padding: 10px 18px;
      font-weight: 500;
      border-radius: 8px;
    }
    .dropdown-item:hover {
      background: #EFF6FF;
      color: #2563EB;
    }

    /* ============= CHAT ============= */
    .chat-item {
      cursor: pointer;
      border-radius: 10px;
      padding: 8px 10px;
      margin-bottom: 4px;
    }
    .chat-item.active {
      background: #e0ecff;
    }
    .chat-item:hover {
      background: #eef2ff;
    }
    .company-logo {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      background: #e5e7eb;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #4b5563;
      margin-right: 8px;
    }
    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 4px;
    }
    .status-online { background: #22c55e; }
    .status-offline { background: #9ca3af; }

    /* CHAT WINDOW */
    .chat-window {
      height: 480px;
      display: flex;
      flex-direction: column;
      border-radius: 14px;
      background: #ffffff;
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
    }
    .chat-header {
      padding: 12px 16px;
      border-bottom: 1px solid #e5e7eb;
    }
    .chat-body {
      flex: 1;
      padding: 12px 16px;
      overflow-y: auto;
      background: #f9fafb;
    }
    .chat-footer {
      padding: 10px 12px;
      border-top: 1px solid #e5e7eb;
      background: #ffffff;
    }

    .msg-row {
      display: flex;
      margin-bottom: 8px;
    }
    .msg-row.me {
      justify-content: flex-end;
    }
    .msg-bubble {
      max-width: 75%;
      padding: 8px 10px;
      border-radius: 12px;
      font-size: 0.9rem;
    }
    .msg-bubble.me {
      background: #1e6ee9;
      color: #ffffff;
      border-bottom-right-radius: 4px;
    }
    .msg-bubble.them {
      background: #e5e7eb;
      color: #111827;
      border-bottom-left-radius: 4px;
    }
    .msg-time {
      font-size: 0.75rem;
      color: #9ca3af;
      margin-top: 2px;
    }

    /* ============= FOOTER ============= */
    .footer {
      background: #0F172A;
      color: white;
      padding: 56px 0 26px;
      margin-top: 70px;
    }
    .footer-title {
      font-size: 17px;
      font-weight: 600;
      margin-bottom: 18px;
    }
    .footer-links a {
      color: #94A3B8;
      text-decoration: none;
    }
    .footer-links a:hover {
      color: white;
    }
    .footer-bottom {
      border-top: 1px solid #1E293B;
      padding-top: 18px;
      margin-top: 32px;
      text-align: center;
      color: #94A3B8;
      font-size: 0.85rem;
    }
  </style>
</head>

