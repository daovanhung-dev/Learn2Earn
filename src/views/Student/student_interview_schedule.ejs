<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Cập nhật panel chi tiết từ 1 item
  function setDetailFromItem(item) {
    const company  = item.getAttribute("data-company");
    const position = item.getAttribute("data-position");
    const date     = item.getAttribute("data-date");
    const time     = item.getAttribute("data-time");
    const location = item.getAttribute("data-location");
    const mode     = item.getAttribute("data-mode");
    const note     = item.getAttribute("data-note");
    const contact  = item.getAttribute("data-contact");
    const status   = item.getAttribute("data-status");

    document.getElementById("detailCompany").textContent  = company || "";
    document.getElementById("detailPosition").textContent = position || "";
    document.getElementById("detailDate").textContent     = date || "";
    document.getElementById("detailTime").textContent     = time || "";
    document.getElementById("detailLocation").textContent = location || "";
    document.getElementById("detailMode").textContent     = mode || "";
    document.getElementById("detailNote").textContent     = note || "";
    document.getElementById("detailContact").textContent  = contact || "";

    const statusBadge = document.getElementById("detailStatus");
    statusBadge.className = "status-badge"; // reset
    if (status === "upcoming") {
      statusBadge.textContent = "Sắp diễn ra";
      statusBadge.classList.add("status-upcoming");
    } else if (status === "done") {
      statusBadge.textContent = "Đã diễn ra";
      statusBadge.classList.add("status-done");
    } else if (status === "cancel") {
      statusBadge.textContent = "Đã hủy";
      statusBadge.classList.add("status-cancel");
    } else {
      statusBadge.textContent = "Khác";
    }
  }

  // Áp dụng filter theo trạng thái
  function applyInterviewFilter(filter) {
    const items = document.querySelectorAll(".interview-item");
    let upcomingCount = 0;
    let allCount = 0;

    items.forEach(item => {
      const status = item.getAttribute("data-status");
      allCount++;

      if (status === "upcoming") upcomingCount++;

      let show = true;
      if (filter === "upcoming" && status !== "upcoming") show = false;
      if (filter === "done" && status !== "done") show = false;
      if (filter === "cancel" && status !== "cancel") show = false;

      item.style.display = show ? "" : "none";
    });

    document.getElementById("countUpcoming").textContent = upcomingCount;
    document.getElementById("countAll").textContent = allCount + " lịch";
  }

  document.addEventListener("DOMContentLoaded", function () {
    const items = document.querySelectorAll(".interview-item");

    // Gắn click cho từng lịch phỏng vấn
    items.forEach(item => {
      item.addEventListener("click", function () {
        items.forEach(i => i.classList.remove("active"));
        item.classList.add("active");
        setDetailFromItem(item);
      });
    });

    // Set mặc định là item đầu tiên (nếu có)
    if (items[0]) {
      items[0].classList.add("active");
      setDetailFromItem(items[0]);
    }

    // Filter pills
    const filterButtons = document.querySelectorAll(".filter-pill");
    filterButtons.forEach(btn => {
      btn.addEventListener("click", function () {
        filterButtons.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        const f = btn.getAttribute("data-filter");
        applyInterviewFilter(f === "all" ? "" : f);
      });
    });

    // Tính lại số lượng ban đầu
    applyInterviewFilter("");

    // Các nút hành động (demo)
    document.getElementById("btnConfirm").addEventListener("click", function () {
      alert("Demo: Xác nhận tham gia lịch phỏng vấn này (chưa kết nối backend).");
    });

    document.getElementById("btnRequestChange").addEventListener("click", function () {
      alert("Demo: Gửi yêu cầu xin đổi lịch phỏng vấn (chưa kết nối backend).");
    });

    document.getElementById("btnJoinOnline").addEventListener("click", function () {
      alert("Demo: Mở link phòng họp online nếu có (chưa gắn URL thật).");
    });
  });
</script>

</body>
</html>
