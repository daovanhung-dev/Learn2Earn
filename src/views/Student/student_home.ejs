      background: #EFF6FF;
      color: #2563EB;
      font-weight: 500;
    }

    .job-time {
      font-size: .8rem;
      color: #6B7280
    }

    .job-actions {
      display: flex;
      flex-direction: column;
      gap: 6px;
      justify-content: center;
      height: 100%
    }

    .btn-apply,
