      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      border-radius: 999px;
      background: #EFF6FF;
      color: #2563EB;
      font-size: .85rem;
    }

    .job-card {
      border-radius: 16px;
      background: #fff;
      border: 1px solid #E2E8F0;
      margin-bottom: 14px;
    }

    .job-card .card-body {
      padding: 16px
