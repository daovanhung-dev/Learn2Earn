      border-radius: 12px;
      padding: 10px 20px;
      font-weight: 600;
      font-size: .95rem;
      color: #fff;
      background: linear-gradient(135deg, #3B82F6, #2563EB);
    }

    .search-helper {
      margin-top: 8px;
      font-size: .85rem;
      color: #64748B;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: space-between;
    }

    .search-helper strong {
      color: #2563EB
