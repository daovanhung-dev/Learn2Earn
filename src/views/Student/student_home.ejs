<!DOCTYPE html>
<html lang="vi">

<%- include('../ComponentStudent/head', { title: 'Trang Chủ Learn2Earn', extras: {} }) %>

<body>
  <%- include('../ComponentStudent/header') %>
  <!-- ===== END HEADER ===== -->
  <section class="hero-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center">
          <div class="hero-badge">
            <i class="fa-solid fa-bolt"></i>
            <span>Tìm việc nhanh – Kết nối trực tiếp doanh nghiệp</span>
          </div>
          <h1 class="hero-title">Tìm <span>việc làm phù hợp</span> với bạn</h1>
          <p class="hero-subtitle">
            Kết nối với hàng ngàn cơ hội việc làm từ các doanh nghiệp hàng đầu trên toàn quốc dành cho sinh viên và
            người đi làm.
          </p>
          <div class="hero-stats">
            <div class="hero-stat-pill"><span>1.000+</span><span>việc làm mới mỗi tuần</span></div>
            <div class="hero-stat-pill"><span>500+</span><span>doanh nghiệp đối tác</span></div>
            <div class="hero-stat-pill"><span>24/7</span><span>theo dõi lịch phỏng vấn</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="search-section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-10">
          <div class="search-box">
            <form class="search-form">
              <div class="row g-3 align-items-center">
                <div class="col-md-4">
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-briefcase"></i></span>
                    <input type="text" class="form-control" placeholder="Vị trí tuyển dụng">
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                    <input type="text" class="form-control" placeholder="Địa điểm">
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-tag"></i></span>
                    <select class="form-control">
                      <option selected>Danh mục nghề</option>
                      <option>Công nghệ thông tin</option>
                      <option>Kinh doanh / Bán hàng</option>
                      <option>Marketing</option>
                      <option>Kế toán / Tài chính</option>
                      <option>Nhân sự</option>
                    </select>
                  </div>
                </div>
                <div class="col-md-2">
                  <button type="submit" class="btn-search">
                    <i class="fas fa-search me-2"></i>Tìm kiếm
                  </button>
                </div>
              </div>
              <div class="search-helper">
                <span>Gợi ý: <strong>Marketing, Thực tập sinh, Bán thời gian,...</strong></span>
                <span>Hiển thị kết quả theo ưu tiên “<strong>Mới nhất</strong>”</span>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="filter-tabs">
    <div class="container">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center flex-wrap gap-2">
          <span class="text-muted me-1 filter-meta">Tìm kiếm theo:</span>
          <ul class="nav nav-pills nav-chips">
            <li class="nav-item"><a class="nav-link" href="#">Tên việc làm</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Tên công ty</a></li>
            <li class="nav-item"><a class="nav-link active" href="#">Cả hai</a></li>
          </ul>
        </div>
        <div class="d-inline-flex align-items-center gap-2">
          <span class="text-muted small">Ưu tiên hiển thị theo:</span>
          <select class="form-select form-select-sm w-auto rounded-3">
            <option>Mới nhất</option>
            <option>Lương cao</option>
            <option>Gần bạn</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <main class="container my-4 my-lg-5">
    <div class="row g-4">
      <aside class="col-lg-3">
        <div class="sidebar-card">
          <div class="card-header">
            <span><i class="fas fa-filter me-2"></i>Lọc nâng cao</span>
            <span class="small text-muted">
              <%= totalJobs %> kết quả
            </span>
          </div>
          <div class="card-body">
            <!-- Filters -->
            <div class="filter-group">
              <div class="filter-label">Theo danh mục nghề</div>
              <% const categories = ['Quản lý kinh doanh', 'Marketing', 'Kế toán', 'Sales Bán lẻ', 'Kinh doanh/Bán hàng', 'Nhân sự', 'Quảng cáo/Sáng tạo']; %>
              <% categories.forEach((cat, index) => { %>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="dm<%= index + 1 %>">
                  <label class="form-check-label" for="dm<%= index + 1 %>">
                    <%= cat %>
                  </label>
                </div>
              <% }) %>
            </div>

            <div class="filter-group">
              <div class="filter-label">Cấp bậc</div>
              <% const levels = ['Tất cả', 'Nhân viên', 'Trưởng nhóm', 'Trưởng phòng', 'Giám đốc', 'Thực tập sinh']; %>
              <% levels.forEach((level, index) => { %>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="capbac" id="cb<%= index %>" <%= index === 0 ? 'checked' : '' %>>
                  <label class="form-check-label" for="cb<%= index %>">
                    <%= level %>
                  </label>
                </div>
              <% }) %>
            </div>

            <div class="filter-group">
              <div class="filter-label">Mức lương</div>
              <% const salaries = ['Tất cả', 'Dưới 10 triệu', '10 – 15 triệu', '15 – 20 triệu', '20 – 25 triệu', 'Trên 25 triệu']; %>
              <% salaries.forEach((salary, index) => { %>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="luong" id="lu<%= index %>" <%= index === 0 ? 'checked' : '' %>>
                  <label class="form-check-label" for="lu<%= index %>">
                    <%= salary %>
                  </label>
                </div>
              <% }) %>
            </div>

            <div class="filter-group">
              <div class="filter-label">Hình thức làm việc</div>
              <% const workTypes = ['Tất cả', 'Toàn thời gian', 'Bán thời gian', 'Thực tập']; %>
              <% workTypes.forEach((type, index) => { %>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="hinhthuc" id="ht<%= index %>" <%= index === 0 ? 'checked' : '' %>>
                  <label class="form-check-label" for="ht<%= index %>">
                    <%= type %>
                  </label>
                </div>
              <% }) %>
            </div>

            <button type="button" class="btn-clear">Xóa lọc</button>
          </div>
        </div>
      </aside>

      <section class="col-lg-9">
        <div class="jobs-header">
          <div>
            <div class="jobs-title">Kết quả tìm kiếm <span>(<%= totalJobs %> việc làm)</span></div>
            <div class="jobs-subtitle">
              Sắp xếp theo: <strong>Mới nhất</strong> · Bạn có thể thay đổi tiêu chí ở phía trên.
            </div>
          </div>
          <div class="result-badge">
            <i class="fa-solid fa-circle-check"></i>
            Phù hợp với sinh viên &amp; người mới đi làm
          </div>
        </div>

        <% jobs.forEach(job => { %>
          <div class="card job-card">
            <div class="card-body">
              <div class="row gx-3">
                <div class="col-md-9">
                  <div class="d-flex align-items-start mb-2">
                    <div class="job-logo"><i class="fas fa-building"></i></div>
                    <div>
                      <h3 class="job-title"><%= job.ten_vi_tri %></h3>
                      <p class="job-company"><%= job.ten_cong_ty %> · <%= job.dia_diem %></p>
                      <div class="job-meta">
                        <div class="job-meta-item"><i class="fas fa-map-marker-alt"></i><span><%= job.dia_diem %></span></div>
                        <div class="job-meta-item"><i class="fas fa-clock"></i><span><%= job.thoi_gian %></span></div>
                        <div class="job-meta-item job-salary"><i class="fas fa-money-bill-wave"></i><span><%= job.muc_luong %></span></div>
                      </div>
                      <div class="job-tags">
                        <% if (job.cap_bac) { %><span class="job-tag"><%= job.cap_bac %></span><% } %>
                        <% if (job.nganh) { %><span class="job-tag"><%= job.nganh %></span><% } %>
                      </div>
                      <% if (job.uu_tien) { %>
                        <div class="job-time"><%= job.uu_tien %></div>
                      <% } %>
                    </div>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="job-actions">
                    <button class="btn-quick-view" onclick="xemChiTiet(<%= job.id %>)">Xem chi tiết</button>
                    <button class="btn-apply" onclick="ungTuyen()">Ứng tuyển</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>

        <nav aria-label="Page navigation">
          <ul class="pagination">
            <li class="page-item <%= page === 1 ? 'disabled' : '' %>"><a class="page-link" href="?page=<%= page - 1 %>" tabindex="-1">Trước</a></li>
            <% for (let i = 1; i <= totalPages; i++) { %>
              <li class="page-item <%= page === i ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>"><%= i %></a></li>
            <% } %>
            <li class="page-item <%= page === totalPages ? 'disabled' : '' %>"><a class="page-link" href="?page=<%= page + 1 %>">Tiếp</a></li>
          </ul>
        </nav>
      </section>
    </div>
  </main>

  <%- include('../ComponentStudent/footer') %>

  <script>
    function xemChiTiet(id) { window.location.href = `/student/JobDescription/${id}`; }
    function ungTuyen() { window.location.href = "UngTuyen.html"; }
  </script>
</body>

</html>
