      border-color: #2563EB;
      color: #fff;
    }

    /* FOOTER */
    .footer {
      background: #020617;
      color: #E5E7EB;
      padding: 40px 0 22px;
      margin-top: 60px;
    }

    .footer-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 12px;
      color: #fff
    }

    .footer p,
