      border-radius: 999px;
      padding: 6px 16px;
      font-size: .9rem;
      font-weight: 500;
      color: #334155;
      margin: 0 6px 6px 0;
    }

    .nav-chips .nav-link.active {
      background: #2563EB;
      color: #fff;
    }

    /* SIDEBAR */
    .sidebar-card {
      background: #fff;
      border-radius: 18px;
      border: 1px solid #E2E8F0;
      margin-bottom: 20px;
    }

    .sidebar-card .card-header {
      border-bottom: 1px solid #E2E8F0;
      padding: 14px 18px;
      font-weight: 600;
      display: flex;
      justify-content: space-between;
    }

    .filter-label {
      font-size: 15px;
      font-weight: 600;
      margin-bottom: 8px
    }

    .filter-group {
      padding-bottom: 14px;
      margin-bottom: 14px;
      border-bottom: 1px solid #E2E8F0
    }

    .filter-group:last-child {
      border-bottom: 0;
      margin-bottom: 0;
      padding-bottom: 0
    }

    .form-check {
      font-size: .9rem;
