<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Learn2Earn – Tìm Việc Làm Nhanh Chóng & Hiệu Quả</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap"
    rel="stylesheet">

  <style>
     /* Cho phép TẤT CẢ thẻ <a> trong header hiển thị con trỏ dạng chọn */
    .header a {
      cursor: pointer;
    }
    /* Thêm cho dropdown item */
    .header .dropdown-item {
      cursor: pointer;
    }
    :root {
      --primary: #2563EB;
      --primary-soft: #EFF6FF;
      --primary-strong: #1D4ED8;
      --neutral: #64748B;
      --bg: #F8FAFC;
      --card: #FFFFFF;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: #1E293B;
      line-height: 1.6;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-family: 'Poppins', sans-serif;
      font-weight: 600
    }

    a {
      text-decoration: none
    }

    /* HEADER */
    .header {
      background: #fff;
      box-shadow: 0 2px 8px rgba(15, 23, 42, .08);
      position: sticky;
      top: 0;
      z-index: 1000
    }

    .navbar {
      padding: .7rem 0
    }

    .navbar-brand {
      display: flex;
      align-items: center
    }

    .logo-img {
      display: flex;
      align-items: center;
      justify-content: center
    }

    .brand-logo {
      height: 60px;
      width: auto;
      object-fit: contain;
      transform: scale(2.2);
      transform-origin: left center
    }

    .navbar-nav .nav-link {
      font-weight: 500;
      font-size: .95rem;
      color: #475569;
      padding: 8px 14px;
      border-radius: 999px;
    }

    .navbar-nav .nav-link:hover {
      background: var(--primary-soft);
      color: var(--primary)
    }

    .navbar-nav .nav-link.active {
      background: #DBEAFE;
      color: var(--primary-strong)
    }

    .nav-icon {
      width: 38px;
      height: 38px;
      margin: 0 6px;
      border-radius: 50%;
      background: #E2E8F0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #475569;
      font-size: 18px;
    }

    .nav-icon:hover {
      background: #CBD5E1;
      color: var(--primary)
    }

    .l2e-dropdown:hover .dropdown-menu {
      display: block
    }

    .dropdown-menu {
      border-radius: 12px;
      border: 1px solid #E5E7EB
    }

    .dropdown-item {
      font-size: .9rem
    }

    /* HERO */
    .hero-section {
      background: radial-gradient(circle at top left, #e0f2fe 0, #f8fafc 50%, #ffffff 100%);
      padding: 70px 0 45px;
    }

    .hero-title {
      font-size: 38px;
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 16px;
    }

    .hero-title span {
      background: linear-gradient(135deg, #3B82F6, #1D4ED8);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      border: 1px solid #BFDBFE;
      background: #EFF6FF;
      font-size: .85rem;
      color: var(--primary-strong);
      margin-bottom: 12px;
    }

    .hero-subtitle {
      font-size: 16px;
      color: #64748B;
      max-width: 640px;
      margin: 0 auto 24px;
    }

    .hero-stats {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 16px;
      font-size: .9rem;
      color: #475569;
    }

    .hero-stat-pill {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 14px;
      border-radius: 999px;
      background: #fff;
      border: 1px solid #E2E8F0;
    }

    .hero-stat-pill span:first-child {
      font-weight: 600;
      color: var(--primary)
    }

    /* SEARCH */
    .search-section {
      margin-top: -26px
