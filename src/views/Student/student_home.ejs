      height: 52px;
      border-radius: 14px;
      background: #EFF6FF;
      color: #2563EB;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      margin-right: 14px;
    }

    .job-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 4px
    }

    .job-company {
      font-size: .9rem;
      color: #6B7280;
      margin-bottom: 8px
    }

    .job-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 8px
    }

    .job-meta-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: .8rem;
      background: #F1F5F9;
      border-radius: 999px;
      padding: 4px 8px;
    }

    .job-salary {
