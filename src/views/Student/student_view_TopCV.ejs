<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function getInitials(name) {
    if (!name) return "";
    const parts = name.trim().split(" ");
    if (parts.length === 1) return parts[0][0]?.toUpperCase() || "";
    const last = parts[parts.length - 1][0] || "";
    const first = parts[0][0] || "";
    return (last + first).toUpperCase();
  }

  function updateDetailFromRow(tr) {
    const name     = tr.dataset.name;
    const major    = tr.dataset.majorFull;
    const position = tr.dataset.position;
    const score    = tr.dataset.score;
    const views    = tr.dataset.views;
    const tags     = tr.dataset.tags;
    const note     = tr.dataset.note;
    const cvfile   = tr.dataset.cvfile;

    document.getElementById("detailName").textContent     = name || "";
    document.getElementById("detailMajor").textContent    = major || "";
    document.getElementById("detailPosition").textContent = position || "";
    document.getElementById("detailScore").textContent    = score ? (score + "/100") : "";
    document.getElementById("detailNote").textContent     = note || "";
    document.getElementById("detailInitials").textContent = getInitials(name);
    document.getElementById("detailFile").textContent     = cvfile || "";

    const tagContainer = document.getElementById("detailTags");
    tagContainer.innerHTML = "";
    if (tags) {
      tags.split(",").forEach(t => {
        const span = document.createElement("span");
        span.className = "chip";
        span.textContent = t.trim();
        tagContainer.appendChild(span);
      });
    }

    document.getElementById("btnViewPdf").dataset.cvfile     = cvfile || "";
    document.getElementById("btnDownloadPdf").dataset.cvfile = cvfile || "";
  }

  function applyFiltersAndSort() {
    const keyword     = document.getElementById("filterKeyword").value.toLowerCase();
    const majorFilter = document.getElementById("filterMajor").value;
    const sortOption  = document.getElementById("sortOption").value;
    const tbody       = document.getElementById("topCvBody");
    const rows        = Array.from(tbody.querySelectorAll("tr"));

    // Lọc
    rows.forEach(tr => {
      const name     = tr.dataset.name.toLowerCase();
      const position = tr.dataset.position.toLowerCase();
      const major    = tr.dataset.major;

      const matchKeyword =
        !keyword ||
        name.includes(keyword) ||
        position.includes(keyword);

      const matchMajor =
        !majorFilter || major === majorFilter;

      if (matchKeyword && matchMajor) {
        tr.style.display = "";
      } else {
        tr.style.display = "none";
      }
    });

    // Sắp xếp
    const visibleRows = rows.filter(tr => tr.style.display !== "none");

    visibleRows.sort((a, b) => {
      const scoreA = parseInt(a.dataset.score || "0", 10);
      const scoreB = parseInt(b.dataset.score || "0", 10);
      const viewA  = parseInt(a.dataset.views || "0", 10);
      const viewB  = parseInt(b.dataset.views || "0", 10);
      const rankA  = parseInt(a.dataset.rank || "0", 10);
      const rankB  = parseInt(b.dataset.rank || "0", 10);

      if (sortOption === "views_desc") {
        return viewB - viewA;
      } else if (sortOption === "rank_asc") {
        return rankA - rankB;
      } else {
        return scoreB - scoreA;
      }
    });

    visibleRows.forEach(tr => tbody.appendChild(tr));
  }

  document.addEventListener("DOMContentLoaded", function () {
    const tbody = document.getElementById("topCvBody");
    const rows  = Array.from(tbody.querySelectorAll("tr"));

    // Hover: chỉ cần rê chuột là đổi chi tiết (không cần click)
    rows.forEach(tr => {
      tr.addEventListener("mouseenter", function () {
        updateDetailFromRow(tr);
      });

      const btn = tr.querySelector(".btn-view-cv");
      if (btn) {
        btn.addEventListener("click", function (e) {
          e.stopPropagation();
          updateDetailFromRow(tr);
        });
      }
    });

    document.getElementById("filterKeyword").addEventListener("input", applyFiltersAndSort);
    document.getElementById("filterMajor").addEventListener("change", applyFiltersAndSort);
    document.getElementById("sortOption").addEventListener("change", applyFiltersAndSort);

    document.getElementById("btnViewPdf").addEventListener("click", function () {
      const file = this.dataset.cvfile || "CV_khong_ro_ten.pdf";
      alert("Giả lập mở file CV: " + file + " (demo, chưa gắn link PDF thật).");
    });

    document.getElementById("btnDownloadPdf").addEventListener("click", function () {
      const file = this.dataset.cvfile || "CV_khong_ro_ten.pdf";
      alert("Giả lập tải file CV: " + file + " (demo).");
    });

    // Hiển thị mặc định dòng đầu tiên
    if (rows.length > 0) {
      updateDetailFromRow(rows[0]);
    }
  });
</script>

</body>
