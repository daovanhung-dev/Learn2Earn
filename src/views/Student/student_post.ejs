<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function applyFilter() {
    const kw   = document.getElementById("keyword").value.toLowerCase();
    const loc  = document.getElementById("location").value;
    const type = document.getElementById("jobType").value;
    const jobs = document.querySelectorAll(".job-card");

    let visibleCount = 0;

    jobs.forEach(job => {
      const title   = job.dataset.title.toLowerCase();
      const company = job.dataset.company.toLowerCase();
      const jLoc    = job.dataset.location;
      const jType   = job.dataset.type;

      const matchKw =
        !kw || title.includes(kw) || company.includes(kw);
      const matchLoc =
        !loc || jLoc === loc;
      const matchType =
        !type || jType === type;

      if (matchKw && matchLoc && matchType) {
        job.style.display = "";
        visibleCount++;
      } else {
        job.style.display = "none";
      }
    });

    document.getElementById("countVisible").textContent =
      visibleCount + " tin hiển thị";
  }

  document.addEventListener("DOMContentLoaded", function () {
    const jobs = document.querySelectorAll(".job-card");
    document.getElementById("totalJobs").textContent = jobs.length;
    document.getElementById("countVisible").textContent = jobs.length + " tin hiển thị";

    document.getElementById("keyword").addEventListener("input", applyFilter);
    document.getElementById("location").addEventListener("change", applyFilter);
    document.getElementById("jobType").addEventListener("change", applyFilter);

    document.getElementById("clearFilter").addEventListener("click", function () {
      document.getElementById("keyword").value = "";
      document.getElementById("location").value = "";
      document.getElementById("jobType").value = "";
      applyFilter();
    });

    // Cho phép click cả card (không chỉ nút) để đi tới trang ứng tuyển (demo)
    jobs.forEach(job => {
      job.addEventListener("click", function (e) {
        if (e.target.tagName.toLowerCase() === "a") return; // đã click vào nút
        window.location.href = "UngTuyen.html";
      });
    });

    // Xử lý nút Chi tiết: hiện panel chi tiết bên phải
    document.querySelectorAll(".btn-detail").forEach(btn => {
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();

        const job = btn.closest(".job-card");
        if (!job) return;

        document.getElementById("jobDetailBox").style.display = "block";
        document.getElementById("dtTitle").textContent       = job.dataset.title;
        document.getElementById("dtCompany").textContent     = job.dataset.company;
        document.getElementById("dtLocation").textContent    = job.dataset.location;
        document.getElementById("dtDeadline").textContent    = job.dataset.deadline;
        document.getElementById("dtDescription").textContent = job.dataset.desc;
      });
    });
  });
</script>

</body>
</html>
