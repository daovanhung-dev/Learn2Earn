<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Cập nhật panel chi tiết từ 1 notif-item
  function setDetailFromItem(item) {
    const title   = item.getAttribute("data-title");
    const source  = item.getAttribute("data-source");
    const time    = item.getAttribute("data-time");
    const content = item.getAttribute("data-content");
    const type    = item.getAttribute("data-type");

    document.getElementById("detailTitle").textContent   = title;
    document.getElementById("detailSource").textContent  = source;
    document.getElementById("detailTime").textContent    = time;
    document.getElementById("detailContent").textContent = content;

    const typeText = document.getElementById("detailTypeText");
    if (type === "recruit") {
      typeText.textContent = "Tuyển dụng";
      typeText.className = "badge bg-success-subtle text-success rounded-pill small";
    } else if (type === "school") {
      typeText.textContent = "Nhà trường";
      typeText.className = "badge bg-danger-subtle text-danger rounded-pill small";
    } else if (type === "system") {
      typeText.textContent = "Hệ thống";
      typeText.className = "badge bg-secondary-subtle text-secondary rounded-pill small";
    } else {
      typeText.textContent = "Khác";
      typeText.className = "badge bg-primary-subtle text-primary rounded-pill small";
    }

    // bỏ trạng thái chưa đọc ở item đang chọn
    item.classList.remove("unread");
  }

  // Áp dụng filter
  function applyFilter(filter) {
    const items = document.querySelectorAll(".notif-item");
    items.forEach(item => {
      const type = item.getAttribute("data-type");
      const isUnread = item.classList.contains("unread");

      let show = true;
      if (filter === "unread" && !isUnread) show = false;
      if (filter === "recruit" && type !== "recruit") show = false;
      if (filter === "school" && type !== "school") show = false;
      if (filter === "system" && type !== "system") show = false;

      item.style.display = show ? "" : "none";
    });
  }

  document.addEventListener("DOMContentLoaded", function () {
    const items = document.querySelectorAll(".notif-item");

    // Gắn click cho từng thông báo
    items.forEach(item => {
      item.addEventListener("click", function () {
        setDetailFromItem(item);
      });
    });

    // Set mặc định là thông báo đầu tiên (nếu có)
    if (items[0]) {
      setDetailFromItem(items[0]);
    }

    // Filter pills
    const filterButtons = document.querySelectorAll(".filter-pill");
    filterButtons.forEach(btn => {
      btn.addEventListener("click", function () {
        filterButtons.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        const f = btn.getAttribute("data-filter");
        applyFilter(f === "all" ? "" : f);
      });
    });

    // Đánh dấu tất cả đã đọc
    document.getElementById("btnMarkAllRead").addEventListener("click", function () {
      document.querySelectorAll(".notif-item").forEach(item => {
        item.classList.remove("unread");
      });
    });

    // Đánh dấu thông báo đang hiển thị chi tiết là đã đọc
    document.getElementById("btnMarkDetailRead").addEventListener("click", function () {
      const currentTitle = document.getElementById("detailTitle").textContent.trim();
      document.querySelectorAll(".notif-item").forEach(item => {
        if (item.getAttribute("data-title") === currentTitle) {
          item.classList.remove("unread");
        }
      });
    });
  });
</script>

