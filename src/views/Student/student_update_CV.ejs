    /* ================= HEADER ================= */
    .header {
      background: #ffffff;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .brand-logo {
        height: 60px;       
        width: auto;
        display: block;
        object-fit: contain;

        transform: scale(2.3);
        transform-origin: left center;
    }


    .navbar {
      min-height: 72px;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      height: 55px;                    /* LOGO TO */
      object-fit: contain;
    }

    /* ====== HOVER BO TRÒN ====== */
    .navbar-nav .nav-link {
      font-weight: 500;
      color: #475569;
      padding: 8px 14px;
      border-radius: 999px;
      transition: 0.25s;
    }

    .navbar-nav .nav-link:hover {
      background: #EFF6FF !important;
      color: #2563EB !important;
    }

    .navbar-nav .nav-link.active {
      background: #DBEAFE !important;
      color: #1D4ED8 !important;
    }

    /* ================= ICON THÔNG BÁO + CHAT ================= */
    .nav-icon {
      width: 38px;
      height: 38px;
      margin-left: 8px;
      margin-right: 8px;
      border-radius: 50%;
      background: #f1f5f9;
      display: flex;
