                  Lần cập nhật cuối: 12/11/2025
                </div>
              </div>
              <button type="button" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-eye"></i> Xem CV
              </button>
            </div>
          </div>

          <form id="cvForm" class="needs-validation" novalidate>

            <!-- Avatar -->
            <div class="text-center mb-4">
              <div class="avatar-box mx-auto" id="avatarPreview">
                <img id="previewAvatarImg" src="https://via.placeholder.com/150x150.png?text=SV" alt="">
