<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Cập nhật CV</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<% const C = (typeof cv !== 'undefined' && cv) ? cv : {}; %>
<% const avatarSrc = (typeof avatarUrl !== 'undefined' && avatarUrl) ? avatarUrl : '/public/images/default-avatar.png'; %>

<div class="container my-5">
  <div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
      <h4 class="mb-0">Cập nhật CV</h4>
    </div>

    <div class="card-body">
      <form action="/student/UpdateCV/<%= C.id %>" method="POST" enctype="multipart/form-data">

        <!-- Ảnh đại diện -->
        <div class="mb-3">
          <label class="form-label">Ảnh đại diện</label>
          <div class="mb-2">
            <img id="preview-avt" src="<%= avatarSrc %>" alt="Avatar" style="height:100px; width:100px; object-fit:cover; border-radius:8px; border:1px solid #ddd;">
          </div>
          <input type="file" name="avt" id="input-avt" class="form-control" accept="image/*">
          <small class="text-muted">Để trống nếu không đổi ảnh</small>
        </div>

        <!-- Họ tên & Ngày sinh -->
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Họ tên</label>
            <input type="text" name="hoten" class="form-control" value="<%= C.hoten || '' %>" required>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Ngày sinh</label>
            <input type="date" name="ngaysinh" class="form-control" value="<%= C.ngaysinh ? (new Date(C.ngaysinh)).toISOString().slice(0,10) : '' %>">
          </div>
        </div>

        <!-- Giới tính & Email -->
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Giới tính</label>
            <select name="gioitinh" class="form-select">
              <option value="" <%= !C.gioitinh ? "selected" : "" %>>-- Chọn --</option>
              <option value="Nam" <%= C.gioitinh === "Nam" ? "selected" : "" %>>Nam</option>
              <option value="Nữ" <%= C.gioitinh === "Nữ" ? "selected" : "" %>>Nữ</option>
              <option value="Khác" <%= C.gioitinh === "Khác" ? "selected" : "" %>>Khác</option>
            </select>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" value="<%= C.email || '' %>" required>
          </div>
        </div>

        <!-- SĐT & Địa chỉ -->
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Số điện thoại</label>
            <input type="text" name="sdt" class="form-control" value="<%= C.sdt || '' %>">
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Địa chỉ</label>
            <input type="text" name="diachi" class="form-control" value="<%= C.diachi || '' %>">
          </div>
        </div>

        <hr>

        <!-- Vị trí & Ngành -->
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Vị trí ứng tuyển</label>
            <input type="text" name="vitri" class="form-control" value="<%= C.vitri || '' %>">
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Ngành</label>
            <input type="text" name="nganh" class="form-control" value="<%= C.nganh || '' %>">
          </div>
        </div>

        <!-- Lương mong muốn -->
        <div class="mb-3">
          <label class="form-label">Lương mong muốn</label>
          <input type="text" name="luongmongmuon" class="form-control" value="<%= C.luongmongmuon || '' %>">
        </div>

        <!-- Mục tiêu nghề nghiệp -->
        <div class="mb-3">
          <label class="form-label">Mục tiêu nghề nghiệp</label>
          <textarea name="muctieunghiep" class="form-control"><%= C.muctieunghiep || '' %></textarea>
        </div>

        <!-- Học vấn, Kinh nghiệm, Kỹ năng, Ngoại ngữ -->
        <div class="mb-3">
          <label class="form-label">Học vấn</label>
          <textarea name="hocvan" class="form-control"><%= C.hocvan || '' %></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Kinh nghiệm</label>
          <textarea name="kinhnghiem" class="form-control"><%= C.kinhnghiem || '' %></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Kỹ năng</label>
          <textarea name="kynang" class="form-control"><%= C.kynang || '' %></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Ngoại ngữ</label>
          <textarea name="ngoaingu" class="form-control"><%= C.ngoaingu || '' %></textarea>
        </div>

        <!-- Chứng chỉ, Dự án, Giải thưởng, Hoạt động -->
        <div class="mb-3">
          <label class="form-label">Chứng chỉ</label>
          <textarea name="chungchi" class="form-control"><%= C.chungchi || '' %></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Dự án</label>
          <textarea name="duan" class="form-control"><%= C.duan || '' %></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Giải thưởng</label>
          <textarea name="giaithuong" class="form-control"><%= C.giaithuong || '' %></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Hoạt động</label>
          <textarea name="hoatdong" class="form-control"><%= C.hoatdong || '' %></textarea>
        </div>

        <!-- Social & Portfolio -->
        <div class="mb-3">
          <label class="form-label">Social (JSON)</label>
          <textarea name="social" class="form-control"><%= (typeof C.social === 'object' ? JSON.stringify(C.social) : (C.social || '')) %></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Portfolio</label>
          <input type="text" name="portfolio" class="form-control" value="<%= C.portfolio || '' %>">
        </div>

        <button class="btn btn-warning w-100 py-2">Cập nhật CV</button>
      </form>
    </div>
  </div>
</div>

<script>
  // preview client-side khi chọn file mới
  document.getElementById('input-avt').addEventListener('change', function(e) {
    const file = e.target.files && e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(evt) {
      document.getElementById('preview-avt').src = evt.target.result;
    };
    reader.readAsDataURL(file);
  });
</script>

</body>
</html>
