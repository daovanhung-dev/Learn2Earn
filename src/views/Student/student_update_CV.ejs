    <script>
      // chuyển trang với fade-out
      function navigateTo(url) {
        // nếu đang ở cùng trang thì không reload
        if (location.pathname === url || location.pathname.endsWith(url)) {
          return;
        }
        document.body.style.transition = 'opacity 0.25s';
        document.body.style.opacity = '0';
        setTimeout(() => { window.location.href = url; }, 220);
      }

      // tự động highlight menu theo current path (dùng data-route)
      function setActiveNavByPath() {
        const links = document.querySelectorAll('[data-route]');
        const path = location.pathname || '/';
        // mapping: nếu path là '/' thì treat as '/Student/Home'
        links.forEach(a => a.classList.remove('active'));
        // Try exact then contains
        let found = false;
        links.forEach(a => {
          const r = a.getAttribute('data-route');
          if (!r) return;
          if (path === r || path.endsWith(r) || path.includes(r)) {
            a.classList.add('active');
            found = true;
          }
        });
        if (!found) {
          // fallback: highlight Trang chủ if on base / or not matched
          const home = document.querySelector('[data-route="/Student/Home"]');
          if (home) home.classList.add('active');
        }
      }

      // close dropdown on small screens when collapsed by bootstrap automatically,
      // but ensure hover dropdown doesn't permanently display after window resize
      function resetDropdownsOnResize() {
        document.querySelectorAll('.dropdown-menu').forEach(dm => {
          if (window.innerWidth <= 992) {
            dm.style.display = '';
          }
        });
      }

      document.addEventListener('DOMContentLoaded', () => {
        setActiveNavByPath();
        window.addEventListener('popstate', setActiveNavByPath);
        window.addEventListener('resize', resetDropdownsOnResize);
      });
    </script>
  </header>

<!-- ================= END HEADER ================= -->
<div class="container py-4">

  <h3 class="fw-bold text-primary mb-4">
