<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
  // Xem avatar mới
  document.getElementById("avatarInput").addEventListener("change", (event) => {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (e) => {
      document.getElementById("previewAvatarImg").src = e.target.result;
      document.getElementById("previewAvatarRight").src = e.target.result;
    };
    reader.readAsDataURL(file);
  });

  function updatePreview() {
    pName.textContent = name.value;
    pPosition.textContent = position.value;
    pEmail.textContent = email.value;
    pPhone.textContent = phone.value;
    pEducation.textContent = education.value;
    pExperience.textContent = experience.value;
    pSkills.textContent = skills.value;
    pProjects.textContent = projects.value;
  }

  btnPreview.onclick = updatePreview;

  window.onload = updatePreview;
</script>

