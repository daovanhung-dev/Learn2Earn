            </div>

            <!-- Thông tin cá nhân -->
            <h5 class="fw-bold text-secondary">Thông tin cá nhân</h5>

            <div class="row">
              <div class="col-6 mb-3">
                <label class="form-label">Họ tên *</label>
                <input type="text" class="form-control" id="name" required value="Nguyễn Văn A">
              </div>

              <div class="col-6 mb-3">
                <label class="form-label">Vị trí mong muốn *</label>
                <input type="text" class="form-control" id="position" required value="Thực tập sinh Java">
              </div>

              <div class="col-6 mb-3">
                <label class="form-label">Email *</label>
                <input type="email" class="form-control" id="email" required value="sv001@sv.vnua.edu.vn">
              </div>

              <div class="col-6 mb-3">
                <label class="form-label">Số điện thoại *</label>
                <input
                  type="text"
                  class="form-control"
                  id="phone"
                  required
                  pattern="^[0-9]{9,11}$"
                  value="0987654321"
                >
              </div>
            </div>

            <!-- Học vấn -->
            <h5 class="fw-bold text-secondary mt-4">Học vấn *</h5>
            <div class="mb-3">
<textarea class="form-control" id="education" rows="2" required>- Đại học Nông nghiệp Việt Nam (VNUA)
- Ngành: Công nghệ thông tin · GPA: 3.2/4.0</textarea>
            </div>

            <!-- Kinh nghiệm -->
            <h5 class="fw-bold text-secondary mt-4">Kinh nghiệm</h5>
<textarea class="form-control" id="experience" rows="3">- Thực tập sinh Java tại ABC Software (06/2025 - 08/2025)
  + Tham gia phát triển module CRUD cho hệ thống quản lý sinh viên
  + Viết API đơn giản với Spring Boot, làm việc với MySQL</textarea>

            <!-- Kỹ năng -->
            <h5 class="fw-bold text-secondary mt-4">Kỹ năng</h5>
<textarea class="form-control" id="skills" rows="3">- Ngôn ngữ: Java, Dart, JavaScript
- Backend: Spring Boot (cơ bản)
- Mobile: Flutter
- Cơ sở dữ liệu: MySQL, PostgreSQL
- Khác: Git, Figma, làm việc nhóm</textarea>

            <!-- Dự án -->
            <h5 class="fw-bold text-secondary mt-4">Dự án cá nhân</h5>
<textarea class="form-control" id="projects" rows="3">- Learn2Earn: Nền tảng kết nối sinh viên – doanh nghiệp
  + Vai trò: Backend, thiết kế CSDL
  + Công nghệ: Java, Spring Boot, PostgreSQL

- Todo App: Ứng dụng quản lý công việc cá nhân
  + Công nghệ: Flutter, SQLite</textarea>

            <!-- File PDF -->
            <h5 class="fw-bold text-secondary mt-4">Cập nhật file CV PDF</h5>
            <input type="file" class="form-control" accept="application/pdf" id="pdfFile">

            <div class="form-check mt-3">
              <input class="form-check-input" type="checkbox" id="setDefault" checked>
              <label class="form-check-label">Đặt CV này làm CV chính</label>
            </div>

            <button class="btn btn-primary w-100 mt-3" type="submit">
              <i class="bi bi-save"></i> Lưu và cập nhật CV
            </button>

            <button class="btn btn-outline-secondary w-100 mt-2" type="button" id="btnPreview">
              <i class="bi bi-eye"></i> Xem preview CV
            </button>

