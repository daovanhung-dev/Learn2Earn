<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>Cài đặt - Learn2Earn</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- ICONS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --primary:#2563eb;
      --muted:#6b7280;
      --soft-bg:#f3f6fb;
      --card:#fff;
      --glass: rgba(255,255,255,0.65);
      --radius:14px;
    }

    body{
      font-family:'Inter',system-ui,Arial;
      background: linear-gradient(180deg, var(--soft-bg) 0%, #ffffff 100%);
      color: #0f172a;
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
      margin:0;
      padding:0;
    }

    /* ---------- HEADER ---------- */
    .header{
      position:sticky;
      top:0;
      z-index:1100;
      background:var(--card);
      box-shadow:0 6px 20px rgba(15,23,42,0.06);
      border-bottom:1px solid rgba(0,0,0,0.03);
    }
    .navbar{
      min-height:72px;
      padding:0.6rem 0;
    }
    .brand-logo{
      height:44px;
      object-fit:contain;
      transition:transform .18s ease;
    }
    .brand-box{ display:flex; align-items:center; gap:.6rem; }
    .brand-title{ font-weight:700; color:var(--primary); font-size:1.05rem; letter-spacing:.2px; }

    .nav-pill{
      border-radius:999px;
      padding:6px 14px;
      font-weight:500;
      color:var(--muted);
      transition: all .18s;
    }
    .nav-pill:hover{ background: rgba(37,99,235,0.06); color:var(--primary); text-decoration:none; }
    .nav-pill.active{ background: rgba(37,99,235,0.12); color:var(--primary); }

    .nav-icon{
      width:40px; height:40px; border-radius:10px;
      display:inline-flex; align-items:center; justify-content:center;
      background:#f7fafc; color:var(--muted); border:1px solid rgba(15,23,42,0.03);
      margin-left:.45rem;
    }
    .nav-icon:hover{ transform:translateY(-2px); box-shadow:0 6px 18px rgba(15,23,42,0.06); cursor:pointer; }

    /* logout bar (ngoài header) */
    .logout-bar{
      background: linear-gradient(90deg, rgba(37,99,235,0.03), rgba(37,99,235,0.01));
      border-bottom:1px solid rgba(15,23,42,0.03);
      padding:10px 0;
    }
    .logout-btn{
      border-radius:12px;
      padding:.45rem .9rem;
    }

    /* ---------- LAYOUT ---------- */
    .container-main{ padding:28px 16px; max-width:1100px; margin:0 auto; }

    .card-soft{
      background:var(--card);
      border-radius:var(--radius);
      box-shadow:0 8px 22px rgba(15,23,42,0.06);
      border:0;
    }

    .section-title{
      font-weight:700; font-size:1rem; display:flex; gap:10px; align-items:center;
      margin-bottom:12px; color:var(--primary);
    }
    .small-muted{ color:var(--muted); font-size:.92rem; }

    /* avatar */
    .avatar-box img{
      width:80px; height:80px; object-fit:cover; border-radius:12px;
      border:3px solid rgba(37,99,235,0.06);
    }

    /* inputs */
    .form-control, .form-select{
      border-radius:10px;
      box-shadow:none;
      border:1px solid rgba(15,23,42,0.08);
    }

    /* danger zone */
    .danger-zone{
      border-radius:12px; background:linear-gradient(180deg,#fff,#fff);
      padding:14px; border:1px solid rgba(220,38,38,0.08);
    }
    .danger-zone .btn-danger{ border-radius:10px; }

    /* footer */
    .footer{ background:#0f172a; color:#e6eefb; padding:42px 0; margin-top:44px; }
    .footer a{ color:#94a3b8; text-decoration:none; }
    .footer a:hover{ color:#fff; text-decoration:none; }

    /* responsive tweaks */
    @media (max-width:992px){
      .brand-title{ display:none; }
      .brand-logo{ transform:scale(1); }
      .container-main{ padding:18px 12px; }
      .avatar-box img{ width:64px; height:64px; }
    }
  </style>
</head>
<body>

  <!-- ========== HEADER ========== -->
  <header class="header">
    <nav class="navbar navbar-expand-lg">
      <div class="container">

        <div class="d-flex align-items-center brand-box">
          <a class="d-flex align-items-center text-decoration-none" role="button" onclick="navigateTo('/Student/Home')">
            <img src="/img/logo-nobr.png" alt="Learn2Earn" class="brand-logo">
            <span class="brand-title ms-1">Learn2Earn</span>
          </a>
        </div>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMain">
          <ul class="navbar-nav mx-auto mb-2 mb-lg-0 align-items-center">
            <li class="nav-item px-1"><a class="nav-link nav-pill" data-route="/Student/Home" onclick="navigateTo('/Student/Home')">Trang chủ</a></li>
            <li class="nav-item px-1"><a class="nav-link nav-pill" data-route="/Student/Profile" onclick="navigateTo('/Student/Profile')">Hồ sơ</a></li>

            <li class="nav-item dropdown px-1 l2e-dropdown">
              <a class="nav-link nav-pill dropdown-toggle" href="#" id="cvMenu" role="button">CV</a>
              <ul class="dropdown-menu shadow-sm">
                <li><a class="dropdown-item" onclick="navigateTo('/Student/CreateCV')">Tạo CV</a></li>
                <li><a class="dropdown-item" onclick="navigateTo('/Student/UpdateCV')">Cập nhật CV</a></li>
                <li><a class="dropdown-item" onclick="navigateTo('/Student/TopCV')">TopCV</a></li>
              </ul>
            </li>

            <li class="nav-item px-1"><a class="nav-link nav-pill" data-route="/Student/Interview" onclick="navigateTo('/Student/Interview')">Lịch phỏng vấn</a></li>
            <li class="nav-item px-1"><a class="nav-link nav-pill" data-route="/Student/PostJobs" onclick="navigateTo('/Student/PostJobs')">Tin tuyển dụng</a></li>
          </ul>

          <div class="d-flex align-items-center ms-auto">
            <div class="me-2 text-end d-none d-md-block small-muted" style="font-size:.92rem;">
              <div>Xin chào, <span class="fw-semibold">Nguyễn Văn A</span></div>
              <div class="small-muted">Sinh viên • Hà Nội</div>
            </div>

            <div class="d-flex align-items-center">
              <div class="nav-icon" title="Thông báo" onclick="navigateTo('/Student/Noti')"><i class="bi bi-bell"></i></div>
              <div class="nav-icon" title="Tin nhắn" onclick="navigateTo('/Student/Chat')"><i class="bi bi-chat-dots"></i></div>

              <!-- small avatar dropdown -->
              <div class="ms-2 dropdown">
                <a class="d-flex align-items-center" role="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                  <img src="https://via.placeholder.com/80x80.png?text=SV" alt="avatar" style="width:42px;height:42px;border-radius:10px;object-fit:cover;border:1px solid rgba(15,23,42,0.04)">
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                  <li><a class="dropdown-item" onclick="navigateTo('/Student/Profile')"><i class="bi bi-person me-2"></i> Hồ sơ</a></li>
                  <li><a class="dropdown-item" onclick="navigateTo('/Student/Setting')"><i class="bi bi-gear me-2"></i> Cài đặt</a></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><a class="dropdown-item text-danger" onclick="logoutUser()"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                </ul>
              </div>

            </div>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <!-- Logout bar (bên ngoài header) - hiển thị gọn, có thể ẩn bằng CSS nếu không cần) -->
  <div class="logout-bar">
    <div class="container d-flex justify-content-end">
      <button class="btn btn-outline-danger logout-btn" onclick="window.location.href='Logout'"><i class="bi bi-box-arrow-right me-1"></i> Đăng xuất</button>
    </div>
  </div>

  <!-- ========== MAIN CONTENT ========== -->
  <main class="container-main">
    <div class="card card-soft mb-4 p-3">
      <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
          <h4 class="mb-1 fw-bold">Cài đặt tài khoản</h4>
          <div class="small-muted">Quản lý thông tin cá nhân, bảo mật, thông báo và quyền riêng tư của bạn trên Learn2Earn.</div>
        </div>
        <div class="text-end">
          <i class="bi bi-person-check text-success me-1"></i>
          <div class="small-muted">Trạng thái: <span class="fw-semibold text-success">Đang hoạt động</span></div>
        </div>
      </div>
    </div>

    <div class="row g-4">

      <!-- LEFT -->
      <div class="col-lg-6">
        <div class="card card-soft p-3 mb-3">
          <div class="section-title"><i class="bi bi-person-circle"></i> Thông tin tài khoản</div>

          <div class="d-flex align-items-center gap-3 mb-3">
            <div class="avatar-box">
              <img src="https://via.placeholder.com/150x150.png?text=SV" id="avatarPreview" alt="avatar">
            </div>
            <div class="flex-grow-1">
              <label class="form-label small mb-1">Ảnh đại diện</label>
              <input type="file" class="form-control form-control-sm" id="avatarInput" accept="image/*">
              <div class="small-muted mt-1">Chọn ảnh vuông, rõ mặt để nhà tuyển dụng dễ nhận diện bạn.</div>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Họ tên</label>
            <input type="text" class="form-control" id="accName" value="Nguyễn Văn A">
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Email</label>
            <input type="email" class="form-control" id="accEmail" value="sv001@sv.vnua.edu.vn">
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Số điện thoại</label>
            <input type="text" class="form-control" id="accPhone" value="0987654321">
          </div>

          <div class="d-grid">
            <button class="btn btn-primary" type="button" id="saveAccountBtn"><i class="bi bi-save me-1"></i> Lưu thay đổi</button>
          </div>
        </div>

        <div class="card card-soft p-3 mb-3">
          <div class="section-title"><i class="bi bi-bell"></i> Cài đặt thông báo</div>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="notifyRecruit" checked>
            <label class="form-check-label">Thông báo từ doanh nghiệp</label>
          </div>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="notifySystem" checked>
            <label class="form-check-label">Thông báo hệ thống</label>
          </div>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="notifyEmail">
            <label class="form-check-label">Thông báo qua email</label>
          </div>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="notifyWeb" checked>
            <label class="form-check-label">Thông báo trên website</label>
          </div>

        </div>
      </div>

      <!-- RIGHT -->
      <div class="col-lg-6">
        <div class="card card-soft p-3 mb-3">
          <div class="section-title"><i class="bi bi-shield-lock"></i> Bảo mật</div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Mật khẩu hiện tại</label>
            <input type="password" class="form-control" id="oldPass" placeholder="Nhập mật khẩu hiện tại">
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Mật khẩu mới</label>
            <input type="password" class="form-control" id="newPass" placeholder="Mật khẩu mới (tối thiểu 8 ký tự)">
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Nhập lại mật khẩu</label>
            <input type="password" class="form-control" id="rePass" placeholder="Nhập lại mật khẩu mới">
          </div>

          <div class="d-grid">
            <button class="btn btn-primary mb-2" type="button" id="btnChangePass"><i class="bi bi-key me-1"></i> Đổi mật khẩu</button>
          </div>
        </div>

        <div class="card card-soft p-3 mb-3">
          <div class="section-title"><i class="bi bi-eye"></i> Quyền riêng tư</div>

          <label class="form-label fw-semibold">Ai có thể xem CV</label>
          <select class="form-select mb-3">
            <option>Mọi doanh nghiệp</option>
            <option>Doanh nghiệp tôi ứng tuyển</option>
            <option>Chỉ mình tôi</option>
          </select>

          <label class="form-label fw-semibold">Ai có thể xem liên hệ</label>
          <select class="form-select mb-3">
            <option>Mọi doanh nghiệp</option>
            <option>Chỉ doanh nghiệp tôi cho phép</option>
            <option>Không ai</option>
          </select>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" checked>
            <label class="form-check-label">Cho phép doanh nghiệp xem hồ sơ</label>
          </div>
        </div>

        <div class="danger-zone mt-2 p-3">
          <div class="fw-semibold mb-1">⚠ Khu vực nguy hiểm</div>
          <p class="small mb-2">Xoá tài khoản là hành động vĩnh viễn. Vui lòng cân nhắc kỹ trước khi thực hiện.</p>
          <div class="d-flex gap-2">
            <button class="btn btn-outline-danger btn-sm">Yêu cầu xoá</button>
            <button class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i> Xoá tài khoản</button>
          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- ========== FOOTER ========== -->
  <footer class="footer mt-4">
    <div class="container">
      <div class="row">
        <div class="col-lg-4 mb-3">
          <h5 class="text-white fw-bold">Learn2Earn</h5>
          <div class="small-muted" style="color:#a4b0c6">Nền tảng tuyển dụng và tìm việc làm tại Việt Nam.</div>
        </div>
        <div class="col-lg-2 col-md-4 mb-3">
          <h6 class="text-white">Về chúng tôi</h6>
          <ul class="list-unstyled">
            <li><a href="#">Giới thiệu</a></li>
            <li><a href="#">Tin tức</a></li>
            <li><a href="#">Tuyển dụng</a></li>
            <li><a href="#">Liên hệ</a></li>
          </ul>
        </div>
        <div class="col-lg-2 col-md-4 mb-3">
          <h6 class="text-white">Ứng viên</h6>
          <ul class="list-unstyled">
            <li><a href="#">Tìm việc</a></li>
            <li><a href="#">Tạo CV</a></li>
            <li><a href="#">Hướng dẫn</a></li>
            <li><a href="#">Blog</a></li>
          </ul>
        </div>
        <div class="col-lg-2 col-md-4 mb-3">
          <h6 class="text-white">Nhà tuyển dụng</h6>
          <ul class="list-unstyled">
            <li><a href="#">Đăng tin</a></li>
            <li><a href="#">Tìm ứng viên</a></li>
            <li><a href="#">Gói dịch vụ</a></li>
            <li><a href="#">Hỗ trợ</a></li>
          </ul>
        </div>
        <div class="col-lg-2 col-md-4 mb-3">
          <h6 class="text-white">Liên hệ</h6>
          <ul class="list-unstyled">
            <li class="small"><i class="fas fa-phone me-2"></i>+84 123 456 789</li>
            <li class="small"><i class="fas fa-envelope me-2"></i>info@learn2earn.vn</li>
            <li class="small"><i class="fas fa-map-marker-alt me-2"></i>Hà Nội, Việt Nam</li>
          </ul>
        </div>
      </div>

      <div class="text-center mt-3" style="color:#94a3b8; font-size:.9rem;">
        © <span id="year"></span> Learn2Earn. Tất cả quyền được bảo lưu.
      </div>
    </div>
  </footer>

  <!-- JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Navigate with fade
    function navigateTo(url){
      if(location.pathname === url || location.pathname.endsWith(url)) return;
      document.body.style.transition = 'opacity .2s';
      document.body.style.opacity = '0';
      setTimeout(()=> location.href = url, 220);
    }

    // Logout (clear cookies + notify backend)
    function logoutUser(){
      // clear common cookies
      document.cookie = "access_token=; path=/; max-age=0;";
      document.cookie = "refresh_token=; path=/; max-age=0;";
      // optional backend call
      fetch('/auth/logout', { method:'POST', credentials:'include' }).catch(()=>{});
      navigateTo('/Login');
    }

    // active links by data-route
    function setActiveNavByPath(){
      document.querySelectorAll('[data-route]').forEach(a => a.classList.remove('active'));
      const path = location.pathname || '/';
      let matched = false;
      document.querySelectorAll('[data-route]').forEach(a=>{
        const r = a.getAttribute('data-route');
        if(!r) return;
        if(path === r || path.endsWith(r) || path.includes(r)){
          a.classList.add('active');
          matched = true;
        }
      });
      if(!matched){
        const home = document.querySelector('[data-route="/Student/Home"]');
        if(home) home.classList.add('active');
      }
    }

    // avatar preview
    document.addEventListener('DOMContentLoaded', ()=>{
      setActiveNavByPath();
      const avatarInput = document.getElementById('avatarInput');
      if(avatarInput){
        avatarInput.addEventListener('change', (e)=>{
          const file = e.target.files && e.target.files[0];
          if(!file) return;
          const reader = new FileReader();
          reader.onload = ev => document.getElementById('avatarPreview').src = ev.target.result;
          reader.readAsDataURL(file);
        });
      }

      // current year
      document.getElementById('year').textContent = new Date().getFullYear();
    });
  </script>

</body>
</html>
