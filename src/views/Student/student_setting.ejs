  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    body {
  background: #f3f6fb;
  font-size: 0.95rem;
  font-family: 'Inter', sans-serif;
}

.card-soft {
  border-radius: 16px;
  border: 0;
  box-shadow: 0 4px 12px rgba(15,23,42,0.08);
  background: #ffffff;
}

.section-title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-title i { color: #1e6ee9; }

/* ================= HEADER ================= */
.header {
  background: #ffffff;
  box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
  position: sticky;
  top: 0;
  z-index: 1000;
}

.brand-logo {
        height: 60px;       
        width: auto;
        display: block;
        object-fit: contain;

        transform: scale(2.3);
        transform-origin: left center;
    }


.navbar {
  min-height: 72px;
  display: flex;
  align-items: center;
}

.navbar-brand img {
  height: 55px;               /* LOGO TO HƠN */
  object-fit: contain;
}

/* ====== HOVER BO TRÒN (KHÔI PHỤC ĐẸP NHẤT) ====== */
.navbar-nav .nav-link {
  font-weight: 500;
  color: #475569;
  padding: 8px 14px;
  border-radius: 999px;
  transition: 0.25s;
}

.navbar-nav .nav-link:hover {
  background: #EFF6FF !important;
  color: #2563EB !important;
}

.navbar-nav .nav-link.active {
  background: #DBEAFE !important;
  color: #1D4ED8 !important;
}

/* ================= ICON THÔNG BÁO + CHAT ================= */
.nav-icon {
  width: 38px;
  height: 38px;
  margin-left: 8px;
  margin-right: 8px;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  font-size: 18px;
  transition: 0.25s;
}

.nav-icon:hover {
  background: #e2e8f0;
  color: #2563EB;
}

/* ================= DROPDOWN CV ================= */
.l2e-dropdown:hover .dropdown-menu {
  display: block;
}

.dropdown-menu {
  display: none;
  border-radius: 12px;
  box-shadow: 0 8px 22px rgba(0,0,0,0.1);
  border: 1px solid #e5e7eb;
  padding: 6px 0;
}

.dropdown-item {
  padding: 10px 18px;
  font-weight: 500;
  border-radius: 8px;
  transition: 0.25s;
}

.dropdown-item:hover {
  background: #EFF6FF;
  color: #2563EB;
}

/* ================= FOOTER ================= */
.footer {
  background: #0F172A;
  color: white;
  padding: 56px 0 26px;
  margin-top: 70px;
}

.footer-title { font-size: 17px; font-weight: 600; margin-bottom: 18px; }
.footer-links { list-style: none; padding: 0; }
.footer-links a { color: #94A3B8; text-decoration: none; }
.footer-links a:hover { color: white; }
.footer-bottom {
  border-top: 1px solid #1E293B;
  padding-top: 18px;
  margin-top: 32px;
  text-align: center;
  color: #94A3B8;
  font-size: 0.85rem;
}
  </style>
