<!-- ================= CONTENT ================= -->
<div class="container py-4">

  <div class="card card-soft mb-4">
    <div class="card-body d-flex flex-wrap justify-content-between align-items-center">
      <div>
        <h4 class="fw-bold text-primary mb-1">Cài đặt tài khoản</h4>
        <div class="small-muted">Quản lý thông tin cá nhân, bảo mật, thông báo và quyền riêng tư của bạn trên Learn2Earn.</div>
      </div>
      <div class="mt-3 mt-md-0 small-muted">
        <i class="bi bi-person-check me-1 text-success"></i>
        Trạng thái tài khoản: <span class="fw-semibold text-success">Đang hoạt động</span>
      </div>
    </div>
  </div>

  <div class="row g-4">

    <!-- ======== CỘT TRÁI ======== -->
    <div class="col-lg-6">
      <div class="card card-soft mb-3">
        <div class="card-body">
          <div class="section-title"><i class="bi bi-person-circle"></i> Thông tin tài khoản</div>

          <div class="d-flex align-items-center mb-3">
            <div class="avatar-box me-3">
              <img src="https://via.placeholder.com/150x150.png?text=SV" id="avatarPreview">
            </div>
            <div>
              <label class="form-label small mb-1">Ảnh đại diện</label>
              <input type="file" class="form-control form-control-sm" id="avatarInput">
              <div class="small-muted mt-1">Chọn ảnh vuông, rõ mặt để nhà tuyển dụng dễ nhận diện bạn.</div>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Họ tên</label>
            <input type="text" class="form-control" id="accName" value="Nguyễn Văn A">
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Email</label>
            <input type="email" class="form-control" id="accEmail" value="sv001@sv.vnua.edu.vn">
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Số điện thoại</label>
            <input type="text" class="form-control" id="accPhone" value="0987654321">
          </div>

          <button class="btn btn-primary w-100" type="button" id="saveAccountBtn">
            <i class="bi bi-save"></i> Lưu thay đổi
          </button>
        </div>
      </div>

      <!-- Cài đặt thông báo -->
      <div class="card card-soft mb-3">
        <div class="card-body">
          <div class="section-title"><i class="bi bi-bell"></i> Cài đặt thông báo</div>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="notifyRecruit" checked>
            <label class="form-check-label">Thông báo từ doanh nghiệp</label>
          </div>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="notifySystem" checked>
            <label class="form-check-label">Thông báo hệ thống</label>
          </div>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="notifyEmail">
            <label class="form-check-label">Thông báo qua email</label>
          </div>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="notifyWeb" checked>
            <label class="form-check-label">Thông báo trên website</label>
          </div>

        </div>
      </div>
    </div>

    <!-- ======== CỘT PHẢI ======== -->
    <div class="col-lg-6">

      <div class="card card-soft mb-3">
        <div class="card-body">

          <div class="section-title"><i class="bi bi-shield-lock"></i> Bảo mật</div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Mật khẩu hiện tại</label>
            <input type="password" class="form-control" id="oldPass">
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Mật khẩu mới</label>
            <input type="password" class="form-control" id="newPass">
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Nhập lại mật khẩu</label>
            <input type="password" class="form-control" id="rePass">
          </div>

          <button class="btn btn-primary w-100 mb-3" type="button" id="btnChangePass">
            <i class="bi bi-key"></i> Đổi mật khẩu
          </button>

        </div>
      </div>

      <!-- Quyền riêng tư -->
      <div class="card card-soft mb-3">
        <div class="card-body">
          <div class="section-title"><i class="bi bi-eye"></i> Quyền riêng tư</div>

          <label class="form-label fw-semibold">Ai có thể xem CV</label>
          <select class="form-select mb-3">
            <option>Mọi doanh nghiệp</option>
            <option>Doanh nghiệp tôi ứng tuyển</option>
            <option>Chỉ mình tôi</option>
          </select>

          <label class="form-label fw-semibold">Ai có thể xem liên hệ</label>
          <select class="form-select mb-3">
            <option>Mọi doanh nghiệp</option>
            <option>Chỉ doanh nghiệp tôi cho phép</option>
            <option>Không ai</option>
          </select>

          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" checked>
            <label class="form-check-label">Cho phép doanh nghiệp xem hồ sơ</label>
          </div>
        </div>
      </div>

      <!-- Danger Zone -->
      <div class="danger-zone">
        <div class="fw-semibold mb-2">⚠ Khu vực nguy hiểm</div>
        <p class="small mb-2">Xoá tài khoản là hành động vĩnh viễn.</p>
        <button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i> Xoá tài khoản</button>
      </div>

    </div>
  </div>
</div>

<!-- ================= FOOTER ================= -->
<footer class="footer">
  <div class="container position-relative">
    <div class="row">
      <div class="col-lg-4 mb-4">
        <h4 class="footer-title">Learn2Earn</h4>
        <p>Nền tảng tuyển dụng và tìm việc làm tại Việt Nam.</p>
      </div>

      <div class="col-lg-2 col-md-4 mb-4">
        <h4 class="footer-title">Về chúng tôi</h4>
        <ul class="footer-links">
          <li><a href="#">Giới thiệu</a></li>
          <li><a href="#">Tin tức</a></li>
          <li><a href="#">Tuyển dụng</a></li>
          <li><a href="#">Liên hệ</a></li>
        </ul>
      </div>

      <div class="col-lg-2 col-md-4 mb-4">
        <h4 class="footer-title">Ứng viên</h4>
        <ul class="footer-links">
          <li><a href="#">Tìm việc</a></li>
          <li><a href="#">Tạo CV</a></li>
          <li><a href="#">Hướng dẫn</a></li>
          <li><a href="#">Blog</a></li>
        </ul>
      </div>

      <div class="col-lg-2 col-md-4 mb-4">
        <h4 class="footer-title">Nhà tuyển dụng</h4>
        <ul class="footer-links">
          <li><a href="#">Đăng tin</a></li>
          <li><a href="#">Tìm ứng viên</a></li>
          <li><a href="#">Gói dịch vụ</a></li>
          <li><a href="#">Hỗ trợ</a></li>
        </ul>
      </div>

      <div class="col-lg-2 col-md-4 mb-4">
        <h4 class="footer-title">Liên hệ</h4>
        <ul class="footer-links">
          <li><a><i class="fas fa-phone me-2"></i>+84 123 456 789</a></li>
          <li><a><i class="fas fa-envelope me-2"></i>info@learn2earn.vn</a></li>
          <li><a><i class="fas fa-map-marker-alt me-2"></i>Hà Nội, Việt Nam</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      © 2023 Learn2Earn. Tất cả quyền được bảo lưu.
    </div>
  </div>
</footer>

<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
  document.getElementById("avatarInput").addEventListener("change", (e)=>{
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = e2 => document.getElementById("avatarPreview").src = e2.target.result;
    reader.readAsDataURL(file);
  });
</script>

</body>
</html>
