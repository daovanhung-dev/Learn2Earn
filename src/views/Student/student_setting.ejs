          </li>

          <li class="nav-item">
            <a class="nav-link" href="TinTuyenDung.html">Tin tuyển dụng</a>
          </li>

        </ul>

        <!-- ===== ICON THÔNG BÁO & CHAT BÊN PHẢI ===== -->
        <ul class="navbar-nav ms-auto d-flex align-items-center">

          <!-- Bell -->
          <li class="nav-item">
            <a class="nav-icon" href="ThongBao.html">
              <i class="bi bi-bell"></i>
            </a>
          </li>

