<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Admin – Cài đặt & Phân quyền</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Fonts & Libs -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet">

  <style>
    :root{
      --primary:#0f766e;
      --primary-soft:#ecfdf5;
      --bg:#020617;
      --bg-soft:#02081f;
      --border:#1e293b;
      --text:#e5e7eb;
      --muted:#9ca3af;
      --danger:#ef4444;
      --info:#38bdf8;
      --warning:#facc15;
      --success:#22c55e;
    }

    *{box-sizing:border-box;}
    body{
      margin:0;
      font-family:'Inter',system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
      background:radial-gradient(circle at top,#0f172a 0,#020617 50%,#000 100%);
      color:var(--text);
    }
    a{text-decoration:none;color:inherit;}

    .layout{
      display:flex;
      min-height:100vh;
    }

    /* ===== SIDEBAR ===== */
    .sidebar{
      width:260px;
      background:linear-gradient(180deg,#020617,#02081f);
      border-right:1px solid var(--border);
      padding:1.2rem 1rem;
      display:flex;
      flex-direction:column;
      position:sticky;
      top:0;
      height:100vh;
    }
    .brand-box{
      display:flex;
      align-items:center;
      gap:.7rem;
      margin-bottom:1.5rem;
      padding:.45rem .5rem .6rem;
      border-radius:1rem;
      background:linear-gradient(135deg,#0f766e33,#38bdf833);
      border:1px solid rgba(148,163,184,.4);
    }
    .brand-logo{
      width:44px;
      height:44px;
      border-radius:.9rem;
      background:#fff;
      overflow:hidden;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .brand-logo img{
      width:100%;
      height:auto;
      object-fit:contain;
    }
    .brand-title{
      font-weight:700;
      font-size:.95rem;
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .brand-sub{
      font-size:.75rem;
      color:var(--muted);
    }

    .sidebar-section-title{
      font-size:.72rem;
      text-transform:uppercase;
      letter-spacing:.14em;
      color:var(--muted);
      margin:.5rem 0 .3rem;
      padding:0 .2rem;
    }
    .nav-main{
      list-style:none;
      padding:0;
      margin:0;
      flex:1;
    }
    .nav-item + .nav-item{margin-top:.15rem;}
    .nav-link{
      display:flex;
      align-items:center;
      gap:.6rem;
      padding:.55rem .65rem;
      border-radius:.9rem;
      font-size:.88rem;
      color:#e5e7eb;
      border:1px solid transparent;
      cursor:pointer;
      transition:all .18s ease;
    }
    .nav-link i{
      width:22px;
      text-align:center;
      font-size:1.1rem;
    }
    .nav-link small{
      display:block;
      font-size:.7rem;
      color:var(--muted);
    }
    .nav-link.active{
      background:linear-gradient(135deg,#0f766e,#0d9488);
      border-color:rgba(34,197,94,.5);
      box-shadow:0 14px 30px rgba(15,118,110,.45);
    }
    .nav-link:hover:not(.active){
      background:#0b1120;
      border-color:rgba(148,163,184,.6);
    }

    .sidebar-bottom{
      margin-top:1rem;
      padding-top:1rem;
      border-top:1px dashed var(--border);
      font-size:.8rem;
      color:var(--muted);
    }
    .sidebar-status{
      display:inline-flex;
      align-items:center;
      gap:.25rem;
      border-radius:999px;
      background:rgba(34,197,94,.12);
      color:#4ade80;
      padding:.15rem .6rem;
      font-size:.7rem;
      margin-bottom:.4rem;
    }
    .sidebar-status i{font-size:.8rem;}

    /* ===== MAIN AREA ===== */
    .main{
      flex:1;
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    /* TOPBAR */
    .topbar{
      padding:.75rem 1.5rem;
      display:flex;
      align-items:center;
      gap:1rem;
      border-bottom:1px solid var(--border);
      background:rgba(15,23,42,.96);
      backdrop-filter:blur(24px);
      position:sticky;
      top:0;
      z-index:10;
    }
    .topbar-title{
      font-size:1.05rem;
      font-weight:600;
    }
    .topbar-sub{
      font-size:.8rem;
      color:var(--muted);
    }
    .topbar-search{
      margin-left:auto;
      display:flex;
      align-items:center;
      gap:.75rem;
    }
    .topbar-btn{
      font-size:.8rem;
      border-radius:999px;
      padding:.35rem .9rem;
      display:inline-flex;
      align-items:center;
      gap:.3rem;
    }
    .topbar-btn i{font-size:1rem;}

    /* PAGE CONTENT */
    .page{
      padding:1.5rem 1.5rem 0;
    }

    .section-header{
      display:flex;
      justify-content:space-between;
      align-items:flex-end;
      margin-bottom:1rem;
    }
    .section-title{
      font-size:1rem;
      font-weight:600;
    }
    .section-sub{
      font-size:.8rem;
      color:var(--muted);
    }

    .card-glass{
      background:linear-gradient(160deg,#020617dd,#02081fe6);
      border-radius:1rem;
      border:1px solid var(--border);
      padding:1rem 1.1rem;
      box-shadow:0 18px 40px rgba(15,23,42,.7);
    }

    .setting-label{
      font-size:.85rem;
      font-weight:500;
      margin-bottom:.1rem;
    }
    .setting-desc{
      font-size:.78rem;
      color:var(--muted);
      margin-bottom:.3rem;
    }

    .form-control,
    .form-select{
      background:#020617;
      border-color:var(--border);
      color:var(--text);
      font-size:.85rem;
    }
    .form-control::placeholder{
      color:#64748b;
    }

    .form-check-label{
      font-size:.83rem;
    }

    .badge-role{
      padding:.15rem .55rem;
      border-radius:999px;
      font-size:.7rem;
      background:rgba(56,189,248,.16);
      color:#7dd3fc;
    }
    .badge-role.school{background:rgba(59,130,246,.16);color:#93c5fd;}
    .badge-role.company{background:rgba(244,114,182,.16);color:#f9a8d4;}
    .badge-role.admin{background:rgba(251,191,36,.16);color:#facc15;}
    .badge-role.student{background:rgba(34,197,94,.16);color:#4ade80;}

    .table-dashboard{
      width:100%;
      border-collapse:collapse;
      font-size:.8rem;
      color:#e5e7eb;
    }
    .table-dashboard th,
    .table-dashboard td{
      padding:.45rem .5rem;
      border-bottom:1px solid #1e293b;
      white-space:nowrap;
    }
    .table-dashboard thead{
      background:#020617;
    }

    /* FOOTER */
    .main-footer{
      background:#02081f;
      margin-top:2rem;
      padding:3rem 2rem 1.5rem;
      border-top:1px solid #020617;
    }
    .footer-logo{
      font-size:1.25rem;
      font-weight:700;
      margin-bottom:.75rem;
      color:#fff;
    }
    .footer-text{
      font-size:.9rem;
      max-width:360px;
      color:#cbd5f5;
    }
    .footer-title{
      font-weight:600;
      font-size:.95rem;
      margin-bottom:1rem;
      color:#e5e7eb;
    }
    .footer-link{
      display:block;
      font-size:.9rem;
      color:#cbd5f5;
      text-decoration:none;
      margin-bottom:.4rem;
    }
    .footer-link:hover{
      color:#fff;
      text-decoration:underline;
    }
    .footer-contact-item{
      font-size:.9rem;
      color:#cbd5f5;
      margin-bottom:.4rem;
      display:flex;
      align-items:flex-start;
      gap:.45rem;
    }
    .footer-contact-item i{
      font-size:1rem;
      margin-top:.1rem;
    }
    .footer-bottom{
      border-top:1px solid rgba(148,163,184,.4);
      margin-top:2rem;
      padding-top:1rem;
      font-size:.8rem;
      color:#9ca3af;
      text-align:center;
    }

    @media (max-width:992px){
      .sidebar{display:none;}
      .layout{flex-direction:column;}
      .topbar{position:static;}
    }
  </style>
</head>

<body>
<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="brand-box">
      <div class="brand-logo">
        <img src="learn2earn-logo.png" alt="Learn2Earn">
      </div>
      <div>
        <div class="brand-title">Learn2Earn</div>
        <div class="brand-sub">Admin Control Center</div>
      </div>
    </div>

    <div class="sidebar-section-title">Dashboard</div>
    <ul class="nav-main">
      <li class="nav-item">
        <a href="admin-home.html" class="nav-link">
          <i class="ri-dashboard-line"></i>
          <div>
            Tổng quan
            <small>Thống kê hệ thống</small>
          </div>
        </a>
      </li>
      <li class="nav-item">
        <a href="admin-users.html" class="nav-link">
          <i class="ri-user-3-line"></i>
          <div>
            Người dùng
            <small>SV – Trường – DN – Admin</small>
          </div>
        </a>
      </li>
      <li class="nav-item">
        <a href="admin-majors.html" class="nav-link">
          <i class="ri-book-2-line"></i>
          <div>
            Ngành học
            <small>Khoa / chuyên ngành</small>
          </div>
        </a>
      </li>
      <li class="nav-item">
        <a href="admin-jobs.html" class="nav-link">
          <i class="ri-briefcase-line"></i>
          <div>
            Tin tuyển dụng
            <small>Thực tập &amp; việc làm</small>
          </div>
        </a>
      </li>
      <li class="nav-item">
        <a href="admin-stats.html" class="nav-link">
          <i class="ri-bar-chart-grouped-line"></i>
          <div>
            Thống kê
            <small>SV &amp; doanh nghiệp</small>
          </div>
        </a>
      </li>
      <li class="nav-item">
        <a href="admin-settings.html" class="nav-link active">
          <i class="ri-settings-3-line"></i>
          <div>
            Cài đặt hệ thống
            <small>Phân quyền, cấu hình</small>
          </div>
        </a>
      </li>
    </ul>

    <div class="sidebar-bottom">
      <div class="sidebar-status">
        <i class="ri-shield-check-line"></i> Phiên bản ổn định
      </div>
      <div>Learn2Earn v1.0.0</div>
      <div>Last sync: 2 phút trước</div>
    </div>
  </aside>

  <!-- MAIN AREA -->
  <div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
      <div>
        <div class="topbar-title">Cài đặt & Phân quyền</div>
        <div class="topbar-sub">Quản lý cấu hình hệ thống, vai trò, bảo mật và thông báo</div>
      </div>

      <div class="topbar-search">
        <button class="btn btn-outline-light topbar-btn">
          <i class="ri-question-line"></i> Trợ giúp
        </button>
        <button class="btn btn-outline-danger topbar-btn">
          <i class="ri-logout-box-r-line"></i> Đăng xuất
        </button>
      </div>
    </header>

    <!-- PAGE CONTENT -->
    <main class="page">

      <!-- SECTION HEADER -->
      <div class="section-header">
        <div>
          <div class="section-title">Cấu hình chung</div>
          <div class="section-sub">Thay đổi các thiết lập cơ bản của nền tảng Learn2Earn</div>
        </div>
      </div>

      <!-- ROW 1: CẤU HÌNH CHUNG + BẢO TRÌ -->
      <div class="row g-3 mb-3">
        <div class="col-lg-7">
          <div class="card-glass">
            <div class="mb-2" style="font-size:.95rem;font-weight:600;">Thông tin nền tảng</div>

            <div class="mb-3">
              <div class="setting-label">Tên nền tảng hiển thị</div>
              <div class="setting-desc">Tên này sẽ hiển thị trên logo, email và tiêu đề trình duyệt.</div>
              <input type="text" class="form-control" value="Learn2Earn – Thực tập & Việc làm sinh viên">
            </div>

            <div class="mb-3">
              <div class="setting-label">Tên miền chính</div>
              <div class="setting-desc">URL chính mà sinh viên, nhà trường và doanh nghiệp truy cập.</div>
              <input type="text" class="form-control" value="https://learn2earn.vn">
            </div>

            <div class="mb-3">
              <div class="setting-label">Logo</div>
              <div class="setting-desc">Sử dụng file logo learn2earn-logo.png trong hệ thống hiện tại.</div>
              <button class="btn btn-outline-light btn-sm">
                <i class="ri-image-edit-line me-1"></i> Thay logo
              </button>
            </div>

            <div class="mb-2">
              <button class="btn btn-primary btn-sm">
                <i class="ri-save-3-line me-1"></i> Lưu thay đổi
              </button>
            </div>
          </div>
        </div>

        <div class="col-lg-5">
          <div class="card-glass h-100">
            <div class="mb-2" style="font-size:.95rem;font-weight:600;">Chế độ hệ thống</div>

            <div class="form-check form-switch mb-2">
              <input class="form-check-input" type="checkbox" id="maintenanceMode" checked>
              <label class="form-check-label" for="maintenanceMode">
                Bật chế độ hoạt động bình thường
              </label>
            </div>
            <div class="setting-desc">
              Khi tắt chế độ này, hệ thống sẽ chuyển sang <b>Chế độ bảo trì</b> và chỉ Admin mới đăng nhập được.
            </div>

            <hr style="border-color:#1f2937;">

            <div class="form-check form-switch mb-2">
              <input class="form-check-input" type="checkbox" id="allowRegister" checked>
              <label class="form-check-label" for="allowRegister">
                Cho phép đăng ký tài khoản mới
              </label>
            </div>
            <div class="setting-desc">
              Áp dụng cho Sinh viên, Doanh nghiệp. Nhà trường thường được Admin khởi tạo thủ công.
            </div>

            <button class="btn btn-outline-light btn-sm mt-2">
              <i class="ri-save-line me-1"></i> Lưu cấu hình
            </button>
          </div>
        </div>
      </div>

      <!-- SECTION: PHÂN QUYỀN -->
      <div class="section-header mt-3">
        <div>
          <div class="section-title">Phân quyền & vai trò</div>
          <div class="section-sub">Quy định quyền hạn cho từng loại tài khoản</div>
        </div>
      </div>

      <div class="card-glass mb-3">
        <div class="mb-2" style="font-size:.95rem;font-weight:600;">Tổng quan vai trò</div>
        <div class="table-responsive mb-3">
          <table class="table-dashboard">
            <thead>
            <tr>
              <th>Vai trò</th>
              <th>Mô tả</th>
              <th>Quyền chính</th>
            </tr>
            </thead>
            <tbody>
            <tr>
              <td><span class="badge-role admin">Admin</span></td>
              <td>Quản trị toàn bộ hệ thống.</td>
              <td>Quản lý người dùng, ngành học, tin tuyển dụng, cấu hình & phân quyền.</td>
            </tr>
            <tr>
              <td><span class="badge-role school">Nhà trường</span></td>
              <td>Quản lý sinh viên của trường, chương trình thực tập.</td>
              <td>Gán sinh viên cho doanh nghiệp, duyệt báo cáo thực tập, xem thống kê theo trường.</td>
            </tr>
            <tr>
              <td><span class="badge-role company">Doanh nghiệp</span></td>
              <td>Đăng tin thực tập / việc làm, quản lý ứng viên.</td>
              <td>Tạo / sửa / đóng tin tuyển dụng, đánh giá sinh viên, xuất danh sách ứng viên.</td>
            </tr>
            <tr>
              <td><span class="badge-role student">Sinh viên</span></td>
              <td>Tìm kiếm và ứng tuyển việc làm, thực tập.</td>
              <td>Ứng tuyển, cập nhật CV, ghi nhật ký thực tập, nộp báo cáo.</td>
            </tr>
            </tbody>
          </table>
        </div>

        <div style="font-size:.85rem;color:var(--muted);">
          Lưu ý: Đây chỉ là giao diện mô phỏng. Khi triển khai thật, phần quyền sẽ được kết nối với backend (role, permission).
        </div>
      </div>

      <!-- ROW: CHI TIẾT QUYỀN (CHECKBOX DEMO) + BẢO MẬT -->
      <div class="row g-3 mb-3">
        <div class="col-lg-7">
          <div class="card-glass h-100">
            <div class="mb-2" style="font-size:.95rem;font-weight:600;">Phân quyền chi tiết (demo UI)</div>
            <div class="setting-desc">
              Chọn vai trò để xem / chỉnh sửa nhóm quyền. (Hiện tại chỉ là giao diện tĩnh, chưa có JS xử lý.)
            </div>

            <div class="mb-3">
              <label class="setting-label">Chọn vai trò</label>
              <select class="form-select form-select-sm">
                <option>Admin</option>
                <option>Nhà trường</option>
                <option>Doanh nghiệp</option>
                <option>Sinh viên</option>
              </select>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="setting-label">Quản lý người dùng</div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="permUserView" checked>
                  <label class="form-check-label" for="permUserView">Xem danh sách người dùng</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="permUserEdit" checked>
                  <label class="form-check-label" for="permUserEdit">Chỉnh sửa thông tin người dùng</label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input" type="checkbox" id="permUserLock" checked>
                  <label class="form-check-label" for="permUserLock">Khoá / mở khoá tài khoản</label>
                </div>
              </div>

              <div class="col-md-6">
                <div class="setting-label">Quản lý nội dung</div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="permJobApprove" checked>
                  <label class="form-check-label" for="permJobApprove">Duyệt tin tuyển dụng</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="permMajorConfig" checked>
                  <label class="form-check-label" for="permMajorConfig">Cấu hình ngành học</label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input" type="checkbox" id="permStatsView" checked>
                  <label class="form-check-label" for="permStatsView">Xem toàn bộ thống kê</label>
                </div>
              </div>
            </div>

            <button class="btn btn-primary btn-sm mt-2">
              <i class="ri-save-3-line me-1"></i> Lưu phân quyền
            </button>
          </div>
        </div>

        <div class="col-lg-5">
          <div class="card-glass h-100">
            <div class="mb-2" style="font-size:.95rem;font-weight:600;">Thiết lập bảo mật</div>

            <div class="form-check form-switch mb-2">
              <input class="form-check-input" type="checkbox" id="twoFA" checked>
              <label class="form-check-label" for="twoFA">
                Bắt buộc xác thực 2 bước cho tài khoản Admin
              </label>
            </div>
            <div class="setting-desc">
              Khi bật, Admin sẽ phải nhập mã OTP (qua email / ứng dụng) khi đăng nhập.
            </div>

            <div class="mb-2">
              <div class="setting-label">Số lần đăng nhập sai cho phép</div>
              <select class="form-select form-select-sm">
                <option>3 lần</option>
                <option selected>5 lần</option>
                <option>10 lần</option>
              </select>
              <div class="setting-desc">
                Vượt quá giới hạn này, tài khoản sẽ bị khoá tạm thời.
              </div>
            </div>

            <div class="mb-2">
              <div class="setting-label">Tự động đăng xuất sau</div>
              <select class="form-select form-select-sm">
                <option>30 phút không hoạt động</option>
                <option selected>60 phút không hoạt động</option>
                <option>120 phút không hoạt động</option>
              </select>
            </div>

            <button class="btn btn-outline-light btn-sm mt-2">
              <i class="ri-shield-keyhole-line me-1"></i> Lưu thiết lập bảo mật
            </button>
          </div>
        </div>
      </div>

      <!-- ROW: THÔNG BÁO + TÀI KHOẢN ADMIN -->
      <div class="row g-3 mb-4">
        <div class="col-lg-7">
          <div class="card-glass h-100">
            <div class="mb-2" style="font-size:.95rem;font-weight:600;">Thông báo & Email</div>

            <div class="setting-desc">
              Chọn các loại sự kiện mà hệ thống sẽ gửi email / thông báo cho Admin.
            </div>

            <div class="form-check mb-1">
              <input class="form-check-input" type="checkbox" id="notifNewJob" checked>
              <label class="form-check-label" for="notifNewJob">
                Gửi email khi có <b>tin tuyển dụng mới</b> cần duyệt
              </label>
            </div>
            <div class="form-check mb-1">
              <input class="form-check-input" type="checkbox" id="notifNewSchool" checked>
              <label class="form-check-label" for="notifNewSchool">
                Gửi email khi có <b>trường mới</b> yêu cầu kích hoạt tài khoản
              </label>
            </div>
            <div class="form-check mb-1">
              <input class="form-check-input" type="checkbox" id="notifAbnormal" checked>
              <label class="form-check-label" for="notifAbnormal">
                Cảnh báo khi phát hiện <b>hoạt động bất thường</b> (đăng nhập lạ, spam tin,...)
              </label>
            </div>
            <div class="form-check mb-3">
              <input class="form-check-input" type="checkbox" id="notifSummary">
              <label class="form-check-label" for="notifSummary">
                Gửi <b>báo cáo tổng hợp hàng tuần</b> qua email
              </label>
            </div>

            <button class="btn btn-outline-light btn-sm">
              <i class="ri-save-line me-1"></i> Lưu cấu hình thông báo
            </button>
          </div>
        </div>

        <div class="col-lg-5">
          <div class="card-glass h-100">
            <div class="mb-2" style="font-size:.95rem;font-weight:600;">Tài khoản Admin hiện tại</div>

            <div class="setting-label">Tên đăng nhập</div>
            <div class="setting-desc">admin_root</div>

            <div class="setting-label">Email</div>
            <div class="setting-desc">admin@learn2earn.vn</div>

            <div class="setting-label">Vai trò</div>
            <div class="setting-desc">
              <span class="badge-role admin">Super Admin</span> – toàn quyền trên hệ thống.
            </div>

            <hr style="border-color:#1f2937;">

            <button class="btn btn-outline-light btn-sm mb-2">
              <i class="ri-key-2-line me-1"></i> Đổi mật khẩu
            </button>
            <br>
            <button class="btn btn-outline-danger btn-sm">
              <i class="ri-logout-circle-r-line me-1"></i> Đăng xuất khỏi tất cả thiết bị
            </button>
          </div>
        </div>
      </div>

