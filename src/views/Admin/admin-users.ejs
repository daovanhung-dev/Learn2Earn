              <td>10/09/2025</td>
              <td style="text-align:right;">
                <button class="btn btn-outline-light btn-sm">Xem</button>
                <button class="btn btn-outline-info btn-sm">Sửa</button>
                <button class="btn btn-outline-danger btn-sm">Khoá</button>
              </td>
            </tr>
            <tr>
              <td>school_vnua</td>
              <td>Phòng CTSV VNUA</td>
              <td><span class="badge-role school">Nhà trường</span></td>
              <td>ctsv@vnua.edu.vn</td>
              <td><span class="badge-status active">Đang hoạt động</span></td>
              <td>02/09/2025</td>
              <td style="text-align:right;">
                <button class="btn btn-outline-light btn-sm">Xem</button>
                <button class="btn btn-outline-info btn-sm">Sửa</button>
                <button class="btn btn-outline-danger btn-sm">Khoá</button>
              </td>
            </tr>
            <tr>
              <td>company_fpt</td>
              <td>FPT Software HR</td>
              <td><span class="badge-role company">Doanh nghiệp</span></td>
              <td>hr@fsoft.com</td>
              <td><span class="badge-status active">Đang hoạt động</span></td>
              <td>25/08/2025</td>
              <td style="text-align:right;">
                <button class="btn btn-outline-light btn-sm">Xem</button>
                <button class="btn btn-outline-info btn-sm">Sửa</button>
                <button class="btn btn-outline-danger btn-sm">Khoá</button>
              </td>
            </tr>
            <tr>
              <td>admin_root</td>
              <td>Super Admin</td>
              <td><span class="badge-role admin">Admin</span></td>
