              <span class="badge-status active">Đối tác đào tạo</span>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card-glass">
            <div class="section-sub mb-1">Doanh nghiệp</div>
            <div class="d-flex justify-content-between align-items-center">
              <div style="font-size:1.2rem;font-weight:600;">135</div>
              <span class="badge-status active">Đang tuyển</span>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card-glass">
            <div class="section-sub mb-1">Tài khoản bị khóa</div>
            <div class="d-flex justify-content-between align-items-center">
              <div style="font-size:1.2rem;font-weight:600;">17</div>
              <span class="badge-status locked">Cần rà soát</span>
            </div>
          </div>
        </div>
      </div>

      <!-- TABLE LIST -->
      <div class="card-glass mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div class="section-title" style="font-size:.95rem;">Danh sách người dùng gần đây</div>
          <div class="section-sub">Hiển thị top 10 tài khoản cập nhật gần nhất</div>
        </div>

        <div class="table-responsive">
          <table class="table-dashboard">
            <thead>
            <tr>
              <th>Tài khoản</th>
              <th>Họ tên</th>
              <th>Vai trò</th>
              <th>Email</th>
              <th>Trạng thái</th>
              <th>Ngày tạo</th>
              <th style="text-align:right;">Thao tác</th>
            </tr>
            </thead>
            <tbody>
            <tr>
              <td>sv_k68cntt01</td>
              <td>Nguyễn Văn A</td>
              <td><span class="badge-role">Sinh viên</span></td>
