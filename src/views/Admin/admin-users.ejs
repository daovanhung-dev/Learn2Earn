              <td><span class="badge-status active">Đang hoạt động</span></td>
              <td>01/08/2025</td>
              <td style="text-align:right;">
                <button class="btn btn-outline-light btn-sm">Xem</button>
                <button class="btn btn-outline-info btn-sm">Sửa</button>
                <button class="btn btn-outline-danger btn-sm">Khoá</button>
              </td>
            </tr>
            <tr>
              <td>company_x123</td>
              <td>Công ty XYZ</td>
              <td><span class="badge-role company">Doanh nghiệp</span></td>
              <td>hr@xyz.com</td>
              <td><span class="badge-status locked">Bị khóa</span></td>
              <td>20/07/2025</td>
              <td style="text-align:right;">
                <button class="btn btn-outline-light btn-sm">Xem</button>
                <button class="btn btn-outline-success btn-sm">Mở khoá</button>
              </td>
            </tr>
            <!-- thêm các dòng demo khác nếu cần -->
            </tbody>
          </table>
        </div>
      </div>

    </main>

    <!-- FOOTER -->
    <footer class="main-footer">
      <div class="container-fluid px-0">
        <div class="row g-4">
          <div class="col-md-4">
            <div class="footer-logo">Learn2Earn</div>
            <p class="footer-text">
              Nền tảng tuyển dụng và tìm việc làm tại Việt Nam, kết nối sinh viên – người đi làm
