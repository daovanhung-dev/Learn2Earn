          </div>

          <div class="col-md-2">
            <div class="footer-title">Liên hệ</div>
            <div class="footer-contact-item">
              <i class="ri-phone-line"></i> <span>+84 123 456 789</span>
            </div>
            <div class="footer-contact-item">
              <i class="ri-mail-line"></i> <span>info@learn2earn.vn</span>
            </div>
            <div class="footer-contact-item">
              <i class="ri-map-pin-line"></i> <span>Hà Nội, Việt Nam</span>
            </div>
          </div>
