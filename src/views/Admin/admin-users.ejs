            <a href="#" class="footer-link">Tài liệu hướng dẫn</a>
            <a href="#" class="footer-link">Blog</a>
          </div>

          <div class="col-md-2">
            <div class="footer-title">Dành cho nhà tuyển dụng</div>
            <a href="#" class="footer-link">Đăng tuyển dụng</a>
            <a href="#" class="footer-link">Tìm ứng viên</a>
            <a href="#" class="footer-link">Gói dịch vụ</a>
