<header class="header">
  <nav class="navbar navbar-expand-lg navbar-light">
    <div class="container">
      <!-- Logo -->
      <a class="navbar-brand" role="button" data-route="/Student/Home" onclick="navigateTo('/Student/Home')">
        <img src="/img/logo-nobr.png" alt="Logo Learn2Earn" class="brand-logo">
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
        <!-- MENU CHÍNH -->
        <ul class="navbar-nav mx-auto d-flex align-items-center">
          <li class="nav-item">
            <a class="nav-link" data-route="/Student/Home" onclick="navigateTo('/Student/Home')">Trang chủ</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" data-route="/Student/Profile" onclick="navigateTo('/Student/CV')">CV</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" data-route="/Student/Interview" onclick="navigateTo('/Student/Interview')">Lịch phỏng vấn</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" data-route="/Student/PostJobs" onclick="navigateTo('/Student/Result')">Kết quả phỏng vấn</a>
          </li>
        </ul>

        <!-- ICON PHẢI -->
        <ul class="navbar-nav ms-auto d-flex align-items-center">
          <li class="nav-item">
            <a class="nav-icon" role="button" data-route="/Student/Noti" onclick="navigateTo('/Student/Noti')">
              <i class="bi bi-bell"></i>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-icon" role="button" data-route="/Student/Chat" onclick="navigateTo('/Student/Chat')">
              <i class="bi bi-chat-dots"></i>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" data-route="/Student/Setting" onclick="navigateTo('/Student/Setting')">Cài đặt</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <script>
    // chuyển trang với fade-out
    function navigateTo(url) {
      if (!url) return;
      if (location.pathname === url || location.pathname.endsWith(url)) {
        return;
      }
      document.body.style.transition = 'opacity 0.25s';
      document.body.style.opacity = '0';
      setTimeout(() => { window.location.href = url; }, 220);
    }

    // tự động highlight menu theo current path (dùng data-route)
    function setActiveNavByPath() {
      const links = document.querySelectorAll('[data-route]');
      const path = location.pathname || '/';
      links.forEach(a => a.classList.remove('active'));
      let found = false;
      links.forEach(a => {
        const r = a.getAttribute('data-route');
        if (!r) return;
        if (path === r || path.endsWith(r) || path.includes(r)) {
          a.classList.add('active');
          found = true;
        }
      });
      if (!found) {
        const home = document.querySelector('[data-route="/Student/Home"]');
        if (home) home.classList.add('active');
      }
    }

    function resetDropdownsOnResize() {
      document.querySelectorAll('.dropdown-menu').forEach(dm => {
        if (window.innerWidth <= 992) {
          dm.style.display = '';
        }
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      setActiveNavByPath();
      window.addEventListener('popstate', setActiveNavByPath);
      window.addEventListener('resize', resetDropdownsOnResize);
    });
  </script>
</header>


