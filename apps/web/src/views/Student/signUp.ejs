<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Đăng Ký - Learn2Earn</title>

  <!-- Bootstrap + FontAwesome + Google Fonts -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Poppins:wght@600;700&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --primary: #3B82F6;
      --primary-dark: #2563EB;
      --muted: #64748B;
      --bg: #F8FAFC;
      --card-radius: 18px;
    }

    * {
      box-sizing: border-box
    }

    body {
      font-family: Inter, system-ui, Segoe UI, Roboto, "Helvetica Neue", Arial;
      background: linear-gradient(135deg, #EFF6FF 0%, #F1F5F9 100%);
      color: #0f172a;
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .card-wrap {
      width: 100%;
      max-width: 1000px;
      display: flex;
      border-radius: var(--card-radius);
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(59, 130, 246, 0.08);
      background: #fff;
    }

    .side {
      flex: 1;
      padding: 40px;
      background: linear-gradient(180deg, rgba(59, 130, 246, 0.06), rgba(59, 130, 246, 0.02));
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 18px;
      min-width: 280px;
    }

    .side h1 {
      font-family: Poppins, Inter;
      margin: 0;
      font-size: 26px;
      color: #0f172a;
    }

    .side p {
      color: var(--muted);
      margin: 0;
      font-size: 14px
    }

    .features {
      list-style: none;
      padding: 0;
      margin-top: 10px
    }

    .features li {
      margin: 9px 0;
      color: #334155;
      font-size: 14px
    }

    .features li i {
      width: 30px;
      height: 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-right: 10px;
      color: var(--primary)
    }

    .form-side {
      flex: 1;
      padding: 36px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .brand {
      display: flex;
      gap: 12px;
      align-items: center;
      margin-bottom: 6px
    }

    .brand img {
      width: 56px;
      height: 56px;
      object-fit: contain;
      border-radius: 10px
    }

    .brand h2 {
      font-size: 20px;
      margin: 0;
      font-family: Poppins
    }

    .small-muted {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 14px
    }

    /* progress */
    .progress-steps {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-bottom: 18px
    }

    .progress-steps .dot {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #fff;
      border: 2px solid #e6eefb;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-weight: 600
    }

    .progress-steps .dot.active {
      background: var(--primary);
      color: #fff;
      border-color: var(--primary)
    }

    .progress-steps .bar {
      height: 4px;
      flex: 1;
      background: #eef2ff;
      border-radius: 4px
    }

    label.form-label {
      font-weight: 600;
      font-size: 14px;
      color: #334155
    }

    .form-control {
      border-radius: 10px;
      padding: 12px 14px;
      border: 1px solid #e6eefb;
      background: #fbfdff
    }

    .form-control:focus {
      box-shadow: 0 6px 18px rgba(59, 130, 246, 0.08);
      border-color: var(--primary-dark);
      outline: none
    }

    .input-with-icon {
      position: relative
    }

    .input-with-icon .fa {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted)
    }

    .input-with-icon .form-control {
      padding-left: 38px
    }

    .password-toggle {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      border: none;
      background: none;
      color: var(--muted);
      cursor: pointer
    }

    .btn-primary-custom {
      background: linear-gradient(90deg, var(--primary), var(--primary-dark));
      border: none;
      color: #fff;
      padding: 12px 18px;
      border-radius: 10px;
      width: 100%;
      font-weight: 600;
    }

    .btn-ghost {
      border: 1px solid #e6eefb;
      background: #fff;
      color: #334155;
      padding: 10px 14px;
      border-radius: 10px;
      width: 100%
    }

    .login-link {
      font-size: 13px;
      color: var(--muted);
      text-align: center;
      margin-top: 10px
    }

    @media (max-width:900px) {
      .card-wrap {
        flex-direction: column
      }

      .side {
        order: 2
      }

      .form-side {
        order: 1
      }
    }
  </style>
</head>

<body>

  <div class="card-wrap">
    <div class="side">
      <div class="brand">
        <img src="/Media/logo.png" alt="L2E" onerror="this.src='https://via.placeholder.com/80/3B82F6/fff?text=L2E'">
        <div>
          <div style="font-weight:700">Learn2Earn</div>
          <div style="font-size:13px;color:var(--muted)">Học để tăng thu nhập</div>
        </div>
      </div>

      <h1>Học để kiếm tiền — kiến thức tạo giá trị</h1>
      <p>Tiếp cận khóa học chất lượng, làm project thực tế, và biến kỹ năng thành thu nhập.</p>

      <ul class="features">
        <li><i class="fas fa-rocket"></i> Hàng trăm khóa học thực tế</li>
        <li><i class="fas fa-coins"></i> Cơ hội kiếm tiền sau học</li>
        <li><i class="fas fa-users"></i> Cộng đồng hỗ trợ</li>
      </ul>
    </div>

    <div class="form-side">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px">
        <div>
          <div style="font-size:18px; font-weight:700">Bắt đầu hành trình</div>
          <div class="small-muted">Tạo tài khoản (gọn & nhanh)</div>
        </div>
        <div style="width:140px">
          <!-- social shortcuts (non-functional) -->
          <div style="display:flex; gap:8px">
            <button type="button" class="btn-ghost" title="Google"><i class="fab fa-google"></i></button>
            <button type="button" class="btn-ghost" title="Facebook"><i class="fab fa-facebook-f"></i></button>
            <button type="button" class="btn-ghost" title="LinkedIn"><i class="fab fa-linkedin-in"></i></button>
          </div>
        </div>
      </div>

      <div class="progress-steps" aria-hidden="true">
        <div class="dot active" id="dot1">1</div>
        <div class="bar"></div>
        <div class="dot" id="dot2">2</div>
        <div class="bar"></div>
        <div class="dot" id="dot3">3</div>
      </div>

      <!-- form (fields match table sinhvien) -->
      <form id="registrationForm" action="/signUpStudent" method="post" enctype="multipart/form-data" novalidate>
        <!-- STEP 1 -->
        <div id="step1">
          <div class="mb-3">
            <label class="form-label" for="hoten">Họ và tên</label>
            <input id="hoten" name="hoten" type="text" class="form-control" required placeholder="Nhập họ tên đầy đủ">
          </div>

          <div class="mb-3 input-with-icon">
            <i class="fa fa-envelope"></i>
            <label class="form-label" for="email">Email</label>
            <input id="email" name="email" type="email" class="form-control" required placeholder="email@example.com">
          </div>

          <div class="d-grid gap-2">
            <button type="button" class="btn-primary-custom" onclick="nextStep(1)">Tiếp theo <i
                class="fas fa-arrow-right" style="margin-left:8px"></i></button>
          </div>
        </div>

        <!-- STEP 2 -->
        <div id="step2" style="display:none">
          <div class="mb-3 input-with-icon" style="position:relative">
            <i class="fa fa-lock"></i>
            <label class="form-label" for="matkhau">Mật khẩu</label>
            <input id="matkhau" name="matkhau" type="password" class="form-control" required
              placeholder="Ít nhất 8 ký tự">
            <button type="button" class="password-toggle" id="toggleMatkhau" aria-label="Toggle password"><i
                class="fa fa-eye"></i></button>
          </div>

          <div class="mb-3">
            <label class="form-label" for="confirmMatkhau">Xác nhận mật khẩu</label>
            <input id="confirmMatkhau" type="password" class="form-control" required placeholder="Nhập lại mật khẩu">
          </div>

          <div class="mb-3">
            <label class="form-label" for="chuyennganh">Chuyên ngành</label>
            <select id="chuyennganh" name="chuyennganh" class="form-control" required>
              <option value="">--- Chọn chuyên ngành ---</option>
              <option value="CNTT">Công nghệ thông tin</option>
              <option value="Kinh tế">Kinh tế</option>
              <option value="Nông nghiệp">Nông nghiệp</option>
              <option value="Khác">Khác</option>
            </select>
          </div>

          <div class="d-flex gap-2">
            <button type="button" class="btn-ghost" onclick="prevStep(2)"><i class="fas fa-arrow-left"></i> Quay
              lại</button>
            <button type="button" class="btn-primary-custom ms-auto" onclick="nextStep(2)">Tiếp theo <i
                class="fas fa-arrow-right" style="margin-left:8px"></i></button>
          </div>
        </div>

        <!-- STEP 3 -->
        <div id="step3" style="display:none">
          <div class="mb-3">
            <label class="form-label" for="avt">Ảnh đại diện (tùy chọn)</label>
            <input id="avt" name="avt" type="file" accept="image/*" class="form-control">
          </div>

          <div class="form-check mb-3">
            <input id="agree" class="form-check-input" type="checkbox" required>
            <label class="form-check-label" for="agree">Tôi đồng ý với <a href="#" style="color:var(--primary)">Điều
                khoản</a></label>
          </div>

          <div class="d-grid gap-2">
            <button type="button" class="btn-ghost" onclick="prevStep(3)"><i class="fas fa-arrow-left"></i> Quay
              lại</button>
            <button type="submit" class="btn-primary-custom">Đăng ký</button>
          </div>
        </div>
      </form>

      <div class="login-link">Đã có tài khoản? <a href="signIn.html" style="color:var(--primary); font-weight:600">Đăng
          nhập</a></div>
    </div>
  </div>

  <script>
    // Simple step control and validation
    const form = document.getElementById('registrationForm');
    let step = 1;

    function showStep(n) {
      document.getElementById('step1').style.display = n === 1 ? 'block' : 'none';
      document.getElementById('step2').style.display = n === 2 ? 'block' : 'none';
      document.getElementById('step3').style.display = n === 3 ? 'block' : 'none';
      document.getElementById('dot1').classList.toggle('active', n === 1);
      document.getElementById('dot2').classList.toggle('active', n === 2);
      document.getElementById('dot3').classList.toggle('active', n === 3);
    }

    function nextStep(current) {
      if (!validate(current)) return;
      step = current + 1;
      showStep(step);
    }

    function prevStep(current) {
      step = current - 1;
      showStep(step);
    }

    function validate(current) {
      // step 1 validation
      if (current === 1) {
        const hoten = document.getElementById('hoten').value.trim();
        const email = document.getElementById('email').value.trim();
        if (!hoten) {
          alert('Vui lòng nhập họ và tên'); return false;
        }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          alert('Vui lòng nhập email hợp lệ'); return false;
        }
      }

      // step 2 validation
      if (current === 2) {
        const pw = document.getElementById('matkhau').value;
        const pw2 = document.getElementById('confirmMatkhau').value;
        const cg = document.getElementById('chuyennganh').value;
        if (pw.length < 8) {
          alert('Mật khẩu phải có ít nhất 8 ký tự'); return false;
        }
        if (pw !== pw2) {
          alert('Mật khẩu xác nhận không khớp'); return false;
        }
        if (!cg) {
          alert('Vui lòng chọn chuyên ngành'); return false;
        }
      }
      return true;
    }

    // password toggle
    document.getElementById('toggleMatkhau').addEventListener('click', () => {
      const inp = document.getElementById('matkhau');
      const i = document.querySelector('#toggleMatkhau i');
      if (inp.type === 'password') { inp.type = 'text'; i.classList.replace('fa-eye', 'fa-eye-slash') }
      else { inp.type = 'password'; i.classList.replace('fa-eye-slash', 'fa-eye') }
    });

    // final submit: let browser do POST after client validation
    form.addEventListener('submit', function (e) {
      // ensure final validations (step 3)
      if (!document.getElementById('agree').checked) {
        e.preventDefault();
        alert('Vui lòng chấp nhận điều khoản để tiếp tục');
        return false;
      }
      // everything ok — form will submit to server (no JS submit simulation)
    });

    // initialize
    showStep(1);
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>