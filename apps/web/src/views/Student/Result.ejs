<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Kết quả ứng tuyển</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container my-5">
    <h2 class="mb-4">Kết quả ứng tuyển của bạn</h2>

    <% if (ketqua.length === 0) { %>
      <p>Bạn chưa ứng tuyển vị trí nào.</p>
    <% } else { %>
      <table class="table table-bordered table-striped">
        <thead>
          <tr>
            <th>Vị trí</th>
            <th>Phòng ban</th>
            <th>Doanh nghiệp</th>
            <th>Trạng thái</th>
            <th>Ngày ứng tuyển</th>
          </tr>
        </thead>
        <tbody>
          <% ketqua.forEach(item => { %>
            <tr>
              <td><%= item.JD?.ten_vi_tri || 'Chưa có' %></td>
              <td><%= item.JD?.phong_ban || 'Chưa có' %></td>
              <td><%= item.DoanhNghiep?.hoten || 'Chưa có' %></td>
              <td><%= item.trangthai %></td>
              <td><%= item.created_at.toLocaleDateString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
