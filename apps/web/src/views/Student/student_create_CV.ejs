<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Tạo CV</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .invalid-message { color: #dc3545; font-size: 0.9rem; margin-top: .25rem; display: none; }
    .is-invalid + .invalid-message { display: block; }
  </style>
</head>

<body class="bg-light">

<div class="container my-5">
  <div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
      <h4 class="mb-0">Tạo CV mới</h4>
    </div>

    <div class="card-body">
      <div id="formAlert" class="alert d-none" role="alert"></div>

      <form id="cvForm" action="/Student/CreateCV" method="POST" enctype="multipart/form-data" novalidate>

        <!-- Ảnh đại diện -->
        <div class="mb-3">
          <label class="form-label">Ảnh đại diện</label>
          <input type="file" id="avt" name="avt" class="form-control" accept="image/*">
          <div class="invalid-message" id="avt_error"></div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Họ tên <span class="text-danger">*</span></label>
            <input type="text" id="hoten" name="hoten" class="form-control" required>
            <div class="invalid-message" id="hoten_error"></div>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label">Ngày sinh</label>
            <input type="date" id="ngaysinh" name="ngaysinh" class="form-control">
            <div class="invalid-message" id="ngaysinh_error"></div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Giới tính</label>
            <select id="gioitinh" name="gioitinh" class="form-select">
              <option value="">-- Chọn --</option>
              <option value="Nam">Nam</option>
              <option value="Nữ">Nữ</option>
              <option value="Khác">Khác</option>
            </select>
            <div class="invalid-message" id="gioitinh_error"></div>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label">Email <span class="text-danger">*</span></label>
            <input type="email" id="email" name="email" class="form-control" required>
            <div class="invalid-message" id="email_error"></div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Số điện thoại</label>
            <input type="text" id="sdt" name="sdt" class="form-control" placeholder="+84 9xxxxxxxx">
            <div class="invalid-message" id="sdt_error"></div>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label">Địa chỉ</label>
            <input type="text" id="diachi" name="diachi" class="form-control">
            <div class="invalid-message" id="diachi_error"></div>
          </div>
        </div>

        <hr>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Vị trí ứng tuyển</label>
            <input type="text" id="vitri" name="vitri" class="form-control">
            <div class="invalid-message" id="vitri_error"></div>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label">Ngành</label>
            <input type="text" id="nganh" name="nganh" class="form-control">
            <div class="invalid-message" id="nganh_error"></div>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label">Lương mong muốn</label>
          <input type="text" id="luongmongmuon" name="luongmongmuon" class="form-control" placeholder="Ví dụ: 10000000">
          <div class="invalid-message" id="luongmongmuon_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Mục tiêu nghề nghiệp</label>
          <textarea id="muctieunghiep" name="muctieunghiep" class="form-control"></textarea>
          <div class="invalid-message" id="muctieunghiep_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Học vấn</label>
          <textarea id="hocvan" name="hocvan" class="form-control"></textarea>
          <div class="invalid-message" id="hocvan_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Kinh nghiệm</label>
          <textarea id="kinhnghiem" name="kinhnghiem" class="form-control"></textarea>
          <div class="invalid-message" id="kinhnghiem_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Kỹ năng</label>
          <textarea id="kynang" name="kynang" class="form-control"></textarea>
          <div class="invalid-message" id="kynang_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Ngoại ngữ</label>
          <textarea id="ngoaingu" name="ngoaingu" class="form-control"></textarea>
          <div class="invalid-message" id="ngoaingu_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Chứng chỉ</label>
          <textarea id="chungchi" name="chungchi" class="form-control"></textarea>
          <div class="invalid-message" id="chungchi_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Dự án</label>
          <textarea id="duan" name="duan" class="form-control"></textarea>
          <div class="invalid-message" id="duan_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Giải thưởng</label>
          <textarea id="giaithuong" name="giaithuong" class="form-control"></textarea>
          <div class="invalid-message" id="giaithuong_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Hoạt động</label>
          <textarea id="hoatdong" name="hoatdong" class="form-control"></textarea>
          <div class="invalid-message" id="hoatdong_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Social (JSON string)</label>
          <textarea id="social" name="social" class="form-control" placeholder='{"facebook":"link","github":"link"}'></textarea>
          <div class="invalid-message" id="social_error"></div>
        </div>

        <div class="mb-3">
          <label class="form-label">Portfolio</label>
          <input type="text" id="portfolio" name="portfolio" class="form-control" placeholder="https://...">
          <div class="invalid-message" id="portfolio_error"></div>
        </div>

        <button type="submit" class="btn btn-primary w-100 py-2">Tạo CV</button>
      </form>
    </div>
  </div>
</div>

<script>
  (function(){
    // cấu hình kiểm tra
    const config = {
      maxImageSizeMB: 2,            // tối đa 2MB cho ảnh
      minNameLength: 2,
      maxTextLength: 5000,          // giới hạn chung cho textarea
      maxShortTextLength: 255,
      minAge: 16,
      maxAge: 80
    };

    const form = document.getElementById('cvForm');
    const alertBox = document.getElementById('formAlert');

    function setError(el, msg) {
      el.classList.add('is-invalid');
      const err = document.getElementById(el.id + '_error');
      if (err) err.textContent = msg;
    }
    function clearError(el) {
      el.classList.remove('is-invalid');
      const err = document.getElementById(el.id + '_error');
      if (err) err.textContent = '';
    }
    function showAlert(type, msg) {
      alertBox.className = 'alert alert-' + type;
      alertBox.textContent = msg;
      alertBox.classList.remove('d-none');
      alertBox.scrollIntoView({behavior: 'smooth', block: 'center'});
    }
    function hideAlert() {
      alertBox.className = 'alert d-none';
      alertBox.textContent = '';
    }

    function isValidEmail(email) {
      // regex đơn giản, đủ cho client-side
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function isValidPhone(phone) {
      if (!phone) return true;
      // remove spaces, dashes, parenteses
      const digits = phone.replace(/[^\d+]/g, '');
      // ít nhất 7 chữ số, nhiều nhất 15
      const justNumbers = digits.replace(/\D/g, '');
      return justNumbers.length >= 7 && justNumbers.length <= 15;
    }

    function parseDate(str) {
      if (!str) return null;
      const d = new Date(str);
      return isNaN(d.getTime()) ? null : d;
    }

    function ageFromDate(dob) {
      if (!dob) return null;
      const today = new Date();
      let age = today.getFullYear() - dob.getFullYear();
      const m = today.getMonth() - dob.getMonth();
      if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) age--;
      return age;
    }

    function isValidJSON(str) {
      try {
        const obj = JSON.parse(str);
        return obj && typeof obj === 'object';
      } catch (e) {
        return false;
      }
    }

    function isValidURL(str) {
      if (!str) return true;
      try {
        const u = new URL(str);
        return u.protocol === 'http:' || u.protocol === 'https:';
      } catch (e) {
        return false;
      }
    }

    // clear error on input
    ['hoten','email','sdt','ngaysinh','avt','social','portfolio'].forEach(id=>{
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('input', ()=> clearError(el));
      el.addEventListener('change', ()=> clearError(el));
    });

    form.addEventListener('submit', function(e){
      hideAlert();
      let firstInvalid = null;
      let hasError = false;

      // clear previous errors
      Array.from(form.elements).forEach(f => {
        if (f.id) clearError(f);
      });

      // hoten (required)
      const hoten = document.getElementById('hoten');
      if (!hoten.value || hoten.value.trim().length < config.minNameLength) {
        setError(hoten, 'Họ tên là bắt buộc (ít nhất ' + config.minNameLength + ' ký tự).');
        hasError = true; if (!firstInvalid) firstInvalid = hoten;
      } else if (hoten.value.trim().length > config.maxShortTextLength) {
        setError(hoten, 'Họ tên quá dài (tối đa '+config.maxShortTextLength+' ký tự).');
        hasError = true; if (!firstInvalid) firstInvalid = hoten;
      }

      // email (required + format)
      const email = document.getElementById('email');
      if (!email.value || !isValidEmail(email.value.trim())) {
        setError(email, 'Email không hợp lệ hoặc trống.');
        hasError = true; if (!firstInvalid) firstInvalid = email;
      }

      // sdt (optional but nếu có phải hợp lệ)
      const sdt = document.getElementById('sdt');
      if (sdt.value && !isValidPhone(sdt.value.trim())) {
        setError(sdt, 'Số điện thoại không hợp lệ (7-15 chữ số).');
        hasError = true; if (!firstInvalid) firstInvalid = sdt;
      }

      // ngaysinh (nếu có: không phải ngày tương lai, tuổi hợp lý)
      const ngaysinh = document.getElementById('ngaysinh');
      if (ngaysinh.value) {
        const d = parseDate(ngaysinh.value);
        if (!d) {
          setError(ngaysinh, 'Ngày sinh không hợp lệ.');
          hasError = true; if (!firstInvalid) firstInvalid = ngaysinh;
        } else {
          const today = new Date();
          if (d > today) {
            setError(ngaysinh, 'Ngày sinh không được lớn hơn ngày hôm nay.');
            hasError = true; if (!firstInvalid) firstInvalid = ngaysinh;
          } else {
            const age = ageFromDate(d);
            if (age !== null && (age < config.minAge || age > config.maxAge)) {
              setError(ngaysinh, 'Tuổi phải nằm trong khoảng ' + config.minAge + ' - ' + config.maxAge + ' tuổi.');
              hasError = true; if (!firstInvalid) firstInvalid = ngaysinh;
            }
          }
        }
      }

      // avt: nếu có - kiểm tra type + size
      const avt = document.getElementById('avt');
      if (avt && avt.files && avt.files.length > 0) {
        const file = avt.files[0];
        if (!file.type.startsWith('image/')) {
          setError(avt, 'Ảnh đại diện phải là file ảnh (jpg, png, gif...).');
          hasError = true; if (!firstInvalid) firstInvalid = avt;
        } else {
          const maxBytes = config.maxImageSizeMB * 1024 * 1024;
          if (file.size > maxBytes) {
            setError(avt, 'Kích thước ảnh tối đa ' + config.maxImageSizeMB + ' MB.');
            hasError = true; if (!firstInvalid) firstInvalid = avt;
          }
        }
      }

      // short text fields length checks
      ['diachi','vitri','nganh','portfolio'].forEach(id=>{
        const el = document.getElementById(id);
        if (!el) return;
        if (el.value && el.value.length > config.maxShortTextLength) {
          setError(el, 'Trường này quá dài (tối đa '+config.maxShortTextLength+' ký tự).');
          hasError = true; if (!firstInvalid) firstInvalid = el;
        }
      });

      // luongmongmuon: nếu có thì phải là số (đơn vị tuỳ bạn)
      const luong = document.getElementById('luongmongmuon');
      if (luong.value) {
        const cleaned = luong.value.replace(/[,\s]/g, '');
        if (isNaN(Number(cleaned))) {
          setError(luong, 'Lương mong muốn phải là số (ví dụ 10000000).');
          hasError = true; if (!firstInvalid) firstInvalid = luong;
        }
      }

      // textareas length limit
      ['muctieunghiep','hocvan','kinhnghiem','kynang','ngoaingu','chungchi','duan','giaithuong','hoatdong'].forEach(id=>{
        const el = document.getElementById(id);
        if (!el) return;
        if (el.value && el.value.length > config.maxTextLength) {
          setError(el, 'Nội dung quá dài (tối đa '+config.maxTextLength+' ký tự).');
          hasError = true; if (!firstInvalid) firstInvalid = el;
        }
      });

      // social JSON
      const social = document.getElementById('social');
      if (social.value) {
        if (!isValidJSON(social.value.trim())) {
          setError(social, 'Trường Social phải là JSON hợp lệ, ví dụ: {"facebook":"link","github":"link"}');
          hasError = true; if (!firstInvalid) firstInvalid = social;
        } else {
          // optional: validate values are strings/urls
          try {
            const parsed = JSON.parse(social.value);
            if (typeof parsed !== 'object' || Array.isArray(parsed)) {
              setError(social, 'Social phải là object JSON (key-value).');
              hasError = true; if (!firstInvalid) firstInvalid = social;
            } else {
              for (const k in parsed) {
                if (typeof parsed[k] !== 'string') {
                  setError(social, 'Giá trị trong Social phải là chuỗi (string).');
                  hasError = true; if (!firstInvalid) firstInvalid = social;
                  break;
                }
              }
            }
          } catch(e) {
            // already handled above
          }
        }
      }

      // portfolio: url check
      const portfolio = document.getElementById('portfolio');
      if (portfolio.value && !isValidURL(portfolio.value.trim())) {
        setError(portfolio, 'Portfolio không phải là URL hợp lệ (bắt đầu bằng http:// hoặc https://).');
        hasError = true; if (!firstInvalid) firstInvalid = portfolio;
      }

      if (hasError) {
        e.preventDefault();
        showAlert('danger', 'Có lỗi trong biểu mẫu. Vui lòng kiểm tra các ô đỏ và sửa trước khi gửi.');
        if (firstInvalid) firstInvalid.focus();
        return false;
      } else {
        // no client-side errors -> allow submit
        // optionally show a spinner or disable button to prevent double-submit
        return true;
      }
    });
  })();
</script>

</body>
</html>
