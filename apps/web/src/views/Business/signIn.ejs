<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Learn2Earn Business - Đăng nhập</title>

  <!-- Bootstrap + Icons + Font -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#eef2f7;
      --card-bg:#ffffff;
      --accent:#1e2a44;
      --muted:#64748b;
      --shadow: 0 8px 28px rgba(14,30,37,0.08);
    }
    *{box-sizing:border-box}
    body{
      font-family: "Inter", sans-serif;
      background: var(--bg);
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:20px;
    }

    .auth-card{
      width:420px;
      background:var(--card-bg);
      border-radius:14px;
      padding:28px;
      box-shadow:var(--shadow);
      border: 1px solid rgba(15,23,42,0.04);
    }

    .logo-box{
      width:56px;height:56px;border-radius:12px;background:var(--accent);color:#fff;
      display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-weight:700;font-size:1.05rem;
    }

    h4.title{ text-align:center; margin-bottom:10px; font-weight:700; color:var(--accent); }
    .tabs { display:flex; gap:8px; justify-content:center; margin-bottom:18px; }
    .tab-btn { padding-bottom:6px; color:var(--muted); font-weight:600; text-decoration:none; }
    .tab-btn.active { color:var(--accent); border-bottom:2px solid var(--accent); }

    .form-label{ font-weight:600; color:#243447; }
    .btn-login{ background:var(--accent); color:#fff; font-weight:700; border-radius:8px; }
    .btn-login i{ margin-right:8px; }

    .small-muted{ color:var(--muted); font-size:13px; text-align:center; margin-top:10px; }

    /* custom alert */
    .alert-business { border-radius:10px; padding:12px 14px; display:flex; gap:12px; align-items:flex-start; }
    .alert-business i{ font-size:18px; margin-top:2px; }

    @media(max-width:480px){
      .auth-card{ width:100%; padding:20px; border-radius:12px; }
    }
  </style>
</head>

<body>
  <div class="auth-card" role="main" aria-labelledby="businessLoginTitle">
    <div class="logo-box">DN</div>
    <h4 id="businessLoginTitle" class="title">Learn2Earn Business</h4>

    <!-- Tabs -->
    <div class="tabs" role="tablist" aria-label="Tùy chọn đăng nhập">
      <a href="/SignInBusiness" class="tab-btn active" role="tab" aria-selected="true">Đăng nhập</a>
      <a href="/SignUpBusiness" class="tab-btn" role="tab" aria-selected="false">Đăng ký</a>
    </div>

    <!-- ERRORS (Passport -> req.session.messages) -->
    <% if (errors && errors.length) { %>
      <div class="mb-3">
        <% errors.forEach(function(err) { %>
          <div class="alert alert-danger alert-business" role="alert">
            <i class="bi bi-exclamation-circle-fill"></i>
            <div>
              <strong>Lỗi</strong>
              <div><%= err %></div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- FORM -->
    <form method="POST" action="/signInBusiness" id="business-login-form" novalidate>
      <div class="mb-3">
        <label class="form-label" for="email">Email doanh nghiệp</label>
        <input id="email" name="email" type="email" class="form-control" placeholder="company@example.com" required
          value="<%= typeof email !== 'undefined' ? email : '' %>" autocomplete="username">
      </div>

      <div class="mb-3">
        <label class="form-label" for="matkhau">Mật khẩu</label>
        <div class="input-group position-relative">
          <input id="matkhau" name="matkhau" type="password" class="form-control" placeholder="Nhập mật khẩu" required
            autocomplete="current-password" aria-describedby="togglePass">
          <button type="button" id="togglePass" class="btn btn-sm position-absolute" style="right:8px;top:50%;transform:translateY(-50%);border:none;background:none;">
            <i class="bi bi-eye"></i>
          </button>
        </div>
      </div>

      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="rememberMe" name="rememberMe">
          <label class="form-check-label small" for="rememberMe">Ghi nhớ đăng nhập</label>
        </div>
        <a href="#" class="small text-decoration-none">Quên mật khẩu?</a>
      </div>

      <button class="btn btn-login w-100 mb-2" type="submit" id="submitBtn">
        <i class="bi bi-box-arrow-in-right"></i> <span id="btnText">Đăng nhập</span>
        <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
      </button>
    </form>

    <div class="small-muted">
      Hỗ trợ doanh nghiệp: <b>support@learn2earn.vn</b>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (function(){
      const toggle = document.getElementById('togglePass');
      const pass = document.getElementById('matkhau');
      toggle?.addEventListener('click', () => {
        if (!pass) return;
        pass.type = pass.type === 'password' ? 'text' : 'password';
        const icon = toggle.querySelector('i');
        icon.classList.toggle('bi-eye');
        icon.classList.toggle('bi-eye-slash');
      });

      // UX submit: disable & spinner
      const form = document.getElementById('business-login-form');
      const submitBtn = document.getElementById('submitBtn');
      const spinner = document.getElementById('btnSpinner');
      form?.addEventListener('submit', () => {
        submitBtn?.setAttribute('disabled', 'true');
        spinner?.classList.remove('d-none');
      });
    })();
  </script>
</body>

</html>
