<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <title>Chat ứng viên - Learn2Earn Business</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <style>
    :root {
      --navy: #1e2a44;
      --navy-light: #2d3b57;
      --gray-bg: #eef2f7;
      --card-bg: #ffffff;
      --text: #1e293b;
      --muted: #64748b;
      --dark-btn: #111827;
      --dark-btn-hover: #0f1623;
    }

    body {
      background: var(--gray-bg);
      font-size: 0.95rem;
      font-family: "Inter", sans-serif;
      color: var(--text);
    }

    /* ===== HEADER ===== */
    .header {
      background: white;
      box-shadow: 0 2px 8px rgba(0, 0, 0, .08);
      position: sticky;
      top: 0;
      z-index: 999;
    }

    .navbar-brand img {
      height: 55px;
      transform: scale(2.2);
      transform-origin: left center;
    }

    .nav-link {
      font-weight: 500;
      color: var(--muted) !important;
      border-radius: 14px;
      padding: 8px 18px !important;
    }

    .nav-link:hover {
      background: #e6ecf5;
      color: var(--navy) !important;
    }

    .nav-link.active {
      background: #dbe4f3;
      color: var(--navy) !important;
    }

    .nav-icon {
      width: 40px;
      height: 40px;
      background: #e6ecf5;
      color: var(--navy);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: 6px;
      font-size: 18px;
    }

    .nav-icon:hover {
      background: #d4dceb;
    }

    /* ===== PAGE CONTENT ===== */
    .card-soft {
      border-radius: 16px;
      border: 0;
      box-shadow: 0 4px 16px rgba(30,42,68,.12);
      background: white;
    }

    .candidate-item {
      cursor: pointer;
      padding: 10px 12px;
      border-radius: 12px;
      margin-bottom: 6px;
    }

    .candidate-item:hover { background: #f0f4ff; }
    .candidate-item.active { background: #dde8ff; }

    .candidate-avatar {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      background: #e5e7eb;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: 8px;
      font-weight: bold;
      color: #111827;
    }

    .status-online { color: #22c55e; font-size: 10px; }
    .status-offline { color: #9ca3af; font-size: 10px; }

    .chat-window {
      height: 480px;
      display: flex;
      flex-direction: column;
      border-radius: 16px;
      background: #ffffff;
      box-shadow: 0 4px 16px rgba(15,23,42,0.08);
    }

    .chat-header {
      padding: 14px 16px;
      border-bottom: 1px solid #e5e7eb;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .chat-body {
      flex: 1;
      padding: 14px 16px;
      overflow-y: auto;
      background: #f8fafc;
    }

    .chat-footer {
      padding: 12px;
      border-top: 1px solid #e5e7eb;
    }

    .msg-row {
      margin-bottom: 10px;
      display: flex;
    }

    .msg-row.me {
      justify-content: flex-end;
    }

    .msg-bubble {
      max-width: 70%;
      padding: 9px 12px;
      border-radius: 14px;
      font-size: 0.9rem;
    }

    .msg-bubble.me {
      background: #1e2a44;
      color: white;
      border-bottom-right-radius: 4px;
    }

    .msg-bubble.them {
      background: #e5e7eb;
      border-bottom-left-radius: 4px;
      color: #1e2a44;
    }

    .msg-time {
      font-size: 11px;
      color: #64748b;
      margin-top: 3px;
    }

    /* ===== FOOTER ===== */
    .footer {
      background: #020617;
      color: #E5E7EB;
      padding: 40px 0 20px;
      margin-top: 60px;
    }

    .footer-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 12px;
      color: #fff;
    }

    .footer-links {
      list-style: none;
      padding: 0;
    }

    .footer-links li {
      margin-bottom: 6px;
    }

    .footer-links a {
      color: #E5E7EB;
      font-size: .9rem;
    }

    .footer-bottom {
      border-top: 1px solid #111827;
      margin-top: 20px;
      padding-top: 12px;
      text-align: center;
      font-size: .85rem;
    }
  </style>
</head>

<body>

  <!-- ========== HEADER ========== -->
  <header class="header">
    <nav class="navbar navbar-expand-lg navbar-light">
      <div class="container">

        <a class="navbar-brand" href="#">
          <img src="/img/logo-nobr.png" alt="Logo Learn2Earn">
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-between" id="navMenu">

          <ul class="navbar-nav mx-auto">
            <li class="nav-item"><a class="nav-link" href="/Business">Trang chủ</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Quản lý tin tuyển dụng</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Ứng viên</a></li>
            <li class="nav-item"><a class="nav-link active" href="#">Chat</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Thống kê</a></li>
          </ul>

          <ul class="navbar-nav ms-auto d-flex align-items-center">
            <li class="nav-item"><a class="nav-icon" href="#"><i class="fa-regular fa-bell"></i></a></li>
            <li class="nav-item"><a class="nav-icon" href="#"><i class="fa-regular fa-comment-dots"></i></a></li>
            <li class="nav-item"><a class="nav-link" href="#">Cài đặt</a></li>
          </ul>

        </div>
      </div>
    </nav>
  </header>

  <!-- ========== PAGE CONTENT ========== -->
  <div class="container py-4">

    <!-- TITLE -->
    <h4 class="fw-bold text-dark mb-2">Trò chuyện với ứng viên</h4>
    <div class="text-muted small mb-4">Quản lý trao đổi trực tiếp với ứng viên đã ứng tuyển</div>

    <div class="row g-4">

      <!-- DANH SÁCH ỨNG VIÊN -->
      <div class="col-lg-4">
        <div class="card card-soft">
          <div class="card-body">

            <div class="d-flex justify-content-between mb-2">
              <span class="fw-semibold">Danh sách ứng viên</span>
              <span class="badge bg-dark text-white">3</span>
            </div>

            <input type="text" id="search" class="form-control form-control-sm mb-3" placeholder="Tìm ứng viên...">

            <div id="candidateList">

              <!-- Ứng viên 1 -->
              <div class="candidate-item active"
                   data-name="Nguyễn Thành Tùng"
                   data-avatar="T"
                   data-position="Thực tập sinh Marketing"
                   data-status="online">
                <div class="d-flex">
                  <div class="candidate-avatar">T</div>
                  <div class="flex-grow-1">
                    <div class="d-flex justify-content-between">
                      <span class="fw-semibold small">Nguyễn Thành Tùng</span>
                      <span class="small text-muted">09:20</span>
                    </div>
                    <div class="small text-muted">Ứng tuyển: Thực tập Marketing</div>
                  </div>
                </div>
              </div>

              <!-- Ứng viên 2 -->
              <div class="candidate-item"
                   data-name="Lê Thu Hà"
                   data-avatar="H"
                   data-position="Frontend Intern"
                   data-status="offline">
                <div class="d-flex">
                  <div class="candidate-avatar">H</div>
                  <div class="flex-grow-1">
                    <div class="d-flex justify-content-between">
                      <span class="fw-semibold small">Lê Thu Hà</span>
                      <span class="small text-muted">Hôm qua</span>
                    </div>
                    <div class="small text-muted">Ứng tuyển: Frontend Intern</div>
                  </div>
                </div>
              </div>

              <!-- Ứng viên 3 -->
              <div class="candidate-item"
                   data-name="Vũ Quốc Nhật"
                   data-avatar="N"
                   data-position="Backend Intern"
                   data-status="online">
                <div class="d-flex">
                  <div class="candidate-avatar">N</div>
                  <div class="flex-grow-1">
                    <div class="d-flex justify-content-between">
                      <span class="fw-semibold small">Vũ Quốc Nhật</span>
                      <span class="small text-muted">2 ngày trước</span>
                    </div>
                    <div class="small text-muted">Ứng tuyển: Backend Intern</div>
                  </div>
                </div>
              </div>

            </div>

          </div>
        </div>
      </div>

      <!-- KHUNG CHAT -->
      <div class="col-lg-8">
        <div class="chat-window">

          <!-- HEADER -->
          <div class="chat-header">

            <div class="d-flex align-items-center">
              <div class="candidate-avatar me-2" id="currentAvatar">T</div>
              <div>
                <div class="fw-semibold" id="currentName">Nguyễn Thành Tùng</div>
                <div class="small text-muted">Ứng tuyển: <span id="currentPosition">Thực tập sinh Marketing</span></div>
              </div>
            </div>

            <div class="small">
              <i class="bi bi-dot status-online" id="currentStatusDot"></i>
              <span id="currentStatus">Đang online</span>
            </div>

          </div>

          <!-- BODY -->
          <div class="chat-body" id="chatBody">

            <div class="msg-row">
              <div>
                <div class="msg-bubble them">
                  Chào anh/chị, em cảm ơn vì đã đọc CV vị trí FullStack của em ạ.
                </div>
                <div class="msg-time">Ứng viên · 09:10</div>
              </div>
            </div>

            <div class="msg-row me">
              <div>
                <div class="msg-bubble me">
                  .heheahihihih
                </div>
                <div class="msg-time">HR · 09:12</div>
              </div>
            </div>

          </div>

          <!-- FOOTER -->
          <div class="chat-footer">
            <div class="input-group">
              <input id="chatInput" type="text" class="form-control" placeholder="Nhập tin nhắn...">
              <button class="btn btn-dark" id="btnSend"><i class="bi bi-send"></i></button>
            </div>
          </div>

        </div>
      </div>

    </div>

  </div>

  <!-- ========== FOOTER ========== -->
  <footer class="footer">
    <div class="container">
      <div class="row">

        <div class="col-lg-4 mb-4">
          <h4 class="footer-title">Learn2Earn</h4>
          <p>Nền tảng hỗ trợ tuyển dụng và tìm kiếm ứng viên chất lượng cao.</p>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Về chúng tôi</h4>
          <ul class="footer-links">
            <li><a href="#">Giới thiệu</a></li>
            <li><a href="#">Tin tức</a></li>
            <li><a href="#">Tuyển dụng</a></li>
            <li><a href="#">Liên hệ</a></li>
          </ul>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Doanh nghiệp</h4>
          <ul class="footer-links">
            <li><a href="#">Đăng tin</a></li>
            <li><a href="#">Quản lý ứng viên</a></li>
            <li><a href="#">Gói dịch vụ</a></li>
            <li><a href="#">Hỗ trợ</a></li>
          </ul>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Liên hệ</h4>
          <ul class="footer-links">
            <li><a href="#"><i class="fas fa-phone me-2"></i>+84 123 456 789</a></li>
            <li><a href="#"><i class="fas fa-envelope me-2"></i>support@learn2earn.vn</a></li>
            <li><a href="#"><i class="fas fa-map-marker-alt me-2"></i>Hà Nội, Việt Nam</a></li>
          </ul>
        </div>

      </div>

      <div class="footer-bottom">
        &copy; 2024 Learn2Earn. All rights reserved.
      </div>
    </div>
  </footer>

  <!-- JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Gửi tin nhắn
    function sendMessage() {
      const input = document.getElementById("chatInput");
      const text = input.value.trim();
      if (!text) return;

      const body = document.getElementById("chatBody");
      body.innerHTML += `
        <div class="msg-row me">
          <div>
            <div class="msg-bubble me">${text}</div>
            <div class="msg-time">HR · vừa xong</div>
          </div>
        </div>
      `;
      body.scrollTop = body.scrollHeight;
      input.value = "";
    }

    document.getElementById("btnSend").onclick = sendMessage;
    document.getElementById("chatInput").addEventListener("keydown", e => {
      if (e.key === "Enter") sendMessage();
    });

    // Chọn ứng viên
    const items = document.querySelectorAll(".candidate-item");
    items.forEach(item => {
      item.addEventListener("click", () => {
        items.forEach(i => i.classList.remove("active"));
        item.classList.add("active");

        document.getElementById("currentName").textContent     = item.dataset.name;
        document.getElementById("currentAvatar").textContent   = item.dataset.avatar;
        document.getElementById("currentPosition").textContent = item.dataset.position;

        const status = item.dataset.status;
        const dot = document.getElementById("currentStatusDot");
        const txt = document.getElementById("currentStatus");

        if (status === "online") {
          dot.className = "bi bi-dot status-online";
          txt.textContent = "Đang online";
        } else {
          dot.className = "bi bi-dot status-offline";
          txt.textContent = "Ngoại tuyến";
        }

        // Nội dung demo theo ứng viên
        const body = document.getElementById("chatBody");
        body.innerHTML = "";

        if (item.dataset.name === "Nguyễn Thành Tùng") {
          body.innerHTML = `
            <div class="msg-row">
              <div>
                <div class="msg-bubble them">
                  Chào anh/chị, em cảm ơn vì đã đọc CV vị trí FullStack của em ạ.
                </div>
                <div class="msg-time">Ứng viên · 09:10</div>
              </div>
            </div>
          `;
        }
        if (item.dataset.name === "Lê Thu Hà") {
          body.innerHTML = `
            <div class="msg-row">
              <div>
                <div class="msg-bubble them">
                  Chào anh/chị, em đã gửi CV cho vị trí Frontend Intern ạ.
                </div>
                <div class="msg-time">Ứng viên · Hôm qua</div>
              </div>
            </div>
          `;
        }
        if (item.dataset.name === "Vũ Quốc Nhật") {
          body.innerHTML = `
            <div class="msg-row">
              <div>
                <div class="msg-bubble them">
                  Em cảm ơn anh/chị đã đọc CV vị trí Backend Intern của em.
                </div>
                <div class="msg-time">Ứng viên · 2 ngày trước</div>
              </div>
            </div>
          `;
        }

        body.scrollTop = body.scrollHeight;
      });
    });

    // Tìm kiếm ứng viên
    document.getElementById("search").addEventListener("input", function () {
      const q = this.value.toLowerCase();
      items.forEach(item => {
        const str = item.dataset.name.toLowerCase() + item.dataset.position.toLowerCase();
        item.style.display = str.includes(q) ? "" : "none";
      });
    });
  </script>

</body>
</html>
