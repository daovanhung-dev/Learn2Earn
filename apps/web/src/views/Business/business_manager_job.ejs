<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Quản lý JD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body { background: #f4faff; }
    .card { border-radius: 12px; }
    .btn-blue { background: #0d6efd; color: #fff; }
  </style>
</head>

<body>
    <%- include('../ComponentBusiness/header') %>

<div class="container my-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold">Quản lý JD</h3>

    <!-- Nút chuyển trang tạo JD -->
    <button 
      class="btn btn-primary" 
      onclick="window.location.href='/Business/PostJob'"
    >
      + Thêm JD
    </button>
  </div>

  <!-- Bảng danh sách JD -->
  <div class="card shadow-sm">
    <div class="card-body">
      <table class="table table-bordered table-hover">
        <thead class="table-primary">
          <tr>
            <th>ID</th>
            <th>Vị trí</th>
            <th>Phòng ban</th>
            <th>Lương</th>
            <th>Địa điểm</th>
            <th>Hạn nộp</th>
            <th>Hành động</th>
          </tr>
        </thead>

        <tbody>
          <% if (jds && jds.length > 0) { %>

            <% jds.forEach(jd => { %>
              <tr>
                <td><%= jd.id %></td>
                <td><%= jd.ten_vi_tri %></td>
                <td><%= jd.phong_ban %></td>
                <td><%= jd.muc_luong %></td>
                <td><%= jd.dia_diem %></td>
                <td><%= jd.han_nop %></td>

                <td class="text-center">

                  <!-- Nút cập nhật -> chuyển trang UpdateJD -->
                  <a 
                    href="/Business/UpdateJD/<%= jd.id %>"
                    class="btn btn-warning btn-sm"
                  >
                    Sửa
                  </a>

                  <!-- Nút xóa -->
                  <a 
                    href="/Business/DeleteJD/<%= jd.id %>" 
                    class="btn btn-danger btn-sm"
                    onclick="return confirm('Bạn chắc muốn xóa JD này?');"
                  >
                    Xóa
                  </a>

                </td>
              </tr>
            <% }); %>

          <% } else { %>
            <tr>
              <td colspan="7" class="text-center text-muted">
                Chưa có JD nào
              </td>
            </tr>
          <% } %>
        </tbody>

      </table>
    </div>
  </div>

</div>
        <%- include('../ComponentBusiness/footer') %>

</body>
</html>
