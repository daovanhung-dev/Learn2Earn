<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Learn2Earn Business - Đăng ký</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>

<style>
  body {
    background: #eef2f7;
    font-family: "Inter", sans-serif;
  }
  .auth-card {
    width: 420px;
    background: white;
    border-radius: 18px;
    padding: 30px 28px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
  }
  .logo-box {
    width: 48px;
    height: 48px;
    background: #1e2a44;
    color: white;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0 auto 10px;
  }
  .tab-btn {
    cursor: pointer;
    font-weight: 600;
    padding-bottom: 6px;
    color: #64748b;
  }
  .tab-btn.active {
    color: #1e2a44;
    border-bottom: 2px solid #1e2a44;
  }
</style>
</head>

<body>

<div class="d-flex justify-content-center align-items-center" style="min-height:100vh;">
  <div class="auth-card">

    <div class="logo-box">DN</div>
    <h4 class="text-center fw-bold mb-4">Learn2Earn Business</h4>

    <!-- TABS -->
    <div class="d-flex justify-content-around mb-4">
      <a href="business_login.html" class="tab-btn">Đăng nhập</a>
      <a href="business_register.html" class="tab-btn active">Đăng ký</a>
    </div>

    <!-- FORM REGISTER -->
    <form>
      <div class="mb-3">
        <label class="form-label fw-semibold">Tên công ty</label>
        <input type="text" class="form-control" placeholder="VD: Công ty Minh Long" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Email doanh nghiệp</label>
        <input type="email" class="form-control" placeholder="company@example.com" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Số điện thoại</label>
        <input type="text" class="form-control" placeholder="098xxxxxxx" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Mật khẩu</label>
        <input type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Nhập lại mật khẩu</label>
        <input type="password" class="form-control" placeholder="Nhập lại mật khẩu" required>
      </div>

      <button class="btn btn-dark w-100 mb-3" type="submit">
        <i class="bi bi-person-plus"></i> Tạo tài khoản
      </button>
    </form>

    <div class="text-center small mt-2 text-muted">
      Hỗ trợ doanh nghiệp: <b>support@learn2earn.vn</b>
    </div>

  </div>
</div>

</body>
</html>
