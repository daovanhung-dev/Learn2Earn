<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Cập nhật thông tin doanh nghiệp - Learn2Earn Business</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>

<style>
  body {
    background: #eef2f7;
    font-family: "Inter", sans-serif;
  }

  .page-title {
    font-weight: 700;
    font-size: 1.4rem;
    color: #1e2a44;
  }

  .card-soft {
    background: white;
    border-radius: 16px;
    border: 0;
    box-shadow: 0 4px 18px rgba(0,0,0,0.08);
  }

  .logo-box {
    width: 90px;
    height: 90px;
    border-radius: 14px;
    overflow: hidden;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.4rem;
    color: #475569;
  }
  .logo-box img { width: 100%; height: 100%; object-fit: cover; }
</style>

</head>
<body>

<div class="container py-4">

  <!-- TIÊU ĐỀ -->
  <div class="mb-4">
    <h4 class="page-title">Cập nhật thông tin doanh nghiệp</h4>
    <div class="text-muted small">
      Hãy bổ sung đầy đủ thông tin để doanh nghiệp của bạn trở nên uy tín và thu hút ứng viên hơn.
    </div>
  </div>

  <div class="card card-soft p-4">

    <!-- LOGO DOANH NGHIỆP -->
    <h6 class="fw-bold mb-3"><i class="bi bi-building me-1"></i> Logo doanh nghiệp</h6>
    <div class="d-flex align-items-center mb-4">
      <div class="logo-box me-3" id="logoPreview">DN</div>
      <div>
        <label class="form-label small">Tải logo (PNG/JPG)</label>
        <input type="file" class="form-control form-control-sm" id="logoInput" accept="image/*">
      </div>
    </div>

    <hr>

    <!-- THÔNG TIN CÔNG TY -->
    <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-1"></i> Thông tin công ty</h6>

    <div class="row g-3">

      <div class="col-md-6">
        <label class="form-label fw-semibold">Tên công ty</label>
        <input type="text" class="form-control" placeholder="VD: Công ty Minh Long" required>
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Lĩnh vực hoạt động</label>
        <select class="form-select">
          <option>Công nghệ thông tin</option>
          <option>Giáo dục</option>
          <option>Marketing</option>
          <option>Sản xuất</option>
          <option>Dịch vụ khác</option>
        </select>
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Quy mô</label>
        <select class="form-select">
          <option>1 - 10 nhân sự</option>
          <option>11 - 50 nhân sự</option>
          <option>51 - 200 nhân sự</option>
          <option>200+ nhân sự</option>
        </select>
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Website</label>
        <input type="text" class="form-control" placeholder="https://example.com">
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Email doanh nghiệp</label>
        <input type="email" class="form-control" placeholder="company@example.com">
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Hotline</label>
        <input type="text" class="form-control" placeholder="0123456789">
      </div>

      <div class="col-md-12">
        <label class="form-label fw-semibold">Địa chỉ</label>
        <input type="text" class="form-control" placeholder="Số nhà / đường / quận / thành phố">
      </div>

      <div class="col-md-12">
        <label class="form-label fw-semibold">Giới thiệu doanh nghiệp</label>
        <textarea class="form-control" rows="5" placeholder="Mô tả ngắn về doanh nghiệp..."></textarea>
      </div>

    </div>

    <hr class="my-4">

    <!-- NÚT LƯU -->
    <div class="text-end">
      <button class="btn btn-dark px-4">
        <i class="bi bi-save me-1"></i> Lưu thông tin
      </button>
    </div>

  </div>

</div>

<!-- JS -->
<script>
  // Preview logo doanh nghiệp
  document.getElementById("logoInput").addEventListener("change", function (e) {
    const file = e.target.files[0];
    if (!file) return;

    if (!file.type.startsWith("image/")) {
      alert("Vui lòng tải file ảnh hợp lệ!");
      return;
    }

    const reader = new FileReader();
    reader.onload = function (ev) {
      document.getElementById("logoPreview").innerHTML =
        `<img src="${ev.target.result}" />`;
    };
    reader.readAsDataURL(file);
  });
</script>

</body>
</html>
