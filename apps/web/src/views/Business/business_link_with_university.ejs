<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <title>Liên kết nhà trường – Learn2Earn Business</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <style>
    :root {
      --navy: #1e2a44;
      --navy-light: #2d3b57;
      --gray-bg: #f5f6f8;
      --card-bg: #ffffff;
      --text: #1e293b;
      --muted: #64748b;
      --dark-btn: #111827;
      --dark-btn-hover: #0f1623;
    }

    body {
      background: var(--gray-bg);
      font-family: "Inter", sans-serif;
      color: var(--text);
    }

    /* ===== HEADER ===== */
    .header {
      background: white;
      box-shadow: 0 2px 8px rgba(0, 0, 0, .08);
      position: sticky;
      top: 0;
      z-index: 999;
    }

    .navbar-brand img {
      height: 55px;
      transform: scale(2.2);
      transform-origin: left center;
    }

    .nav-link {
      font-weight: 500;
      color: var(--muted) !important;
      border-radius: 14px;
      padding: 8px 18px !important;
    }

    .nav-link:hover {
      background: #e6ecf5;
      color: var(--navy) !important;
    }

    .nav-link.active {
      background: #dbe4f3;
      color: var(--navy) !important;
    }

    .nav-icon {
      width: 40px;
      height: 40px;
      background: #e6ecf5;
      color: var(--navy);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: 6px;
      font-size: 18px;
    }

    .nav-icon:hover {
      background: #d4dceb;
    }

    /* ===== PAGE CONTENT ===== */
    .page {
      background: #fff;
      border: 1px solid #e9ecef;
      border-radius: .75rem;
    }

    .form-label {
      font-size: .9rem;
    }

    .status-badge {
      font-weight: 600;
    }

    /* Mobile responsive table */
    @media (max-width:575.98px) {
      .table thead {
        display: none;
      }

      .table tr {
        display: block;
        margin-bottom: 1rem;
        border: 1px solid #e9ecef;
        border-radius: .5rem;
      }

      .table td {
        display: block;
        border: 0 !important;
        border-bottom: 1px solid #f1f3f5 !important;
        padding: .65rem .9rem;
      }

      .table td:last-child {
        border-bottom: 0 !important;
      }

      .table td::before {
        content: attr(data-label);
        display: block;
        font-weight: 600;
        color: #6c757d;
        margin-bottom: .2rem;
      }

      td[data-label="Hành động"] {
        text-align: right;
      }
    }

    /* ===== FOOTER ===== */
    .footer {
      background: #020617;
      color: #E5E7EB;
      padding: 40px 0 20px;
      margin-top: 60px;
    }

    .footer-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 12px;
      color: #fff;
    }

    .footer-links {
      list-style: none;
      padding: 0;
    }

    .footer-links li {
      margin-bottom: 6px;
    }

    .footer-links a {
      color: #E5E7EB;
      font-size: .9rem;
    }

    .footer-bottom {
      border-top: 1px solid #111827;
      margin-top: 20px;
      padding-top: 12px;
      text-align: center;
      font-size: .85rem;
    }
  </style>
</head>

<body>

  <!-- ========== HEADER ========== -->
  <header class="header">
    <nav class="navbar navbar-expand-lg navbar-light">
      <div class="container">

        <a class="navbar-brand" href="#">
          <img src="/img/logo-nobr.png" alt="Logo Learn2Earn">
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-between" id="navMenu">

          <ul class="navbar-nav mx-auto">
            <li class="nav-item"><a class="nav-link" href="/Business">Trang chủ</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Quản lý tin tuyển dụng</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Ứng viên</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Chat</a></li>
            <li class="nav-item"><a class="nav-link active" href="#">Thống kê</a></li>
          </ul>

          <ul class="navbar-nav ms-auto d-flex align-items-center">
            <li class="nav-item"><a class="nav-icon" href="#"><i class="fa-regular fa-bell"></i></a></li>
            <li class="nav-item"><a class="nav-icon" href="#"><i class="fa-regular fa-comment-dots"></i></a></li>
            <li class="nav-item"><a class="nav-link" href="#">Cài đặt</a></li>
          </ul>

        </div>
      </div>
    </nav>
  </header>

  <!-- ========== CONTENT ========== -->
  <main class="container my-4">
    <div class="page p-3 p-md-4">
      <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
        <div>
          <h5 class="mb-1">Liên kết nhà trường</h5>
          <div class="text-secondary">Kết nối và quản lý đối tác học thuật</div>
        </div>
        <div class="ms-auto small text-secondary"><span id="resultCount">0</span> kết quả</div>
      </div>

      <!-- FILTERS -->
      <form id="filterForm" class="row g-3 mb-3">
        <div class="col-12 col-md-4">
          <label class="form-label" for="q">Tên trường / Email</label>
          <input id="q" type="search" class="form-control" placeholder="Nhập tên hoặc email...">
        </div>
        <div class="col-6 col-md-3">
          <label class="form-label" for="city">Tỉnh/TP</label>
          <select id="city" class="form-select">
            <option value="">Tất cả</option>
            <option>Hà Nội</option>
            <option>TP. HCM</option>
            <option>Đà Nẵng</option>
            <option>Huế</option>
          </select>
        </div>
        <div class="col-6 col-md-3">
          <label class="form-label" for="status">Trạng thái</label>
          <select id="status" class="form-select">
            <option value="">Tất cả</option>
            <option value="connected">Đang kết nối</option>
            <option value="pending">Chờ duyệt</option>
            <option value="not">Chưa kết nối</option>
          </select>
        </div>
        <div class="col-12 col-md-2 d-flex gap-2">
          <button type="button" id="btnSearch" class="btn btn-primary w-100 mt-auto">Tìm</button>
          <button type="button" id="btnReset" class="btn btn-outline-secondary w-100 mt-auto">Xoá</button>
        </div>
      </form>

      <!-- TABLE -->
      <div class="table-responsive">
        <table id="schoolTable" class="table align-middle">
          <thead class="table-light">
            <tr class="text-center">
              <th class="text-start">Tên trường</th>
              <th>Địa chỉ</th>
              <th class="text-start">Email</th>
              <th>Trạng thái</th>
              <th>Hành động</th>
            </tr>
          </thead>
          <tbody id="tbody">
            <!-- dữ liệu mẫu -->
            <tr data-city="Hà Nội" data-status="connected">
              <td data-label="Tên trường">ĐH Công nghệ — VNU</td>
              <td data-label="Địa chỉ" class="text-center">Hà Nội</td>
              <td data-label="Email">contact@vnu.edu.vn</td>
              <td data-label="Trạng thái" class="text-center">
                <span class="text-success status-badge">Đang kết nối</span>
              </td>
              <td data-label="Hành động" class="text-center">
                <div class="btn-group">
                  <button class="btn btn-primary btn-sm btn-connect" data-name="ĐH Công nghệ — VNU">Kết nối</button>
                  <button class="btn btn-outline-primary btn-sm btn-detail"
                    data-name="ĐH Công nghệ — VNU"
                    data-email="contact@vnu.edu.vn"
                    data-city="Hà Nội"
                    data-note="Đối tác chiến lược">Chi tiết</button>
                </div>
              </td>
            </tr>

            <tr data-city="Hà Nội" data-status="pending">
              <td data-label="Tên trường">ĐH Bách Khoa</td>
              <td data-label="Địa chỉ" class="text-center">Hà Nội</td>
              <td data-label="Email">abc@hust.edu.vn</td>
              <td data-label="Trạng thái" class="text-center">
                <span class="text-warning status-badge">Chờ duyệt</span>
              </td>
              <td data-label="Hành động" class="text-center">
                <div class="btn-group">
                  <button class="btn btn-primary btn-sm btn-connect" data-name="ĐH Bách Khoa">Kết nối</button>
                  <button class="btn btn-outline-primary btn-sm btn-detail"
                    data-name="ĐH Bách Khoa"
                    data-email="abc@hust.edu.vn"
                    data-city="Hà Nội"
                    data-note="Kỹ thuật – hợp tác nghiên cứu">Chi tiết</button>
                </div>
              </td>
            </tr>

            <tr data-city="TP. HCM" data-status="not">
              <td data-label="Tên trường">ĐH Khoa học Tự nhiên</td>
              <td data-label="Địa chỉ" class="text-center">TP. HCM</td>
              <td data-label="Email">info@hcmus.edu.vn</td>
              <td data-label="Trạng thái" class="text-center">
                <span class="text-danger status-badge">Chưa kết nối</span>
              </td>
              <td data-label="Hành động" class="text-center">
                <div class="btn-group">
                  <button class="btn btn-primary btn-sm btn-connect" data-name="ĐH Khoa học Tự nhiên">Kết nối</button>
                  <button class="btn btn-outline-primary btn-sm btn-detail"
                    data-name="ĐH Khoa học Tự nhiên"
                    data-email="info@hcmus.edu.vn"
                    data-city="TP. HCM"
                    data-note="Khối KHTN">Chi tiết</button>
                </div>
              </td>
            </tr>

            <tr data-city="Đà Nẵng" data-status="not">
              <td data-label="Tên trường">ĐH Bách Khoa Đà Nẵng</td>
              <td data-label="Địa chỉ" class="text-center">Đà Nẵng</td>
              <td data-label="Email">contact@dut.udn.vn</td>
              <td data-label="Trạng thái" class="text-center">
                <span class="text-danger status-badge">Chưa kết nối</span>
              </td>
              <td data-label="Hành động" class="text-center">
                <div class="btn-group">
                  <button class="btn btn-primary btn-sm btn-connect" data-name="ĐH Bách Khoa Đà Nẵng">Kết nối</button>
                  <button class="btn btn-outline-primary btn-sm btn-detail"
                    data-name="ĐH Bách Khoa Đà Nẵng"
                    data-email="contact@dut.udn.vn"
                    data-city="Đà Nẵng"
                    data-note="Kỹ thuật miền Trung">Chi tiết</button>
                </div>
              </td>
            </tr>

            <tr data-city="Huế" data-status="connected">
              <td data-label="Tên trường">ĐH Nông Lâm Huế</td>
              <td data-label="Địa chỉ" class="text-center">Huế</td>
              <td data-label="Email">partner@huaf.edu.vn</td>
              <td data-label="Trạng thái" class="text-center">
                <span class="text-success status-badge">Đang kết nối</span>
              </td>
              <td data-label="Hành động" class="text-center">
                <div class="btn-group">
                  <button class="btn btn-primary btn-sm btn-connect" data-name="ĐH Nông Lâm Huế">Kết nối</button>
                  <button class="btn btn-outline-primary btn-sm btn-detail"
                    data-name="ĐH Nông Lâm Huế"
                    data-email="partner@huaf.edu.vn"
                    data-city="Huế"
                    data-note="Nông nghiệp – hợp tác đào tạo">Chi tiết</button>
                </div>
              </td>
            </tr>

          </tbody>
        </table>
      </div>

      <!-- PAGINATION -->
      <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="small text-secondary">Hiển thị <span id="rangeInfo">0–0</span></div>
        <nav aria-label="Trang">
          <ul id="pager" class="pagination pagination-sm mb-0"></ul>
        </nav>
      </div>
    </div>
  </main>

  <!-- ========== FOOTER ========== -->
  <footer class="footer">
    <div class="container">
      <div class="row">

        <div class="col-lg-4 mb-4">
          <h4 class="footer-title">Learn2Earn</h4>
          <p>Nền tảng hỗ trợ tuyển dụng và tìm kiếm ứng viên chất lượng cao.</p>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Về chúng tôi</h4>
          <ul class="footer-links">
            <li><a href="#">Giới thiệu</a></li>
            <li><a href="#">Tin tức</a></li>
            <li><a href="#">Tuyển dụng</a></li>
            <li><a href="#">Liên hệ</a></li>
          </ul>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Doanh nghiệp</h4>
          <ul class="footer-links">
            <li><a href="#">Đăng tin</a></li>
            <li><a href="#">Quản lý ứng viên</a></li>
            <li><a href="#">Gói dịch vụ</a></li>
            <li><a href="#">Hỗ trợ</a></li>
          </ul>
        </div>

        <div class="col-lg-2 col-md-4 mb-4">
          <h4 class="footer-title">Liên hệ</h4>
          <ul class="footer-links">
            <li><a href="#"><i class="fas fa-phone me-2"></i>+84 123 456 789</a></li>
            <li><a href="#"><i class="fas fa-envelope me-2"></i>support@learn2earn.vn</a></li>
            <li><a href="#"><i class="fas fa-map-marker-alt me-2"></i>Hà Nội, Việt Nam</a></li>
          </ul>
        </div>

      </div>

      <div class="footer-bottom">
        &copy; 2024 Learn2Earn. All rights reserved.
      </div>
    </div>
  </footer>

  <!-- MODAL XÁC NHẬN -->
  <div class="modal fade" id="connectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h6 class="modal-title">Xác nhận kết nối</h6>
          <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          Bạn muốn gửi yêu cầu kết nối tới <strong id="connectName">...</strong>?
        </div>
        <div class="modal-footer">
          <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Huỷ</button>
          <button class="btn btn-primary" id="btnDoConnect">Gửi yêu cầu</button>
        </div>
      </div>
    </div>
  </div>

  <!-- OFFCANVAS CHI TIẾT -->
  <div class="offcanvas offcanvas-end" tabindex="-1" id="detailCanvas">
    <div class="offcanvas-header">
      <h5 class="offcanvas-title" id="detailTitle">Chi tiết trường</h5>
      <button class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
      <dl class="row">
        <dt class="col-4">Email</dt>
        <dd class="col-8" id="detailEmail">—</dd>
        <dt class="col-4">Địa chỉ</dt>
        <dd class="col-8" id="detailCity">—</dd>
        <dt class="col-4">Ghi chú</dt>
        <dd class="col-8" id="detailNote">—</dd>
      </dl>
      <button class="btn btn-primary btn-sm" id="detailConnect">Kết nối</button>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    (() => {
      const q = document.getElementById('q');
      const city = document.getElementById('city');
      const status = document.getElementById('status');
      const tbody = document.getElementById('tbody');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      const resultCount = document.getElementById('resultCount');
      const rangeInfo = document.getElementById('rangeInfo');
      const pager = document.getElementById('pager');
      const pageSize = 5;

      let filtered = rows.slice();
      let page = 1;

      function normalize(s) {
        return (s || '').toLowerCase().trim();
      }

      function applyFilter() {
        const k = normalize(q.value);
        const c = city.value;
        const st = status.value;

        filtered = rows.filter(tr => {
          const text = normalize(tr.innerText);
          const okK = !k || text.includes(k);
          const okC = !c || tr.dataset.city === c;
          const okS = !st || tr.dataset.status === st;
          return okK && okC && okS;
        });

        page = 1;
        render();
      }

      function render() {
        rows.forEach(tr => tr.style.display = 'none');

        const total = filtered.length;
        const pages = Math.max(1, Math.ceil(total / pageSize));
        if (page > pages) page = pages;

        const start = (page - 1) * pageSize;
        const end = Math.min(start + pageSize, total);

        filtered.slice(start, end).forEach(tr => tr.style.display = 'table-row');

        resultCount.textContent = total;
        rangeInfo.textContent = total ? `${start + 1}–${end}` : '0–0';

        pager.innerHTML = '';
        const makeItem = (label, p, disabled = false, active = false) => {
          const li = document.createElement('li');
          li.className = `page-item ${disabled ? 'disabled' : ''} ${active ? 'active' : ''}`;
          const a = document.createElement('a');
          a.className = 'page-link';
          a.href = '#';
          a.textContent = label;
          a.onclick = (e) => { e.preventDefault(); if (!disabled) { page = p; render(); } };
          li.appendChild(a);
          pager.appendChild(li);
        };
        makeItem('«', Math.max(1, page - 1), page === 1);
        for (let i = 1; i <= pages; i++) makeItem(i, i, false, i === page);
        makeItem('»', Math.min(pages, page + 1), page === pages);
      }

      document.getElementById('btnSearch').addEventListener('click', applyFilter);

      document.getElementById('btnReset').addEventListener('click', () => {
        q.value = ''; city.value = ''; status.value = ''; applyFilter();
      });

      [q, city, status].forEach(el => el.addEventListener('keydown', e => {
        if (e.key === 'Enter') { e.preventDefault(); applyFilter(); }
      }));

      // ===== Modal Kết nối =====
      const connectModal = new bootstrap.Modal('#connectModal');
      let pendingSchool = '';

      tbody.addEventListener('click', (e) => {
        const btnConnect = e.target.closest('.btn-connect');
        const btnDetail = e.target.closest('.btn-detail');

        if (btnConnect) {
          pendingSchool = btnConnect.dataset.name;
          document.getElementById('connectName').textContent = pendingSchool;
          connectModal.show();
        }

        if (btnDetail) {
          document.getElementById('detailTitle').textContent = btnDetail.dataset.name;
          document.getElementById('detailEmail').textContent = btnDetail.dataset.email;
          document.getElementById('detailCity').textContent = btnDetail.dataset.city;
          document.getElementById('detailNote').textContent = btnDetail.dataset.note;

          // chuẩn bị nút "Kết nối" trong offcanvas
          document.getElementById('detailConnect').dataset.name = btnDetail.dataset.name;

          const offcanvas = new bootstrap.Offcanvas('#detailCanvas');
          offcanvas.show();
        }
      });

      document.getElementById('btnDoConnect').addEventListener('click', () => {
        connectModal.hide();

        const toast = document.createElement('div');
        toast.className = 'toast align-items-center text-bg-primary border-0 position-fixed bottom-0 end-0 m-3';
        toast.setAttribute('role', 'alert');

        toast.innerHTML = `
          <div class="d-flex">
            <div class="toast-body">
              Đã gửi yêu cầu kết nối tới <strong>${pendingSchool}</strong>.
            </div>
            <button class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
          </div>
        `;

        document.body.appendChild(toast);
        new bootstrap.Toast(toast).show();
      });

      // nút "Kết nối" trong offcanvas
      document.getElementById('detailConnect').addEventListener('click', (e) => {
        const name = e.target.dataset.name || document.getElementById('detailTitle').textContent;
        pendingSchool = name;
        document.getElementById('connectName').textContent = pendingSchool;

        const offcanvasEl = document.getElementById('detailCanvas');
        const offcanvasInstance = bootstrap.Offcanvas.getInstance(offcanvasEl);
        if (offcanvasInstance) offcanvasInstance.hide();

        connectModal.show();
      });

      // Khởi tạo lần đầu
      applyFilter();
    })();
  </script>

</body>
</html>
