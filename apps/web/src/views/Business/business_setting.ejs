<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>Cài đặt - Doanh nghiệp</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
        :root {
            --navy: #1e2a44;
            --navy-light: #2d3b57;
            --gray-bg: #f1f5f9;
            --card-bg: #ffffff;
            --text: #1e293b;
            --muted: #64748b;
            --dark-btn: #111827;
            --dark-btn-hover: #0f1623;
        }

        body {
            background: var(--gray-bg);
            font-family: "Inter", sans-serif;
            color: var(--text);
        }

        /* HEADER */
        .header {
            background: white;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .l2e-logo {
            height: 55px;
            transform: scale(2.2);
            transform-origin: left center;
        }

        /* Nav links */
        .nav-link {
            font-weight: 500;
            color: var(--muted) !important;
            border-radius: 14px;
            padding: 8px 18px !important;
        }

        .nav-link:hover {
            background: #e6ecf5;
            color: var(--navy) !important;
        }

        .nav-link.active {
            background: #dbe4f3;
            color: var(--navy) !important;
        }

        .nav-icon {
            width: 40px;
            height: 40px;
            background: #e6ecf5;
            color: var(--navy);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: 6px;
            font-size: 18px;
        }

        .nav-icon:hover {
            background: #d4dceb;
            color: var(--navy);
        }

        /* FOOTER */
        .footer {
            background: #020617;
            color: #e5e7eb;
            padding: 40px 0 20px;
            margin-top: 60px;
        }

        .footer-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #fff;
        }

        .footer-links {
            list-style: none;
            padding: 0;
        }

        .footer-links li {
            margin-bottom: 6px;
        }

        .footer-links a {
            color: #e5e7eb;
            font-size: 0.9rem;
            text-decoration: none;
        }

        .footer-links a:hover {
            text-decoration: underline;
        }

        .footer-bottom {
            border-top: 1px solid #111827;
            margin-top: 20px;
            padding-top: 12px;
            text-align: center;
            font-size: 0.85rem;
        }

    :root{
      --brand: #0ea5a4;
      --muted: #6c757d;
      --card-radius: 12px;
    }
    body{ background:#f6fbfb; font-family:Inter, system-ui, sans-serif; }
    .container-main{ max-width:980px; margin:40px auto; }

    .brand-bar{
      background:linear-gradient(90deg, rgba(14,165,164,0.06), rgba(14,165,164,0.02));
      padding:18px;
      border-radius:14px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      border:1px solid rgba(14,165,164,0.08);
    }
    .company-name { font-weight:600; color:#064e4d; }
    .card-custom{ border:1px solid rgba(6,78,77,0.06); border-radius:var(--card-radius); box-shadow:0 6px 18px rgba(8,60,60,0.03); }
    .section-title{ font-size:0.95rem; font-weight:600; color:#073737; }
    .muted{ color:var(--muted); font-size:0.9rem; }
    .logout-btn{ background:transparent; border:1px solid rgba(14,165,164,0.18); color:var(--brand); }
    .small-note{ font-size:0.85rem; color:#6b7280; }
  </style>
</head>
<body>

<div class="container-main">
    <%- include('../ComponentBusiness/header') %>

  <!-- Banner -->
  <div class="brand-bar mb-4 card-custom p-3">
    <div>
      <div class="company-name">Công ty TNHH ABC</div>
      <div class="muted">Tài khoản doanh nghiệp • ID: 001</div>
    </div>

    <div class="d-flex gap-2">
      <button class="btn btn-sm logout-btn" onclick="confirmLogout()">Đăng xuất</button>
    </div>
  </div>

  <!-- Nội dung chính -->
  <div class="card card-custom p-4 mb-4">
    <div class="row g-4">

      <!-- Thông tin công ty -->
      <div class="col-md-6">
        <div class="section-title mb-2">Thông tin công ty</div>

        <div class="mb-2"><strong>Tên:</strong> <span class="muted">Công ty TNHH ABC</span></div>
        <div class="mb-2"><strong>Email:</strong> <span class="muted">company@gmail.com</span></div>
        <div class="mb-2"><strong>Địa chỉ:</strong> <span class="muted">Hà Nội, Việt Nam</span></div>

        <div class="mt-3">
          <button class="btn btn-sm btn-outline-primary">Sửa thông tin</button>
        </div>
      </div>

      <!-- Đổi mật khẩu -->
      <div class="col-md-6">
        <div class="section-title mb-2">Đổi mật khẩu</div>

        <div class="row g-2">
          <div class="col-12">
            <label class="form-label small">Mật khẩu hiện tại</label>
            <input type="password" class="form-control form-control-sm">
          </div>

          <div class="col-md-6">
            <label class="form-label small">Mật khẩu mới</label>
            <input type="password" class="form-control form-control-sm">
          </div>

          <div class="col-md-6">
            <label class="form-label small">Nhập lại</label>
            <input type="password" class="form-control form-control-sm">
          </div>

          <div class="col-12">
            <button class="btn btn-sm btn-primary mt-1">Cập nhật mật khẩu</button>
          </div>
        </div>
      </div>

      <!-- Thông báo -->
      <div class="col-12">
        <hr>
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="section-title">Thông báo</div>
            <div class="muted">Bật / tắt các phương thức nhận thông báo</div>
          </div>

          <div class="d-flex gap-3 align-items-center">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" checked>
              <label class="form-check-label">Email</label>
            </div>

            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox">
              <label class="form-check-label">SMS</label>
            </div>

            <button class="btn btn-sm btn-outline-success">Lưu</button>
          </div>
        </div>
      </div>

      <!-- Xóa tài khoản -->
      <div class="col-12">
        <hr>
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="section-title text-danger">Nguy hiểm</div>
            <div class="muted">Xóa tài khoản sẽ khiến toàn bộ dữ liệu bị xóa vĩnh viễn.</div>
          </div>

          <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete()">Xóa tài khoản</button>
        </div>
      </div>

    </div>
  </div>

  <div class="text-center muted small-note">Learn2Earn Business Version</div>
</div>

<script>
  function confirmLogout(){
    if(confirm("Bạn có chắc muốn đăng xuất?")){
      alert("Đã đăng xuất!");
      window.location.href='Logout';
    }
  }

  function confirmDelete(){
    if(confirm("Bạn chắc chắn muốn xóa tài khoản?")){
      alert("Tài khoản đã bị xóa!");
    }
  }
</script>
        <%- include('../ComponentBusiness/footer') %>

</body>
</html>
